flowchart LR
  subgraph Client[Browser / Frontend]
    U[User]
    W[Widget JS\nassistant-widget.js]
    P[/assistant Page\nassistant-page.html.twig]
    DL[dataLayer GA events]
  end

  subgraph Drupal[Drupal 11 / ilas_site_assistant]
