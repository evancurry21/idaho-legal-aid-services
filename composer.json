{
    "name": "drupal/cms",
    "version": "1.1.3",
    "description": "Drupal CMS is a ready-to-use platform built on Drupal core, offering smart defaults to get started quickly and enterprise-grade tools for marketers, designers, and content creators.",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/drupal",
    "support": {
        "docs": "https://drupal.org/docs/user_guide/en/index.html",
        "chat": "https://drupal.org/node/314178"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "path",
            "url": "upstream-configuration"
        }
    ],
    "require": {
        "composer/installers": "^2.3",
        "cweagans/composer-patches": "^2.0",
        "dompdf/dompdf": "^3.1",
        "dropsolid/langfuse-php-sdk": "^1.2",
        "drupal/ai": "^1.3",
        "drupal/ai_provider_google_vertex": "^1.1",
        "drupal/ai_seo": "^1.0",
        "drupal/ai_vdb_provider_pinecone": "^1.1@beta",
        "drupal/antibot": "^2.0",
        "drupal/bootstrap5": "^4.0",
        "drupal/bootstrap_layout_builder": "^2.2",
        "drupal/bootstrap_styles": "^1.2",
        "drupal/ckeditor5_plugin_pack": "^1.3",
        "drupal/ckeditor_link_styles": "^1.1",
        "drupal/core-composer-scaffold": "^11",
        "drupal/core-project-message": "^11",
        "drupal/core-recommended": "^11",
        "drupal/drupal_cms_accessibility_tools": "^1.1",
        "drupal/drupal_cms_ai": "^1.1",
        "drupal/drupal_cms_blog": "^1.1",
        "drupal/drupal_cms_case_study": "^1.1",
        "drupal/drupal_cms_events": "^1.1",
        "drupal/drupal_cms_forms": "^1.1",
        "drupal/drupal_cms_news": "^1.1",
        "drupal/drupal_cms_page": "^1.1",
        "drupal/drupal_cms_person": "^1.1",
        "drupal/drupal_cms_project": "^1.1",
        "drupal/drupal_cms_seo_tools": "^1.1",
        "drupal/drupal_cms_starter": "^1.1",
        "drupal/editor_advanced_link": "^2.3",
        "drupal/gemini_provider": "^1.0@beta",
        "drupal/google_analytics": "^4.0",
        "drupal/google_cse": "^5.0",
        "drupal/google_translator": "^2.3",
        "drupal/hreflang": "^1.16",
        "drupal/imce": "^3.1",
        "drupal/layout_paragraphs": "^2.1",
        "drupal/mailsystem": "^4.5",
        "drupal/metatag_ai": "^2.0",
        "drupal/paragraphs": "^1.19",
        "drupal/project_browser": "@beta",
        "drupal/raven": "^7.3",
        "drupal/recipe_installer_kit": "^1-alpha3@alpha",
        "drupal/schema_metatag": "^3.0",
        "drupal/search_api_db": "^1.0",
        "drupal/search_api_page": "^1.1",
        "drupal/seckit": "^2.0",
        "drupal/tmgmt": "^1.17",
        "drupal/tmgmt_google": "^1.2",
        "drupal/turnstile": "^1.1",
        "drupal/twig_tweak": "^3.4",
        "drupal/views_infinite_scroll": "^2.0",
        "drupal/webform": "@beta",
        "drush/drush": "^13.6",
        "pantheon-systems/drupal-integrations": "^11",
        "pantheon-upstreams/upstream-configuration": "dev-main",
        "setasign/fpdf": "^1.8",
        "setasign/fpdi": "^2.6"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "php-http/discovery": true,
            "cweagans/composer-patches": true
        },
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3.0"
        },
        "preferred-install": {
            "dist": "dist"
        }
    },
    "extra": {
        "patches": {
            "drupal/core": {
                "BigPipe undefined array key fix (https://www.drupal.org/project/drupal/issues/3194462)": "patches/bigpipe-undefined-array-key-3194462.patch"
            },
            "drupal/tmgmt": {
                "Fix paragraphs asymmetric translation saving source instead of translated text (https://www.drupal.org/project/tmgmt/issues/3134922)": "patches/tmgmt-paragraphs-3134922-46.patch"
            },
            "google-gemini-php/client": {
                "Handle missing description field in v1beta model listing": "patches/gemini-php-model-description-optional.patch"
            },
            "drupal/gemini_provider": {
                "Use v1beta API for embedding model support + gemini-embedding-001 vector size": "patches/gemini-provider-v1beta.patch"
            },
            "drupal/ai_vdb_provider_pinecone": {
                "Add query-only Pinecone timeout client and config controls": "patches/ai-vdb-provider-pinecone-query-timeouts.patch"
            }
        },
        "compile-mode": "all",
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            },
            "file-mapping": {
                "[web-root]/robots.txt": false
            }
        },
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": ["type:drupal-library"],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/Commands/contrib/{$name}": ["type:drupal-drush"],
            "web/modules/custom/{$name}": ["type:drupal-custom-module"],
            "web/profiles/custom/{$name}": ["type:drupal-custom-profile"],
            "recipes/{$name}": ["type:drupal-recipe"],
            "web/themes/custom/{$name}": ["type:drupal-custom-theme"]
        },
        "drupal-core-project-message": {
            "include-keys": ["homepage", "support"],
            "post-create-project-cmd-message": [
                "<bg=blue;fg=white>                                                   </>",
                "<bg=blue;fg=white>  Congratulations, you’ve installed Drupal CMS!    </>",
                "<bg=blue;fg=white>                                                   </>",
                "",
                "<bg=yellow;fg=black>Next steps</>:",
                "  * Read the user guide: https://www.drupal.org/docs/user_guide/en/index.html",
                "  * Get support: https://drupal.org/support",
                "  * Get involved with the Drupal community: https://drupal.org/getting-involved"
            ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Drupal\\ilas_site_assistant\\": "web/modules/custom/ilas_site_assistant/src/",
            "Drupal\\Tests\\ilas_site_assistant\\": "web/modules/custom/ilas_site_assistant/tests/src/"
        }
    },
    "require-dev": {
        "behat/mink": "^1.13",
        "behat/mink-browserkit-driver": "^2.3",
        "mikey179/vfsstream": "^1.6",
        "phpspec/prophecy-phpunit": "^2.4",
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "test:pure": "vendor/bin/phpunit -c phpunit.pure.xml",
        "test:drupal": "vendor/bin/phpunit -c phpunit.xml --testsuite drupal-unit",
        "test:all": "vendor/bin/phpunit -c phpunit.xml"
    }
}
