diff --git a/src/QueryTimeoutPineconeClient.php b/src/QueryTimeoutPineconeClient.php
new file mode 100644
index 0000000..2ba8ac4
--- /dev/null
+++ b/src/QueryTimeoutPineconeClient.php
@@ -0,0 +1,27 @@
+<?php
+
+namespace Drupal\ai_vdb_provider_pinecone;
+
+use Probots\Pinecone\Client as PineconeClient;
+use Saloon\Traits\Plugins\HasTimeout;
+
+/**
+ * Pinecone client variant with query-only transport timeouts.
+ */
+final class QueryTimeoutPineconeClient extends PineconeClient {
+
+  use HasTimeout;
+
+  /**
+   * Constructs a timeout-aware Pinecone query client.
+   */
+  public function __construct(
+    string $api_key,
+    ?string $index_host = NULL,
+    protected float $connectTimeout = 1.0,
+    protected float $requestTimeout = 2.0,
+  ) {
+    parent::__construct($api_key, $index_host);
+  }
+
+}
