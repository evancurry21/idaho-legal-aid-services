<?php

/**
 * @file
 * Install, update and uninstall functions for the ILAS Site Assistant module.
 */

/**
 * Implements hook_schema().
 */
function ilas_site_assistant_schema() {
  $schema = [];

  // Aggregated analytics table (no PII).
  $schema['ilas_site_assistant_stats'] = [
    'description' => 'Stores aggregated non-PII analytics for the Site Assistant.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'event_type' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'description' => 'Type of event (chat_open, topic_selected, resource_click, etc.)',
      ],
      'event_value' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
        'description' => 'Event value (topic name, URL path, etc.) - no PII',
      ],
      'count' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 1,
        'description' => 'Aggregated count for this event type/value combination.',
      ],
      'date' => [
        'type' => 'varchar',
        'length' => 10,
        'not null' => TRUE,
        'description' => 'Date in YYYY-MM-DD format.',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'date' => ['date'],
      'event_date' => ['event_type', 'date'],
      'event_value' => ['event_type', 'event_value'],
    ],
    'unique keys' => [
      'event_date_value' => ['event_type', 'event_value', 'date'],
    ],
  ];

  // Metadata-only "no_answer" fingerprints for content gap analysis.
  $schema['ilas_site_assistant_no_answer'] = [
    'description' => 'Stores metadata-only fingerprints for queries that had no matching results.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'query_hash' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'description' => 'Hash of the normalized redacted query for deduplication.',
      ],
      'language_hint' => [
        'type' => 'varchar',
        'length' => 16,
        'not null' => TRUE,
        'default' => 'unknown',
        'description' => 'Coarse language hint for aggregate reporting.',
      ],
      'length_bucket' => [
        'type' => 'varchar',
        'length' => 16,
        'not null' => TRUE,
        'default' => 'empty',
        'description' => 'Bucketed query length for observability.',
      ],
      'redaction_profile' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => 'none',
        'description' => 'Sorted token labels describing what redaction classes were present.',
      ],
      'count' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 1,
      ],
      'first_seen' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'Unix timestamp when first recorded.',
      ],
      'last_seen' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'Unix timestamp when last recorded.',
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'query_hash' => ['query_hash'],
    ],
    'indexes' => [
      'count' => ['count'],
      'last_seen' => ['last_seen'],
    ],
  ];

  // Opt-in conversation metadata log table (no message text, short retention).
  $schema['ilas_site_assistant_conversations'] = [
    'description' => 'Opt-in conversation logs for QA/debugging using metadata-only message fingerprints.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'conversation_id' => [
        'type' => 'varchar',
        'length' => 36,
        'not null' => TRUE,
        'description' => 'UUID grouping messages in one conversation.',
      ],
      'direction' => [
        'type' => 'varchar',
        'length' => 10,
        'not null' => TRUE,
        'description' => 'Message direction: user or assistant.',
      ],
      'message_hash' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Hash of the normalized redacted message text.',
      ],
      'message_length_bucket' => [
        'type' => 'varchar',
        'length' => 16,
        'not null' => TRUE,
        'default' => 'empty',
        'description' => 'Bucketed message length for observability.',
      ],
      'redaction_profile' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => 'none',
        'description' => 'Sorted token labels describing what redaction classes were present.',
      ],
      'intent' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => FALSE,
        'description' => 'Detected intent type.',
      ],
      'response_type' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => FALSE,
        'description' => 'Response type (faq, navigation, escalation, etc.).',
      ],
      'created' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'Unix timestamp.',
      ],
      'request_id' => [
        'type' => 'varchar',
        'length' => 36,
        'not null' => FALSE,
        'default' => NULL,
        'description' => 'Per-request correlation UUID for tracing across logs.',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'conversation' => ['conversation_id'],
      'created' => ['created'],
      'intent_created' => ['intent', 'created'],
      'request_id' => ['request_id'],
    ],
  ];

  $schema['ilas_site_assistant_conversation_state'] = ilas_site_assistant_conversation_state_schema_definition();

  return $schema;
}

/**
 * Returns the durable assistant conversation-state schema definition.
 */
function ilas_site_assistant_conversation_state_schema_definition(): array {
  return [
    'description' => 'Stores short-lived durable assistant flow state keyed by conversation UUID.',
    'fields' => [
      'conversation_id' => [
        'type' => 'varchar',
        'length' => 36,
        'not null' => TRUE,
        'description' => 'UUID grouping assistant state for one conversation.',
      ],
      'session_fingerprint' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Hashed session binding used to invalidate stale cross-session state.',
      ],
      'pending_flow_type' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Currently active durable flow identifier, if any.',
      ],
      'pending_flow_origin_intent' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Intent that armed the pending flow state.',
      ],
      'pending_flow_remaining_turns' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Remaining turn budget for the pending flow.',
      ],
      'pending_flow_created' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Unix timestamp when the pending flow state was created.',
      ],
      'updated' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Unix timestamp when the durable state row was last updated.',
      ],
      'expires' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Unix timestamp when the durable state row must expire.',
      ],
    ],
    'primary key' => ['conversation_id'],
    'indexes' => [
      'expires' => ['expires'],
    ],
  ];
}

/**
 * Add conversation log table for opt-in QA/debugging.
 */
function ilas_site_assistant_update_10001() {
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('ilas_site_assistant_conversations')) {
    $table = [
      'description' => 'Opt-in conversation logs for QA/debugging using metadata-only message fingerprints.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'unsigned' => TRUE,
          'not null' => TRUE,
        ],
        'conversation_id' => [
          'type' => 'varchar',
          'length' => 36,
          'not null' => TRUE,
          'description' => 'UUID grouping messages in one conversation.',
        ],
        'direction' => [
          'type' => 'varchar',
          'length' => 10,
          'not null' => TRUE,
          'description' => 'Message direction: user or assistant.',
        ],
        'message_hash' => [
          'type' => 'varchar',
          'length' => 64,
          'not null' => TRUE,
          'default' => '',
          'description' => 'Hash of the normalized redacted message text.',
        ],
        'message_length_bucket' => [
          'type' => 'varchar',
          'length' => 16,
          'not null' => TRUE,
          'default' => 'empty',
          'description' => 'Bucketed message length for observability.',
        ],
        'redaction_profile' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'default' => 'none',
          'description' => 'Sorted token labels describing what redaction classes were present.',
        ],
        'intent' => [
          'type' => 'varchar',
          'length' => 64,
          'not null' => FALSE,
          'description' => 'Detected intent type.',
        ],
        'response_type' => [
          'type' => 'varchar',
          'length' => 32,
          'not null' => FALSE,
          'description' => 'Response type (faq, navigation, escalation, etc.).',
        ],
        'created' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'Unix timestamp.',
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'conversation' => ['conversation_id'],
        'created' => ['created'],
      ],
    ];
    $schema->createTable('ilas_site_assistant_conversations', $table);
  }
}

/**
 * Add request_id column and intent_created index to conversations table.
 */
function ilas_site_assistant_update_10002() {
  $schema = \Drupal::database()->schema();
  $table = 'ilas_site_assistant_conversations';

  if (!$schema->tableExists($table)) {
    return;
  }

  // Add request_id column for per-request correlation.
  if (!$schema->fieldExists($table, 'request_id')) {
    $schema->addField($table, 'request_id', [
      'type' => 'varchar',
      'length' => 36,
      'not null' => FALSE,
      'default' => NULL,
      'description' => 'Per-request correlation UUID for tracing across logs.',
    ]);
    $schema->addIndex($table, 'request_id', ['request_id'], [
      'fields' => [
        'request_id' => [
          'type' => 'varchar',
          'length' => 36,
        ],
      ],
    ]);
  }

  // Add composite index for conversation viewer filtering.
  // Drupal's addIndex requires the full field spec for the index.
  try {
    $schema->addIndex($table, 'intent_created', ['intent', 'created'], [
      'fields' => [
        'intent' => [
          'type' => 'varchar',
          'length' => 64,
        ],
        'created' => [
          'type' => 'int',
          'unsigned' => TRUE,
        ],
      ],
    ]);
  }
  catch (\Exception $e) {
    // Index may already exist.
  }
}

/**
 * Backfill Langfuse config map for older installs missing the nested object.
 */
function ilas_site_assistant_update_10003() {
  $config = \Drupal::configFactory()->getEditable('ilas_site_assistant.settings');
  $langfuse = $config->get('langfuse');

  if (!is_array($langfuse)) {
    $langfuse = [];
  }

  $defaults = [
    'enabled' => FALSE,
    'host' => 'https://us.cloud.langfuse.com',
    'public_key' => '',
    'secret_key' => '',
    'sample_rate' => 1.0,
    'environment' => 'production',
    'timeout' => 5.0,
    'max_queue_depth' => 10000,
    'max_item_age_seconds' => 3600,
  ];

  // Preserve existing values and fill only missing keys.
  $merged = $langfuse + $defaults;
  if ($merged === $langfuse) {
    return t('Langfuse config map already present.');
  }

  $config->set('langfuse', $merged)->save(TRUE);
  return t('Backfilled missing langfuse config defaults.');
}

/**
 * Backfill SLO target config block for older installs.
 */
function ilas_site_assistant_update_10004() {
  $config = \Drupal::configFactory()->getEditable('ilas_site_assistant.settings');
  $slo = $config->get('slo');

  if (!is_array($slo)) {
    $slo = [];
  }

  $defaults = [
    'availability_target_pct' => 99.5,
    'latency_p95_target_ms' => 2000,
    'latency_p99_target_ms' => 5000,
    'error_rate_target_pct' => 5.0,
    'error_budget_window_hours' => 168,
    'cron_max_age_seconds' => 7200,
    'cron_expected_cadence_seconds' => 3600,
    'queue_max_depth' => 10000,
    'queue_max_age_seconds' => 3600,
  ];

  $merged = $slo + $defaults;
  if ($merged === $slo) {
    return t('SLO config block already present.');
  }

  $config->set('slo', $merged)->save(TRUE);
  return t('Backfilled missing SLO config defaults.');
}

/**
 * Backfill cost-control policy config block for older active configs.
 */
function ilas_site_assistant_update_10005() {
  $config = \Drupal::configFactory()->getEditable('ilas_site_assistant.settings');
  $cost_control = $config->get('cost_control');

  if (!is_array($cost_control)) {
    $cost_control = [];
  }

  $defaults = [
    'daily_call_limit' => 5000,
    'monthly_call_limit' => 100000,
    'sample_rate' => 1.0,
    'cache_hit_rate_target' => 0.30,
    'cache_stats_window_seconds' => 86400,
    'manual_kill_switch' => FALSE,
    'pricing' => [
      'model' => 'gemini-1.5-flash',
      'input_per_1m_tokens' => 0.075,
      'output_per_1m_tokens' => 0.30,
    ],
    'alert_cooldown_minutes' => 60,
  ];

  $merged = $cost_control + $defaults;

  $pricing = $cost_control['pricing'] ?? [];
  if (!is_array($pricing)) {
    $pricing = [];
  }
  $merged['pricing'] = $pricing + $defaults['pricing'];

  if ($merged === $cost_control) {
    return t('Cost-control config block already present.');
  }

  $config->set('cost_control', $merged)->save(TRUE);
  return t('Backfilled missing cost-control config defaults.');
}

/**
 * Removes stored Vertex credential blobs from config and migrates the key path.
 */
function ilas_site_assistant_update_10006() {
  $messages = [];

  $config = \Drupal::configFactory()->getEditable('ilas_site_assistant.settings');
  $llm = $config->get('llm');
  if (is_array($llm) && array_key_exists('service_account_json', $llm)) {
    unset($llm['service_account_json']);
    $config->set('llm', $llm)->save(TRUE);
    $messages[] = t('Removed llm.service_account_json from active ILAS Site Assistant config.');
  }

  if (!\Drupal::moduleHandler()->moduleExists('key')) {
    $messages[] = t('Key module is not enabled; skipped Vertex key entity migration.');
    return implode(' ', $messages);
  }

  $vertexKey = \Drupal::configFactory()->getEditable('key.key.vertex_sa_credentials');
  $vertexKeyData = $vertexKey->getRawData();
  if (!is_array($vertexKeyData) || $vertexKeyData === []) {
    $messages[] = t('Vertex key entity config was not found.');
    return implode(' ', $messages);
  }

  $changed = FALSE;
  if (($vertexKeyData['key_provider'] ?? NULL) !== 'ilas_runtime_site_setting') {
    $vertexKey->set('key_provider', 'ilas_runtime_site_setting');
    $changed = TRUE;
  }

  $providerSettings = $vertexKeyData['key_provider_settings'] ?? [];
  if (!is_array($providerSettings) || ($providerSettings['settings_key'] ?? NULL) !== 'ilas_vertex_sa_json' || array_key_exists('key_value', $providerSettings)) {
    $vertexKey->set('key_provider_settings', [
      'settings_key' => 'ilas_vertex_sa_json',
    ]);
    $changed = TRUE;
  }

  if (($vertexKeyData['key_input'] ?? NULL) !== 'none') {
    $vertexKey->set('key_input', 'none');
    $changed = TRUE;
  }

  if (($vertexKeyData['description'] ?? NULL) !== 'GCP service account JSON for Vertex AI (fallback provider). Value resolved from a runtime-only Drupal site setting populated in settings.php.') {
    $vertexKey->set('description', 'GCP service account JSON for Vertex AI (fallback provider). Value resolved from a runtime-only Drupal site setting populated in settings.php.');
    $changed = TRUE;
  }

  $dependencies = $vertexKeyData['dependencies'] ?? [];
  $moduleDependencies = $dependencies['module'] ?? [];
  if (!is_array($moduleDependencies) || !in_array('ilas_site_assistant', $moduleDependencies, TRUE)) {
    $moduleDependencies = is_array($moduleDependencies) ? $moduleDependencies : [];
    $moduleDependencies[] = 'ilas_site_assistant';
    sort($moduleDependencies);
    $dependencies['module'] = $moduleDependencies;
    $vertexKey->set('dependencies', $dependencies);
    $changed = TRUE;
  }

  if ($changed) {
    $vertexKey->save(TRUE);
    $messages[] = t('Migrated vertex_sa_credentials to the runtime-only site-setting key provider.');
  }
  else {
    $messages[] = t('Vertex key entity already uses the runtime-only site-setting key provider.');
  }

  return implode(' ', $messages);
}

/**
 * Minimizes observability payload tables and purges pre-RAUD-11 trace batches.
 */
function ilas_site_assistant_update_10007() {
  $messages = [];
  $database = \Drupal::database();
  $schema = $database->schema();

  $topic_lookup = ilas_site_assistant_raud11_topic_lookup();
  $office_lookup = ilas_site_assistant_raud11_office_lookup();

  if ($schema->tableExists('ilas_site_assistant_no_answer')) {
    ilas_site_assistant_raud11_add_field_if_missing($schema, 'ilas_site_assistant_no_answer', 'language_hint', [
      'type' => 'varchar',
      'length' => 16,
      'not null' => TRUE,
      'default' => 'unknown',
      'description' => 'Coarse language hint for aggregate reporting.',
    ]);
    ilas_site_assistant_raud11_add_field_if_missing($schema, 'ilas_site_assistant_no_answer', 'length_bucket', [
      'type' => 'varchar',
      'length' => 16,
      'not null' => TRUE,
      'default' => 'empty',
      'description' => 'Bucketed query length for observability.',
    ]);
    ilas_site_assistant_raud11_add_field_if_missing($schema, 'ilas_site_assistant_no_answer', 'redaction_profile', [
      'type' => 'varchar',
      'length' => 255,
      'not null' => TRUE,
      'default' => 'none',
      'description' => 'Sorted token labels describing what redaction classes were present.',
    ]);

    if ($schema->fieldExists('ilas_site_assistant_no_answer', 'sanitized_query')) {
      $rows = $database->select('ilas_site_assistant_no_answer', 'n')
        ->fields('n', ['sanitized_query', 'count', 'first_seen', 'last_seen'])
        ->execute()
        ->fetchAll();

      $aggregates = [];
      foreach ($rows as $row) {
        $metadata = \Drupal\ilas_site_assistant\Service\ObservabilityPayloadMinimizer::buildTextMetadataWithLanguage((string) $row->sanitized_query);
        $hash = $metadata['text_hash'];
        if (!isset($aggregates[$hash])) {
          $aggregates[$hash] = [
            'query_hash' => $hash,
            'language_hint' => $metadata['language_hint'],
            'length_bucket' => $metadata['length_bucket'],
            'redaction_profile' => $metadata['redaction_profile'],
            'count' => 0,
            'first_seen' => (int) $row->first_seen,
            'last_seen' => (int) $row->last_seen,
          ];
        }

        $aggregates[$hash]['count'] += (int) $row->count;
        $aggregates[$hash]['first_seen'] = min($aggregates[$hash]['first_seen'], (int) $row->first_seen);
        $aggregates[$hash]['last_seen'] = max($aggregates[$hash]['last_seen'], (int) $row->last_seen);
      }

      ilas_site_assistant_raud11_drop_field_if_exists($schema, 'ilas_site_assistant_no_answer', 'sanitized_query');

      $database->truncate('ilas_site_assistant_no_answer')->execute();
      foreach ($aggregates as $aggregate) {
        $database->insert('ilas_site_assistant_no_answer')
          ->fields($aggregate)
          ->execute();
      }
      $messages[] = t('Backfilled no-answer metadata and removed sanitized_query storage.');
    }
  }

  if ($schema->tableExists('ilas_site_assistant_conversations')) {
    ilas_site_assistant_raud11_add_field_if_missing($schema, 'ilas_site_assistant_conversations', 'message_hash', [
      'type' => 'varchar',
      'length' => 64,
      'not null' => TRUE,
      'default' => '',
      'description' => 'Hash of the normalized redacted message text.',
    ]);
    ilas_site_assistant_raud11_add_field_if_missing($schema, 'ilas_site_assistant_conversations', 'message_length_bucket', [
      'type' => 'varchar',
      'length' => 16,
      'not null' => TRUE,
      'default' => 'empty',
      'description' => 'Bucketed message length for observability.',
    ]);
    ilas_site_assistant_raud11_add_field_if_missing($schema, 'ilas_site_assistant_conversations', 'redaction_profile', [
      'type' => 'varchar',
      'length' => 255,
      'not null' => TRUE,
      'default' => 'none',
      'description' => 'Sorted token labels describing what redaction classes were present.',
    ]);

    if ($schema->fieldExists('ilas_site_assistant_conversations', 'redacted_message')) {
      $rows = $database->select('ilas_site_assistant_conversations', 'c')
        ->fields('c', ['id', 'redacted_message'])
        ->execute()
        ->fetchAll();

      foreach ($rows as $row) {
        $metadata = \Drupal\ilas_site_assistant\Service\ObservabilityPayloadMinimizer::buildTextMetadata((string) $row->redacted_message);
        $database->update('ilas_site_assistant_conversations')
          ->fields([
            'message_hash' => $metadata['text_hash'],
            'message_length_bucket' => $metadata['length_bucket'],
            'redaction_profile' => $metadata['redaction_profile'],
          ])
          ->condition('id', $row->id)
          ->execute();
      }

      ilas_site_assistant_raud11_drop_field_if_exists($schema, 'ilas_site_assistant_conversations', 'redacted_message');
      $messages[] = t('Backfilled conversation metadata and removed redacted_message storage.');
    }
  }

  if ($schema->tableExists('ilas_site_assistant_stats')) {
    $rows = $database->select('ilas_site_assistant_stats', 's')
      ->fields('s', ['event_type', 'event_value', 'count', 'date'])
      ->execute()
      ->fetchAll();

    $aggregates = [];
    foreach ($rows as $row) {
      $normalized = ilas_site_assistant_raud11_normalize_analytics_value(
        (string) $row->event_type,
        (string) ($row->event_value ?? ''),
        $topic_lookup,
        $office_lookup
      );
      $key = implode('|', [
        (string) $row->event_type,
        $normalized,
        (string) $row->date,
      ]);
      if (!isset($aggregates[$key])) {
        $aggregates[$key] = [
          'event_type' => (string) $row->event_type,
          'event_value' => $normalized,
          'count' => 0,
          'date' => (string) $row->date,
        ];
      }
      $aggregates[$key]['count'] += (int) $row->count;
    }

    $database->truncate('ilas_site_assistant_stats')->execute();
    foreach ($aggregates as $aggregate) {
      $database->insert('ilas_site_assistant_stats')
        ->fields($aggregate)
        ->execute();
    }

    $messages[] = t('Normalized legacy analytics event values to the RAUD-11 contract.');
  }

  try {
    \Drupal::queue('ilas_langfuse_export')->deleteQueue();
    $messages[] = t('Purged queued Langfuse export batches created before the RAUD-11 payload contract.');
  }
  catch (\Throwable $e) {
    $messages[] = t('Failed to purge queued Langfuse export batches.');
  }

  return $messages ? implode(' ', $messages) : t('RAUD-11 observability minimization update already applied.');
}

/**
 * Externalizes retrieval identifiers and LegalServer URL governance.
 */
function ilas_site_assistant_update_10008() {
  $config = \Drupal::configFactory()->getEditable('ilas_site_assistant.settings');

  $retrieval = $config->get('retrieval');
  $retrieval = is_array($retrieval) ? $retrieval : [];

  $vector_search = $config->get('vector_search');
  $vector_search = is_array($vector_search) ? $vector_search : [];

  $vector_index_hygiene = $config->get('vector_index_hygiene');
  $vector_index_hygiene = is_array($vector_index_hygiene) ? $vector_index_hygiene : [];
  $managed_indexes = $vector_index_hygiene['managed_indexes'] ?? [];
  $managed_indexes = is_array($managed_indexes) ? $managed_indexes : [];

  $canonical_urls = $config->get('canonical_urls');
  $canonical_urls = is_array($canonical_urls) ? $canonical_urls : [];

  $resolved_retrieval = [
    'faq_index_id' => (string) ($retrieval['faq_index_id'] ?? 'faq_accordion'),
    'resource_index_id' => (string) ($retrieval['resource_index_id'] ?? 'assistant_resources'),
    'resource_fallback_index_id' => (string) ($retrieval['resource_fallback_index_id'] ?? 'content'),
    'faq_vector_index_id' => (string) ($retrieval['faq_vector_index_id']
      ?? $vector_search['faq_index_id']
      ?? $managed_indexes['faq_vector']['index_id']
      ?? 'faq_accordion_vector'),
    'resource_vector_index_id' => (string) ($retrieval['resource_vector_index_id']
      ?? $vector_search['resource_index_id']
      ?? $managed_indexes['resource_vector']['index_id']
      ?? 'assistant_resources_vector'),
  ];

  unset($vector_search['faq_index_id'], $vector_search['resource_index_id']);

  if (isset($managed_indexes['faq_vector']) && is_array($managed_indexes['faq_vector'])) {
    unset($managed_indexes['faq_vector']['index_id']);
  }
  if (isset($managed_indexes['resource_vector']) && is_array($managed_indexes['resource_vector'])) {
    unset($managed_indexes['resource_vector']['index_id']);
  }
  if ($managed_indexes !== []) {
    $vector_index_hygiene['managed_indexes'] = $managed_indexes;
  }

  unset($canonical_urls['online_application']);

  $config
    ->set('retrieval', $resolved_retrieval)
    ->set('vector_search', $vector_search)
    ->set('vector_index_hygiene', $vector_index_hygiene)
    ->set('canonical_urls', $canonical_urls)
    ->save(TRUE);

  return t('Migrated retrieval identifiers into ilas_site_assistant.settings:retrieval, removed exported canonical_urls.online_application, and cleared duplicate vector index ownership.');
}

/**
 * Ensures the lexical Search API indexes exist on existing environments.
 */
function ilas_site_assistant_update_10009() {
  $created = [];
  foreach (['faq_accordion', 'assistant_resources'] as $index_id) {
    if (ilas_site_assistant_raud21_ensure_index_exists($index_id)) {
      $created[] = $index_id;
    }
  }

  if ($created === []) {
    return t('Verified lexical Search API indexes already exist.');
  }

  return t('Created missing lexical Search API indexes from canonical config: @indexes.', [
    '@indexes' => implode(', ', $created),
  ]);
}

/**
 * Removes stored Gemini API keys from config and migrates the key path.
 */
function ilas_site_assistant_update_10010() {
  $messages = [];

  $config = \Drupal::configFactory()->getEditable('ilas_site_assistant.settings');
  $llm = $config->get('llm');
  if (is_array($llm) && (($llm['api_key'] ?? '') !== '')) {
    $llm['api_key'] = '';
    $config->set('llm', $llm)->save(TRUE);
    $messages[] = t('Removed stored llm.api_key from active ILAS Site Assistant config.');
  }

  if (!\Drupal::moduleHandler()->moduleExists('key')) {
    $messages[] = t('Key module is not enabled; skipped Gemini key entity migration.');
    return implode(' ', $messages);
  }

  $geminiKey = \Drupal::configFactory()->getEditable('key.key.gemini_api_key');
  $geminiKeyData = $geminiKey->getRawData();
  if (!is_array($geminiKeyData) || $geminiKeyData === []) {
    $messages[] = t('Gemini key entity config was not found.');
    return implode(' ', $messages);
  }

  $changed = FALSE;
  if (($geminiKeyData['key_provider'] ?? NULL) !== 'ilas_runtime_site_setting') {
    $geminiKey->set('key_provider', 'ilas_runtime_site_setting');
    $changed = TRUE;
  }

  $providerSettings = $geminiKeyData['key_provider_settings'] ?? [];
  if (!is_array($providerSettings) || ($providerSettings['settings_key'] ?? NULL) !== 'ilas_gemini_api_key' || array_key_exists('key_value', $providerSettings)) {
    $geminiKey->set('key_provider_settings', [
      'settings_key' => 'ilas_gemini_api_key',
    ]);
    $changed = TRUE;
  }

  if (($geminiKeyData['key_input'] ?? NULL) !== 'none') {
    $geminiKey->set('key_input', 'none');
    $changed = TRUE;
  }

  if (($geminiKeyData['description'] ?? NULL) !== 'Google AI Studio API key. Value resolved from a runtime-only Drupal site setting populated in settings.php.') {
    $geminiKey->set('description', 'Google AI Studio API key. Value resolved from a runtime-only Drupal site setting populated in settings.php.');
    $changed = TRUE;
  }

  $dependencies = $geminiKeyData['dependencies'] ?? [];
  $moduleDependencies = $dependencies['module'] ?? [];
  if (!is_array($moduleDependencies) || !in_array('ilas_site_assistant', $moduleDependencies, TRUE)) {
    $moduleDependencies = is_array($moduleDependencies) ? $moduleDependencies : [];
    $moduleDependencies[] = 'ilas_site_assistant';
    sort($moduleDependencies);
    $dependencies['module'] = $moduleDependencies;
    $geminiKey->set('dependencies', $dependencies);
    $changed = TRUE;
  }

  if ($changed) {
    $geminiKey->save(TRUE);
    $messages[] = t('Migrated gemini_api_key to the runtime-only site-setting key provider.');
  }
  else {
    $messages[] = t('Gemini key entity already uses the runtime-only site-setting key provider.');
  }

  return implode(' ', $messages);
}

/**
 * Adds the durable assistant conversation-state table.
 */
function ilas_site_assistant_update_10011() {
  $schema = \Drupal::database()->schema();
  $table = 'ilas_site_assistant_conversation_state';

  if ($schema->tableExists($table)) {
    return t('Durable assistant conversation-state table already exists.');
  }

  $schema->createTable($table, ilas_site_assistant_conversation_state_schema_definition());
  return t('Created durable assistant conversation-state table.');
}

/**
 * Adds an index on analytics date for 2-year retention cleanup scans.
 */
function ilas_site_assistant_update_10012() {
  $schema = \Drupal::database()->schema();
  if ($schema->tableExists('ilas_site_assistant_stats') && !$schema->indexExists('ilas_site_assistant_stats', 'date')) {
    $schema->addIndex('ilas_site_assistant_stats', 'date', ['date'], [
      'fields' => [
        'date' => [
          'type' => 'varchar',
          'length' => 10,
        ],
      ],
    ]);
    return t('Added analytics date index.');
  }

  return t('Analytics date index already exists.');
}

/**
 * Creates a lexical Search API index from canonical config when missing.
 *
 * @param string $index_id
 *   The Search API index machine name.
 *
 * @return bool
 *   TRUE when the index was created, FALSE when it already existed.
 */
function ilas_site_assistant_raud21_ensure_index_exists(string $index_id): bool {
  $index_storage = \Drupal::entityTypeManager()->getStorage('search_api_index');
  if ($index_storage->load($index_id)) {
    return FALSE;
  }

  $definition = ilas_site_assistant_raud21_load_canonical_index_definition($index_id);
  $server_id = (string) ($definition['server'] ?? '');
  if ($server_id === '') {
    throw new \Drupal\Core\Utility\UpdateException(sprintf('Canonical Search API index definition for "%s" is missing the server ID.', $index_id));
  }

  $server = \Drupal::entityTypeManager()
    ->getStorage('search_api_server')
    ->load($server_id);
  if (!$server) {
    throw new \Drupal\Core\Utility\UpdateException(sprintf('Cannot create Search API index "%s" because server "%s" is missing.', $index_id, $server_id));
  }

  $index_storage->create($definition)->save();
  return TRUE;
}

/**
 * Loads the canonical config definition for one lexical Search API index.
 *
 * @param string $index_id
 *   The Search API index machine name.
 *
 * @return array<string, mixed>
 *   The canonical config entity definition.
 */
function ilas_site_assistant_raud21_load_canonical_index_definition(string $index_id): array {
  $config_name = 'search_api.index.' . $index_id;
  $definition = \Drupal::service('config.storage.sync')->read($config_name);
  if (is_array($definition) && ($definition['id'] ?? NULL) === $index_id) {
    return $definition;
  }

  $module_path = \Drupal::service('extension.list.module')->getPath('ilas_site_assistant');
  $path = DRUPAL_ROOT . '/' . $module_path . '/config/install/' . $config_name . '.yml';
  if (!is_file($path)) {
    throw new \Drupal\Core\Utility\UpdateException(sprintf('Canonical Search API index definition "%s" is missing from config sync and module install config.', $config_name));
  }

  $definition = \Drupal\Component\Serialization\Yaml::decode(file_get_contents($path));
  if (!is_array($definition) || ($definition['id'] ?? NULL) !== $index_id) {
    throw new \Drupal\Core\Utility\UpdateException(sprintf('Canonical Search API index definition "%s" could not be parsed.', $config_name));
  }

  return $definition;
}

/**
 * Adds a field only when it is missing.
 */
function ilas_site_assistant_raud11_add_field_if_missing($schema, string $table, string $field, array $spec): void {
  if (!$schema->fieldExists($table, $field)) {
    $schema->addField($table, $field, $spec);
  }
}

/**
 * Drops a field when it is still present.
 */
function ilas_site_assistant_raud11_drop_field_if_exists($schema, string $table, string $field): void {
  if ($schema->fieldExists($table, $field)) {
    $schema->dropField($table, $field);
  }
}

/**
 * Returns a lookup of legacy topic labels to topic IDs.
 */
function ilas_site_assistant_raud11_topic_lookup(): array {
  if (!\Drupal::hasService('ilas_site_assistant.topic_resolver')) {
    return [];
  }

  try {
    $topics = \Drupal::service('ilas_site_assistant.topic_resolver')->getAllTopics();
  }
  catch (\Throwable $e) {
    return [];
  }

  $lookup = [];
  foreach ($topics as $topic) {
    $name = mb_strtolower(trim((string) ($topic['name'] ?? '')));
    $id = $topic['id'] ?? NULL;
    if ($name !== '' && $id !== NULL) {
      $lookup[$name] = (string) $id;
    }
  }

  return $lookup;
}

/**
 * Returns a lookup of office names to canonical office paths.
 */
function ilas_site_assistant_raud11_office_lookup(): array {
  $lookup = [];

  foreach (\Drupal\ilas_site_assistant\Service\OfficeLocationResolver::OFFICES as $office) {
    $name = mb_strtolower(trim((string) ($office['name'] ?? '')));
    $url = (string) ($office['url'] ?? '');
    if ($name !== '' && $url !== '') {
      $lookup[$name] = $url;
    }
  }

  return $lookup;
}

/**
 * Normalizes analytics values through the shared RAUD-11 minimizer.
 */
function ilas_site_assistant_raud11_normalize_analytics_value(string $event_type, string $event_value, array $topic_lookup, array $office_lookup): string {
  return \Drupal\ilas_site_assistant\Service\ObservabilityPayloadMinimizer::normalizeAnalyticsValue($event_type, $event_value, [
    'topic_lookup' => $topic_lookup,
    'office_lookup' => $office_lookup,
  ]);
}

/**
 * Implements hook_install().
 */
function ilas_site_assistant_install() {
  \Drupal::messenger()->addStatus(t('ILAS Site Assistant installed. Configure at /admin/config/ilas/site-assistant'));
}

/**
 * Implements hook_uninstall().
 */
function ilas_site_assistant_uninstall() {
  // Remove configuration.
  \Drupal::configFactory()->getEditable('ilas_site_assistant.settings')->delete();
}
