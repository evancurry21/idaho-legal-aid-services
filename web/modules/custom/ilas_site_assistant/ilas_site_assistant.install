<?php

/**
 * @file
 * Install, update and uninstall functions for the ILAS Site Assistant module.
 */

/**
 * Implements hook_schema().
 */
function ilas_site_assistant_schema() {
  $schema = [];

  // Aggregated analytics table (no PII).
  $schema['ilas_site_assistant_stats'] = [
    'description' => 'Stores aggregated non-PII analytics for the Site Assistant.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'event_type' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'description' => 'Type of event (chat_open, topic_selected, resource_click, etc.)',
      ],
      'event_value' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
        'description' => 'Event value (topic name, URL path, etc.) - no PII',
      ],
      'count' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 1,
        'description' => 'Aggregated count for this event type/value combination.',
      ],
      'date' => [
        'type' => 'varchar',
        'length' => 10,
        'not null' => TRUE,
        'description' => 'Date in YYYY-MM-DD format.',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'event_date' => ['event_type', 'date'],
      'event_value' => ['event_type', 'event_value'],
    ],
    'unique keys' => [
      'event_date_value' => ['event_type', 'event_value', 'date'],
    ],
  ];

  // Sanitized "no_answer" queries for content gap analysis.
  $schema['ilas_site_assistant_no_answer'] = [
    'description' => 'Stores sanitized queries that had no matching results.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'query_hash' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'description' => 'Hash of sanitized query for deduplication.',
      ],
      'sanitized_query' => [
        'type' => 'varchar',
        'length' => 100,
        'not null' => TRUE,
        'description' => 'Truncated, sanitized query text (no PII).',
      ],
      'count' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 1,
      ],
      'first_seen' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'Unix timestamp when first recorded.',
      ],
      'last_seen' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'Unix timestamp when last recorded.',
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'query_hash' => ['query_hash'],
    ],
    'indexes' => [
      'count' => ['count'],
      'last_seen' => ['last_seen'],
    ],
  ];

  // Opt-in conversation log table (PII-redacted, short retention).
  $schema['ilas_site_assistant_conversations'] = [
    'description' => 'Opt-in conversation logs for QA/debugging (PII-redacted).',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'conversation_id' => [
        'type' => 'varchar',
        'length' => 36,
        'not null' => TRUE,
        'description' => 'UUID grouping messages in one conversation.',
      ],
      'direction' => [
        'type' => 'varchar',
        'length' => 10,
        'not null' => TRUE,
        'description' => 'Message direction: user or assistant.',
      ],
      'redacted_message' => [
        'type' => 'text',
        'size' => 'medium',
        'not null' => TRUE,
        'description' => 'PII-redacted message text.',
      ],
      'intent' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => FALSE,
        'description' => 'Detected intent type.',
      ],
      'response_type' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => FALSE,
        'description' => 'Response type (faq, navigation, escalation, etc.).',
      ],
      'created' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'Unix timestamp.',
      ],
      'request_id' => [
        'type' => 'varchar',
        'length' => 36,
        'not null' => FALSE,
        'default' => NULL,
        'description' => 'Per-request correlation UUID for tracing across logs.',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'conversation' => ['conversation_id'],
      'created' => ['created'],
      'intent_created' => ['intent', 'created'],
      'request_id' => ['request_id'],
    ],
  ];

  return $schema;
}

/**
 * Add conversation log table for opt-in QA/debugging.
 */
function ilas_site_assistant_update_10001() {
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('ilas_site_assistant_conversations')) {
    $table = [
      'description' => 'Opt-in conversation logs for QA/debugging (PII-redacted).',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'unsigned' => TRUE,
          'not null' => TRUE,
        ],
        'conversation_id' => [
          'type' => 'varchar',
          'length' => 36,
          'not null' => TRUE,
          'description' => 'UUID grouping messages in one conversation.',
        ],
        'direction' => [
          'type' => 'varchar',
          'length' => 10,
          'not null' => TRUE,
          'description' => 'Message direction: user or assistant.',
        ],
        'redacted_message' => [
          'type' => 'text',
          'size' => 'medium',
          'not null' => TRUE,
          'description' => 'PII-redacted message text.',
        ],
        'intent' => [
          'type' => 'varchar',
          'length' => 64,
          'not null' => FALSE,
          'description' => 'Detected intent type.',
        ],
        'response_type' => [
          'type' => 'varchar',
          'length' => 32,
          'not null' => FALSE,
          'description' => 'Response type (faq, navigation, escalation, etc.).',
        ],
        'created' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'Unix timestamp.',
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'conversation' => ['conversation_id'],
        'created' => ['created'],
      ],
    ];
    $schema->createTable('ilas_site_assistant_conversations', $table);
  }
}

/**
 * Add request_id column and intent_created index to conversations table.
 */
function ilas_site_assistant_update_10002() {
  $schema = \Drupal::database()->schema();
  $table = 'ilas_site_assistant_conversations';

  if (!$schema->tableExists($table)) {
    return;
  }

  // Add request_id column for per-request correlation.
  if (!$schema->fieldExists($table, 'request_id')) {
    $schema->addField($table, 'request_id', [
      'type' => 'varchar',
      'length' => 36,
      'not null' => FALSE,
      'default' => NULL,
      'description' => 'Per-request correlation UUID for tracing across logs.',
    ]);
    $schema->addIndex($table, 'request_id', ['request_id'], [
      'fields' => [
        'request_id' => [
          'type' => 'varchar',
          'length' => 36,
        ],
      ],
    ]);
  }

  // Add composite index for conversation viewer filtering.
  // Drupal's addIndex requires the full field spec for the index.
  try {
    $schema->addIndex($table, 'intent_created', ['intent', 'created'], [
      'fields' => [
        'intent' => [
          'type' => 'varchar',
          'length' => 64,
        ],
        'created' => [
          'type' => 'int',
          'unsigned' => TRUE,
        ],
      ],
    ]);
  }
  catch (\Exception $e) {
    // Index may already exist.
  }
}

/**
 * Backfill Langfuse config map for older installs missing the nested object.
 */
function ilas_site_assistant_update_10003() {
  $config = \Drupal::configFactory()->getEditable('ilas_site_assistant.settings');
  $langfuse = $config->get('langfuse');

  if (!is_array($langfuse)) {
    $langfuse = [];
  }

  $defaults = [
    'enabled' => FALSE,
    'host' => 'https://us.cloud.langfuse.com',
    'public_key' => '',
    'secret_key' => '',
    'sample_rate' => 1.0,
    'environment' => 'production',
    'timeout' => 5.0,
    'max_queue_depth' => 10000,
    'max_item_age_seconds' => 3600,
  ];

  // Preserve existing values and fill only missing keys.
  $merged = $langfuse + $defaults;
  if ($merged === $langfuse) {
    return t('Langfuse config map already present.');
  }

  $config->set('langfuse', $merged)->save(TRUE);
  return t('Backfilled missing langfuse config defaults.');
}

/**
 * Backfill SLO target config block for older installs.
 */
function ilas_site_assistant_update_10004() {
  $config = \Drupal::configFactory()->getEditable('ilas_site_assistant.settings');
  $slo = $config->get('slo');

  if (!is_array($slo)) {
    $slo = [];
  }

  $defaults = [
    'availability_target_pct' => 99.5,
    'latency_p95_target_ms' => 2000,
    'latency_p99_target_ms' => 5000,
    'error_rate_target_pct' => 5.0,
    'error_budget_window_hours' => 168,
    'cron_max_age_seconds' => 7200,
    'cron_expected_cadence_seconds' => 3600,
    'queue_max_depth' => 10000,
    'queue_max_age_seconds' => 3600,
  ];

  $merged = $slo + $defaults;
  if ($merged === $slo) {
    return t('SLO config block already present.');
  }

  $config->set('slo', $merged)->save(TRUE);
  return t('Backfilled missing SLO config defaults.');
}

/**
 * Backfill cost-control policy config block for older active configs.
 */
function ilas_site_assistant_update_10005() {
  $config = \Drupal::configFactory()->getEditable('ilas_site_assistant.settings');
  $cost_control = $config->get('cost_control');

  if (!is_array($cost_control)) {
    $cost_control = [];
  }

  $defaults = [
    'daily_call_limit' => 5000,
    'monthly_call_limit' => 100000,
    'sample_rate' => 1.0,
    'cache_hit_rate_target' => 0.30,
    'cache_stats_window_seconds' => 86400,
    'manual_kill_switch' => FALSE,
    'pricing' => [
      'model' => 'gemini-1.5-flash',
      'input_per_1m_tokens' => 0.075,
      'output_per_1m_tokens' => 0.30,
    ],
    'alert_cooldown_minutes' => 60,
  ];

  $merged = $cost_control + $defaults;

  $pricing = $cost_control['pricing'] ?? [];
  if (!is_array($pricing)) {
    $pricing = [];
  }
  $merged['pricing'] = $pricing + $defaults['pricing'];

  if ($merged === $cost_control) {
    return t('Cost-control config block already present.');
  }

  $config->set('cost_control', $merged)->save(TRUE);
  return t('Backfilled missing cost-control config defaults.');
}

/**
 * Removes stored Vertex credential blobs from config and migrates the key path.
 */
function ilas_site_assistant_update_10006() {
  $messages = [];

  $config = \Drupal::configFactory()->getEditable('ilas_site_assistant.settings');
  $llm = $config->get('llm');
  if (is_array($llm) && array_key_exists('service_account_json', $llm)) {
    unset($llm['service_account_json']);
    $config->set('llm', $llm)->save(TRUE);
    $messages[] = t('Removed llm.service_account_json from active ILAS Site Assistant config.');
  }

  if (!\Drupal::moduleHandler()->moduleExists('key')) {
    $messages[] = t('Key module is not enabled; skipped Vertex key entity migration.');
    return implode(' ', $messages);
  }

  $vertexKey = \Drupal::configFactory()->getEditable('key.key.vertex_sa_credentials');
  $vertexKeyData = $vertexKey->getRawData();
  if (!is_array($vertexKeyData) || $vertexKeyData === []) {
    $messages[] = t('Vertex key entity config was not found.');
    return implode(' ', $messages);
  }

  $changed = FALSE;
  if (($vertexKeyData['key_provider'] ?? NULL) !== 'ilas_runtime_site_setting') {
    $vertexKey->set('key_provider', 'ilas_runtime_site_setting');
    $changed = TRUE;
  }

  $providerSettings = $vertexKeyData['key_provider_settings'] ?? [];
  if (!is_array($providerSettings) || ($providerSettings['settings_key'] ?? NULL) !== 'ilas_vertex_sa_json' || array_key_exists('key_value', $providerSettings)) {
    $vertexKey->set('key_provider_settings', [
      'settings_key' => 'ilas_vertex_sa_json',
    ]);
    $changed = TRUE;
  }

  if (($vertexKeyData['key_input'] ?? NULL) !== 'none') {
    $vertexKey->set('key_input', 'none');
    $changed = TRUE;
  }

  if (($vertexKeyData['description'] ?? NULL) !== 'GCP service account JSON for Vertex AI (fallback provider). Value resolved from a runtime-only Drupal site setting populated in settings.php.') {
    $vertexKey->set('description', 'GCP service account JSON for Vertex AI (fallback provider). Value resolved from a runtime-only Drupal site setting populated in settings.php.');
    $changed = TRUE;
  }

  $dependencies = $vertexKeyData['dependencies'] ?? [];
  $moduleDependencies = $dependencies['module'] ?? [];
  if (!is_array($moduleDependencies) || !in_array('ilas_site_assistant', $moduleDependencies, TRUE)) {
    $moduleDependencies = is_array($moduleDependencies) ? $moduleDependencies : [];
    $moduleDependencies[] = 'ilas_site_assistant';
    sort($moduleDependencies);
    $dependencies['module'] = $moduleDependencies;
    $vertexKey->set('dependencies', $dependencies);
    $changed = TRUE;
  }

  if ($changed) {
    $vertexKey->save(TRUE);
    $messages[] = t('Migrated vertex_sa_credentials to the runtime-only site-setting key provider.');
  }
  else {
    $messages[] = t('Vertex key entity already uses the runtime-only site-setting key provider.');
  }

  return implode(' ', $messages);
}

/**
 * Implements hook_install().
 */
function ilas_site_assistant_install() {
  \Drupal::messenger()->addStatus(t('ILAS Site Assistant installed. Configure at /admin/config/ilas/site-assistant'));
}

/**
 * Implements hook_uninstall().
 */
function ilas_site_assistant_uninstall() {
  // Remove configuration.
  \Drupal::configFactory()->getEditable('ilas_site_assistant.settings')->delete();
}
