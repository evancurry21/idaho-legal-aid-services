<?php

/**
 * @file
 * Primary module hooks for ILAS Site Assistant module.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function ilas_site_assistant_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.ilas_site_assistant':
      $output = '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('The ILAS Site Assistant is a site-scoped chatbot that helps users find FAQs, resources, forms, and guides without providing legal advice.') . '</p>';
      $output .= '<h3>' . t('Features') . '</h3>';
      $output .= '<ul>';
      $output .= '<li>' . t('FAQ search and display') . '</li>';
      $output .= '<li>' . t('Resource/Form/Guide finder by topic') . '</li>';
      $output .= '<li>' . t('Service area navigation') . '</li>';
      $output .= '<li>' . t('Policy enforcement (no legal advice)') . '</li>';
      $output .= '<li>' . t('Privacy-first analytics') . '</li>';
      $output .= '</ul>';
      return $output;
  }
}

/**
 * Implements hook_theme().
 */
function ilas_site_assistant_theme($existing, $type, $theme, $path) {
  return [
    'ilas_site_assistant_page' => [
      'variables' => [
        'disclaimer' => NULL,
        'suggestions' => [],
        'config' => [],
      ],
      'template' => 'assistant-page',
    ],
    'ilas_site_assistant_widget' => [
      'variables' => [
        'disclaimer' => NULL,
        'config' => [],
      ],
      'template' => 'assistant-widget',
    ],
  ];
}

/**
 * Implements hook_page_attachments().
 */
function ilas_site_assistant_page_attachments(array &$attachments) {
  ilas_site_assistant_attach_observability($attachments);

  $config = \Drupal::config('ilas_site_assistant.settings');

  // Only attach widget if enabled globally.
  if (!$config->get('enable_global_widget')) {
    return;
  }

  // Get current path to exclude certain pages.
  $current_path = \Drupal::service('path.current')->getPath();
  $excluded_paths = $config->get('excluded_paths') ?? [];

  foreach ($excluded_paths as $path) {
    if (strpos($current_path, $path) === 0) {
      return;
    }
  }

  // Attach the widget library.
  $attachments['#attached']['library'][] = 'ilas_site_assistant/widget';

  // Pass configuration to JavaScript.
  // NOTE: csrfToken intentionally omitted — widget fetches from
  // /assistant/api/session/bootstrap before the first chat POST. This avoids
  // stale tokens in cached pages.
  $attachments['#attached']['drupalSettings']['ilasSiteAssistant'] = [
    'apiBase' => '/assistant/api',
    'disclaimer' => $config->get('disclaimer_text') ?? t('I can help you find information on the Idaho Legal Aid Services website. I cannot provide legal advice.'),
    'enableFaq' => $config->get('enable_faq') ?? TRUE,
    'enableResources' => $config->get('enable_resources') ?? TRUE,
    'canonicalUrls' => ilas_site_assistant_get_canonical_urls(),
  ];
}

/**
 * Attaches site-wide browser observability settings and helper library.
 *
 * @param array $attachments
 *   The page attachments array.
 */
function ilas_site_assistant_attach_observability(array &$attachments): void {
  $runtime = \Drupal\Core\Site\Settings::get('ilas_observability', []);
  $ravenConfig = \Drupal::config('raven.settings');
  $sentryEnabled = (bool) $ravenConfig->get('client_key');
  $sentryBrowserDsn = (string) ($ravenConfig->get('public_dsn') ?: '');
  $sentryBrowserEnabled = !empty($sentryBrowserDsn)
    && (
      (bool) $ravenConfig->get('javascript_error_handler')
      || (float) ($ravenConfig->get('browser_traces_sample_rate') ?? 0) > 0
    );
  $newRelicEnabled = !empty($runtime['new_relic']['browser_enabled']);

  if (!$sentryBrowserEnabled && !$newRelicEnabled) {
    return;
  }

  $attachments['#attached']['library'][] = 'ilas_site_assistant/observability';
  $attachments['#attached']['drupalSettings']['ilasObservability'] = [
    'environment' => $runtime['environment'] ?? 'local',
    'pantheonEnv' => $runtime['pantheon_environment'] ?? '',
    'multidevName' => $runtime['multidev_name'] ?? '',
    'release' => $runtime['release'] ?? '',
    'gitSha' => $runtime['git_sha'] ?? '',
    'siteName' => $runtime['pantheon_site_name'] ?? 'local',
    'siteId' => $runtime['pantheon_site_id'] ?? '',
    'publicSiteUrl' => $runtime['public_site_url'] ?? '',
    'routeName' => \Drupal::routeMatch()->getRouteName(),
    'path' => \Drupal::service('path.current')->getPath(),
    'assistant' => [
      'name' => 'aila',
      'apiBase' => '/assistant/api',
    ],
    'sentry' => [
      'enabled' => $sentryEnabled,
      'browserEnabled' => $sentryBrowserEnabled,
      'showReportDialog' => (bool) $ravenConfig->get('show_report_dialog'),
      'replayEnabled' => !empty(($runtime['sentry']['browser']['replay_session_sample_rate'] ?? 0)) || !empty(($runtime['sentry']['browser']['replay_on_error_sample_rate'] ?? 0)),
      'replaySessionSampleRate' => (float) ($runtime['sentry']['browser']['replay_session_sample_rate'] ?? 0),
      'replayOnErrorSampleRate' => (float) ($runtime['sentry']['browser']['replay_on_error_sample_rate'] ?? 0),
    ],
    'newRelic' => [
      'browserEnabled' => $newRelicEnabled,
    ],
  ];
}

if (!function_exists('ilas_site_assistant_get_canonical_urls')) {

  /**
   * Returns the canonical URLs for the site assistant.
   *
   * @return array
   *   Array of canonical URLs keyed by identifier.
   */
  function ilas_site_assistant_get_canonical_urls() {
    if (\Drupal::hasService('ilas_site_assistant.retrieval_configuration')) {
      return \Drupal::service('ilas_site_assistant.retrieval_configuration')->getCanonicalUrls();
    }

    $config = \Drupal::config('ilas_site_assistant.settings');
    $urls = $config->get('canonical_urls');
    $urls = is_array($urls) ? $urls : [];

    $online_application = \Drupal\Core\Site\Settings::get('ilas_site_assistant_legalserver_online_application_url', '');
    if (is_string($online_application) && trim($online_application) !== '') {
      $urls['online_application'] = trim($online_application);
    }

    return $urls;
  }

}

/**
 * Implements hook_cron().
 */
function ilas_site_assistant_cron() {
  $start = microtime(TRUE);
  $success = TRUE;
  // Budget guard: skip non-critical tasks if cron is running long to avoid
  // Sentry Cron Monitor timeouts and lock contention (PHP-S/R, PHP-Q).
  $maxSeconds = 120;

  try {
    // Clean up expired analytics data.
    \Drupal::service('ilas_site_assistant.analytics_logger')->cleanupOldData();

    // Clean up expired conversation logs.
    if (\Drupal::hasService('ilas_site_assistant.conversation_logger')) {
      \Drupal::service('ilas_site_assistant.conversation_logger')->cleanup();
    }

    // Prune stale violation timestamps (older than 24 hours).
    if (\Drupal::hasService('ilas_site_assistant.safety_violation_tracker')) {
      \Drupal::service('ilas_site_assistant.safety_violation_tracker')->prune(time() - 86400);
    }

    // Check for safety spike alerts.
    if (\Drupal::hasService('ilas_site_assistant.safety_alert')) {
      \Drupal::service('ilas_site_assistant.safety_alert')->checkThresholds();
    }

    // Run scheduled vector-index hygiene refresh and monitoring snapshots.
    // This is the heaviest cron task — guard with time budget.
    $elapsed = microtime(TRUE) - $start;
    if ($elapsed > $maxSeconds) {
      \Drupal::logger('ilas_site_assistant')->warning('Cron task budget exhausted (@elapsed s), skipping vector hygiene refresh', [
        '@elapsed' => round($elapsed, 2),
      ]);
    }
    elseif (\Drupal::hasService('ilas_site_assistant.vector_index_hygiene')) {
      try {
        \Drupal::service('ilas_site_assistant.vector_index_hygiene')->runScheduledRefresh();
      }
      catch (\Throwable $e) {
        // On non-live environments, missing Pinecone backends are expected —
        // log as warning instead of error to reduce Sentry noise (PHP-15).
        $env = getenv('PANTHEON_ENVIRONMENT') ?: '';
        $logMethod = ($env === 'live' || $env === 'test') ? 'error' : 'warning';
        \Drupal::logger('ilas_site_assistant')->{$logMethod}('Vector index hygiene refresh failed: @message', [
          '@message' => $e->getMessage(),
        ]);
      }
    }

  }
  catch (\Throwable $e) {
    $success = FALSE;
    \Drupal::logger('ilas_site_assistant')->error('Cron failed: @message', [
      '@message' => $e->getMessage(),
    ]);
  }
  finally {
    $duration_ms = (microtime(TRUE) - $start) * 1000;
    if (\Drupal::hasService('ilas_site_assistant.cron_health_tracker')) {
      \Drupal::service('ilas_site_assistant.cron_health_tracker')->recordRun($duration_ms, $success);
    }

    // Check SLO alert thresholds after recording this cron run's health.
    if (\Drupal::hasService('ilas_site_assistant.slo_alert')) {
      try {
        \Drupal::service('ilas_site_assistant.slo_alert')->checkAll();
      }
      catch (\Throwable $e) {
        \Drupal::logger('ilas_site_assistant')->error('SLO alert check failed: @message', [
          '@message' => $e->getMessage(),
        ]);
      }
    }
  }
}

/**
 * Implements hook_mail().
 */
function ilas_site_assistant_mail($key, &$message, $params) {
  switch ($key) {
    case 'safety_alert':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['body'];
      break;
  }
}
