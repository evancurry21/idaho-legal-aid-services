<?php

/**
 * @file
 * Employment Application module hooks.
 */

/**
 * Implements hook_mail().
 */
function employment_application_mail($key, &$message, $params) {
  switch ($key) {
    case 'admin_notification':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['message'];
      
      // Add PDF attachment if provided
      if (!empty($params['pdf_content']) && !empty($params['application_id'])) {
        $filename = 'employment-application-' . preg_replace('/[^a-zA-Z0-9-_]/', '_', $params['application_id']) . '.pdf';
        
        // Add attachment to message
        $message['attachments'][] = [
          'filename' => $filename,
          'filemime' => 'application/pdf',
          'content' => $params['pdf_content'],
        ];
      }
      break;
      
    case 'confirmation':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['message'];
      break;
  }
}

/**
 * Best-effort secure deletion of a file.
 *
 * Overwrites file content with random bytes before unlinking. This is
 * defense-in-depth; effectiveness depends on the underlying filesystem
 * and storage layer (SSDs, journaling, NFS may retain old data).
 *
 * @param \Drupal\Core\File\FileSystemInterface $fileSystem
 *   The file system service.
 * @param string $uri
 *   The file URI (e.g. private://employment-applications/2025-03/file.pdf).
 * @param \Psr\Log\LoggerInterface $logger
 *   Logger for warnings on failure.
 */
function _employment_application_secure_delete_file(
  \Drupal\Core\File\FileSystemInterface $fileSystem,
  string $uri,
  \Psr\Log\LoggerInterface $logger,
): void {
  try {
    $realPath = $fileSystem->realpath($uri);
    if (!$realPath || !file_exists($realPath)) {
      return;
    }

    // Overwrite file content before unlinking.
    $size = filesize($realPath);
    if ($size > 0) {
      $handle = fopen($realPath, 'wb');
      if ($handle) {
        // Cap at 10MB to prevent memory issues. App files are typically <5MB.
        fwrite($handle, random_bytes(min($size, 10 * 1024 * 1024)));
        fflush($handle);
        fclose($handle);
      }
    }

    $fileSystem->delete($uri);
  }
  catch (\Throwable $e) {
    $logger->warning('Secure file deletion failed for @uri: @error', [
      '@uri' => $uri,
      '@error' => $e->getMessage(),
    ]);
  }
}

/**
 * Implements hook_cron().
 *
 * Purges employment applications older than the configured retention period.
 */
function employment_application_cron() {
  $config = \Drupal::config('employment_application.settings');
  $retentionDays = (int) $config->get('retention_days');

  // 0 or unset = keep forever.
  if ($retentionDays <= 0) {
    return;
  }

  $cutoff = \Drupal::time()->getRequestTime() - ($retentionDays * 86400);
  $database = \Drupal::database();
  $fileSystem = \Drupal::service('file_system');
  $logger = \Drupal::logger('employment_application');

  // Find expired applications.
  try {
    $results = $database->select('employment_applications', 'ea')
      ->fields('ea', ['id', 'application_id', 'file_data'])
      ->condition('submitted', $cutoff, '<')
      ->execute();

    $count = 0;
    foreach ($results as $row) {
      // Collect file URIs before DB changes.
      $physicalFiles = [];
      $fileData = json_decode($row->file_data, TRUE);

      // Transaction: DB operations first (reversible via rollback).
      $transaction = $database->startTransaction();
      try {
        if (is_array($fileData)) {
          foreach ($fileData as $fieldFiles) {
            if (!is_array($fieldFiles)) {
              continue;
            }
            foreach ($fieldFiles as $fileRef) {
              $fid = $fileRef['fid'] ?? NULL;
              if ($fid) {
                $file = \Drupal\file\Entity\File::load($fid);
                if ($file) {
                  $physicalFiles[] = $file->getFileUri();
                  $file->delete();
                }
              }
            }
          }
        }

        // Delete DB record.
        $database->delete('employment_applications')
          ->condition('id', $row->id)
          ->execute();

        // Commit.
        unset($transaction);
      }
      catch (\Throwable $e) {
        $transaction->rollBack();
        $logger->error('Failed to purge application @id: @error', [
          '@id' => $row->application_id,
          '@error' => $e->getMessage(),
        ]);
        continue;
      }

      // Outside transaction: best-effort secure deletion of physical files.
      foreach ($physicalFiles as $uri) {
        _employment_application_secure_delete_file($fileSystem, $uri, $logger);
      }

      $count++;
    }

    if ($count > 0) {
      $logger->info('Data retention cron: purged @count applications older than @days days.', [
        '@count' => $count,
        '@days' => $retentionDays,
      ]);
    }
  }
  catch (\Throwable $e) {
    $logger->error('Application purge failed: @message', [
      '@message' => $e->getMessage(),
    ]);
  }

  // Purge expired drafts (7 days).
  if (!$database->schema()->tableExists('employment_application_drafts')) {
    $logger->warning('Table employment_application_drafts does not exist. Run "drush updb" to create it.');
    return;
  }
  $draftCutoff = \Drupal::time()->getRequestTime() - (7 * 86400);
  $draftsDeleted = $database->delete('employment_application_drafts')
    ->condition('created', $draftCutoff, '<')
    ->execute();
  if ($draftsDeleted > 0) {
    $logger->info('Draft cleanup: purged @count expired drafts.', [
      '@count' => $draftsDeleted,
    ]);
  }
}