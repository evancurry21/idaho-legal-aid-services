<?php

/**
 * @file
 * ILAS SEO module - provides SEO optimizations for Idaho Legal Aid Services.
 */

use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\node\NodeInterface;

/**
 * Implements hook_page_attachments_alter().
 *
 * Adds noindex meta tag to search pages, paginated pages, and filtered views
 * to prevent index bloat and improve crawl efficiency.
 */
function ilas_seo_page_attachments_alter(array &$attachments) {
  // Don't run on admin pages.
  if (\Drupal::service('router.admin_context')->isAdminRoute()) {
    return;
  }

  $should_noindex = FALSE;
  $request = \Drupal::request();
  $route_match = \Drupal::routeMatch();
  $route_name = $route_match->getRouteName();

  // Noindex 404 error pages — they should never be indexed.
  if ($route_name === 'system.404') {
    $should_noindex = TRUE;
  }

  // Noindex auto-translated language paths (sw, nl).
  // These languages use machine translation and may be thin content.
  // Only English (en) and Spanish (es) are human-translated.
  $current_language = \Drupal::languageManager()->getCurrentLanguage()->getId();
  $auto_translated_languages = ['sw', 'nl'];
  if (in_array($current_language, $auto_translated_languages, TRUE)) {
    $should_noindex = TRUE;
  }

  // Routes that should always be noindex.
  // Note: /forms and /guides main pages are indexed (in sitemap).
  // Only search pages and their filtered/paginated variants get noindex.
  $noindex_routes = [
    // Search pages.
    'view.search.page_1',
    'view.site_search.page_1',
    'search.view_node_search',
    'search.view',
  ];

  // Check if current route is in noindex list.
  if (in_array($route_name, $noindex_routes)) {
    $should_noindex = TRUE;
  }

  // Check for pagination on any page (page parameter > 0).
  $page = $request->query->get('page');
  if (!empty($page) && is_numeric($page) && (int) $page > 0) {
    $should_noindex = TRUE;
  }

  // Check for exposed filter parameters that indicate a filtered/faceted page.
  // These parameters should trigger noindex regardless of route type to prevent
  // crawl waste on parameterized URLs.
  $filter_params = ['keys', 'search', 'category', 'topic', 'type', 'sort_by', 'sort_order'];
  foreach ($filter_params as $param) {
    if ($request->query->has($param)) {
      $should_noindex = TRUE;
      break;
    }
  }

  // Remove the Drupal generator meta tag to reduce CMS fingerprinting (L-1).
  if (isset($attachments['#attached']['html_head'])) {
    foreach ($attachments['#attached']['html_head'] as $key => $tag) {
      if (isset($tag[1]) && $tag[1] === 'system_meta_generator') {
        unset($attachments['#attached']['html_head'][$key]);
      }
    }
  }

  // Apply noindex if conditions are met.
  if ($should_noindex) {
    // Remove any existing robots meta tag first.
    if (isset($attachments['#attached']['html_head'])) {
      foreach ($attachments['#attached']['html_head'] as $key => $tag) {
        if (isset($tag[1]) && $tag[1] === 'robots') {
          unset($attachments['#attached']['html_head'][$key]);
        }
      }
    }

    // Add noindex, follow meta tag.
    $attachments['#attached']['html_head'][] = [
      [
        '#tag' => 'meta',
        '#attributes' => [
          'name' => 'robots',
          'content' => 'noindex, follow',
        ],
      ],
      'robots_noindex',
    ];
  }

  // Add publishingPrinciples to Article schema for article content types.
  $route_match = \Drupal::routeMatch();
  $node = $route_match->getParameter('node');
  if ($node instanceof NodeInterface) {
    $article_bundles = ['press_entry', 'resource', 'news', 'legal_content'];
    if (in_array($node->bundle(), $article_bundles, TRUE)) {
      $attachments['#attached']['html_head'][] = [
        [
          '#tag' => 'meta',
          '#attributes' => [
            'name' => 'publishingPrinciples',
            'content' => 'https://idaholegalaid.org/editorial-policy',
            'group' => 'schema_article',
            'schema_metatag' => TRUE,
          ],
        ],
        'schema_article_publishing_principles',
      ];
    }
  }
}

/**
 * Implements hook_metatags_alter().
 *
 * Fixes schema.org structured data and ensures metatag correctness:
 * - Converts SmartDate Unix timestamps to ISO 8601 for Event schema.
 * - Sets conditional eventAttendanceMode based on event format field.
 * - Builds properly structured location schema for events.
 * - Ensures Article/NewsArticle schema always has an image property.
 * - Enforces noindex for search/pagination/auto-translated pages.
 */
function ilas_seo_metatags_alter(array &$metatags, array &$context) {
  $request = \Drupal::request();
  $route_name = \Drupal::routeMatch()->getRouteName();

  // --- Noindex enforcement ---
  $noindex_routes = [
    'view.search.page_1',
    'view.site_search.page_1',
    'system.404',
  ];

  $should_noindex = in_array($route_name, $noindex_routes);

  $page = $request->query->get('page');
  if (!empty($page) && is_numeric($page) && (int) $page > 0) {
    $should_noindex = TRUE;
  }

  $current_language = \Drupal::languageManager()->getCurrentLanguage()->getId();
  if (in_array($current_language, ['sw', 'nl'], TRUE)) {
    $should_noindex = TRUE;
  }

  if ($should_noindex) {
    $metatags['robots'] = 'noindex, follow';
  }

  // --- Schema fixes (require entity context) ---
  $entity = $context['entity'] ?? NULL;
  if (!$entity instanceof NodeInterface) {
    return;
  }

  $bundle = $entity->bundle();

  // === Fix Event schema (dates, attendance mode, location) ===
  if ($bundle === 'event') {
    _ilas_seo_fix_event_schema($metatags, $entity);
  }

  // === Fix Article/NewsArticle image, inLanguage, and about property ===
  if (in_array($bundle, ['press_entry', 'resource', 'news', 'legal_content'], TRUE)) {
    _ilas_seo_fix_article_image($metatags, $entity);
    // Add inLanguage for better multi-language schema understanding.
    $metatags['schema_article_in_language'] = $entity->language()->getId();

    // Fix article_tag for multi-value taxonomy fields.
    // Token [node:field:entity:name] only returns the first delta; we need all
    // values comma-separated so the article_tag plugin (multiple=TRUE) can
    // split them into individual <meta property="article:tag"> elements.
    $tag_field_map = [
      'news' => 'field_tags',
      'resource' => 'field_topics',
    ];
    if (isset($tag_field_map[$bundle])) {
      $tag_field = $tag_field_map[$bundle];
      if ($entity->hasField($tag_field) && !$entity->get($tag_field)->isEmpty()) {
        $tag_names = [];
        foreach ($entity->get($tag_field)->referencedEntities() as $term) {
          $tag_names[] = $term->label();
        }
        if (!empty($tag_names)) {
          $metatags['article_tag'] = implode(',', $tag_names);
        }
      }
    }

    // Fix 'about' property to use Thing structure (resource and legal_content).
    if (in_array($bundle, ['resource', 'legal_content'], TRUE)) {
      $about_name = '';
      // Resource uses field_service_areas (plural), legal_content uses field_service_area (singular).
      $about_fields = ['field_service_areas', 'field_service_area'];
      foreach ($about_fields as $about_field) {
        if ($entity->hasField($about_field) && !$entity->get($about_field)->isEmpty()) {
          $term = $entity->get($about_field)->entity;
          if ($term) {
            $about_name = $term->label();
            break;
          }
        }
      }
      if (!empty($about_name)) {
        $metatags['schema_article_about'] = serialize([
          '@type' => 'Thing',
          'name' => $about_name,
        ]);
      }
    }
  }

  // === Add mainEntityOfPage to Event schema ===
  if ($bundle === 'event') {
    $metatags['schema_event_main_entity_of_page'] = $entity->toUrl()->setAbsolute()->toString();
  }
}

/**
 * Fixes Event schema: dates to ISO 8601, attendance mode, and location.
 *
 * @param array $metatags
 *   The metatag values array (pre-token-replacement).
 * @param \Drupal\node\NodeInterface $node
 *   The event node entity.
 */
function _ilas_seo_fix_event_schema(array &$metatags, NodeInterface $node): void {
  // --- Fix dates: read SmartDate field directly, format as ISO 8601 ---
  if ($node->hasField('field_event__date') && !$node->get('field_event__date')->isEmpty()) {
    $date_item = $node->get('field_event__date')->first();

    // SmartDate timezone property can be NULL or empty string; guard both.
    $timezone_string = $date_item->timezone ?? '';
    if ($timezone_string === '') {
      // Fall back to Drupal site default, then PHP default, then UTC.
      $timezone_string = \Drupal::config('system.date')->get('timezone.default')
        ?: date_default_timezone_get()
        ?: 'America/Boise';
    }

    try {
      $timezone = new \DateTimeZone($timezone_string);
    }
    catch (\Exception $e) {
      \Drupal::logger('ilas_seo')->warning('Invalid timezone "@tz" on event node @nid; falling back to America/Boise.', [
        '@tz' => $timezone_string,
        '@nid' => $node->id(),
      ]);
      $timezone = new \DateTimeZone('America/Boise');
    }

    $start_value = $date_item->value;
    if (is_numeric($start_value)) {
      $dt = new \DateTime('@' . (int) $start_value);
      $dt->setTimezone($timezone);
      $metatags['schema_event_start_date'] = $dt->format('c');
    }

    $end_value = $date_item->end_value;
    if (is_numeric($end_value)) {
      $dt = new \DateTime('@' . (int) $end_value);
      $dt->setTimezone($timezone);
      $metatags['schema_event_end_date'] = $dt->format('c');
    }
  }

  // --- Fix attendance mode based on event format field ---
  $format = 'in_person';
  if ($node->hasField('field_event__format') && !$node->get('field_event__format')->isEmpty()) {
    $format = $node->get('field_event__format')->value;
  }

  switch ($format) {
    case 'online':
      $metatags['schema_event_event_attendance_mode'] = 'OnlineEventAttendanceMode';
      // Build VirtualLocation with join URL from the event link field.
      $virtual_url = $node->toUrl()->setAbsolute()->toString();
      if ($node->hasField('field_event__link') && !$node->get('field_event__link')->isEmpty()) {
        $link_item = $node->get('field_event__link')->first();
        $link_url = $link_item->getUrl();
        if ($link_url) {
          $virtual_url = $link_url->setAbsolute()->toString();
        }
      }
      $metatags['schema_event_location'] = serialize([
        '@type' => 'VirtualLocation',
        'url' => $virtual_url,
      ]);
      break;

    case 'hybrid':
      $metatags['schema_event_event_attendance_mode'] = 'MixedEventAttendanceMode';
      // For hybrid: build an array with both physical Place and VirtualLocation.
      $locations = [];

      // Physical location.
      $place = _ilas_seo_build_event_place($node);
      if ($place) {
        $locations[] = $place;
      }

      // Virtual location.
      $virtual_url = $node->toUrl()->setAbsolute()->toString();
      if ($node->hasField('field_event__link') && !$node->get('field_event__link')->isEmpty()) {
        $link_item = $node->get('field_event__link')->first();
        $link_url = $link_item->getUrl();
        if ($link_url) {
          $virtual_url = $link_url->setAbsolute()->toString();
        }
      }
      $locations[] = [
        '@type' => 'VirtualLocation',
        'url' => $virtual_url,
      ];

      $metatags['schema_event_location'] = serialize($locations);
      break;

    default:
      // In-person (default).
      $metatags['schema_event_event_attendance_mode'] = 'OfflineEventAttendanceMode';
      $place = _ilas_seo_build_event_place($node);
      if ($place) {
        $metatags['schema_event_location'] = serialize($place);
      }
      break;
  }

  // --- Fix event image fallback ---
  $image_url = _ilas_seo_get_node_image_url($node);
  if ($image_url) {
    $metatags['schema_event_image'] = $image_url;
  }
}

/**
 * Builds a Place schema array from an event node's location fields.
 *
 * @param \Drupal\node\NodeInterface $node
 *   The event node.
 *
 * @return array|null
 *   A Place schema array, or NULL if no location data is available.
 */
function _ilas_seo_build_event_place(NodeInterface $node): ?array {
  $location_name = '';
  if ($node->hasField('field_event__location_name') && !$node->get('field_event__location_name')->isEmpty()) {
    $location_name = $node->get('field_event__location_name')->value;
  }

  $place = [
    '@type' => 'Place',
    'name' => $location_name,
  ];

  // Build structured PostalAddress from Address module field.
  if ($node->hasField('field_event__location_address') && !$node->get('field_event__location_address')->isEmpty()) {
    $address = $node->get('field_event__location_address')->first();
    $postal_address = [
      '@type' => 'PostalAddress',
      'addressCountry' => $address->country_code ?: 'US',
    ];

    if (!empty($address->address_line1)) {
      $postal_address['streetAddress'] = $address->address_line1;
      if (!empty($address->address_line2)) {
        $postal_address['streetAddress'] .= ', ' . $address->address_line2;
      }
    }
    if (!empty($address->locality)) {
      $postal_address['addressLocality'] = $address->locality;
    }
    if (!empty($address->administrative_area)) {
      $postal_address['addressRegion'] = $address->administrative_area;
    }
    if (!empty($address->postal_code)) {
      $postal_address['postalCode'] = $address->postal_code;
    }

    $place['address'] = $postal_address;
  }

  // Only return if we have at least a name or address.
  if (empty($location_name) && !isset($place['address'])) {
    return NULL;
  }

  return $place;
}

/**
 * Ensures Article/NewsArticle schema has an image property.
 *
 * Sets the schema_article_image directly from the entity's media fields,
 * bypassing token resolution which may fail for some field configurations.
 *
 * @param array $metatags
 *   The metatag values array.
 * @param \Drupal\node\NodeInterface $node
 *   The article node entity.
 */
function _ilas_seo_fix_article_image(array &$metatags, NodeInterface $node): void {
  $image_url = _ilas_seo_get_node_image_url($node);
  if ($image_url) {
    $metatags['schema_article_image'] = $image_url;
  }
  elseif (empty($metatags['schema_article_image'])) {
    // Fallback to organization logo if no image is available.
    $metatags['schema_article_image'] = 'https://idaholegalaid.org/themes/custom/b5subtheme/images/ILAS_logo_notagline_bg-white_raster.png';
  }
}

/**
 * Extracts the absolute URL of a node's featured/SEO image.
 *
 * Checks field_seo_image first, then field_featured_image.
 *
 * @param \Drupal\node\NodeInterface $node
 *   The node entity.
 *
 * @return string|null
 *   The absolute image URL, or NULL if no image is available.
 */
function _ilas_seo_get_node_image_url(NodeInterface $node): ?string {
  $image_fields = ['field_seo_image', 'field_featured_image'];

  foreach ($image_fields as $field_name) {
    if (!$node->hasField($field_name) || $node->get($field_name)->isEmpty()) {
      continue;
    }

    $media = $node->get($field_name)->entity;
    if (!$media || !$media->hasField('field_media_image') || $media->get('field_media_image')->isEmpty()) {
      continue;
    }

    $file = $media->get('field_media_image')->entity;
    if ($file) {
      return \Drupal::service('file_url_generator')->generateAbsoluteString($file->getFileUri());
    }
  }

  return NULL;
}
