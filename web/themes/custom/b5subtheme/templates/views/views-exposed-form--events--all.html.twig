{#
/**
 * @file
 * Theme override for Events listing exposed filter form.
 *
 * Renders the upcoming/past grouped filter as styled tab buttons
 * instead of a dropdown select. The select element is hidden via CSS
 * and JavaScript syncs tab clicks to the hidden select value.
 *
 * Available variables:
 * - form: The exposed form render array containing the "when" filter.
 */
#}

{# Render the form with custom tab markup #}
<div class="events-filter">
  <div class="events-filter__tabs" role="tablist" aria-label="{{ 'Filter events by time'|t }}">
    <a href="?when=1"
       class="events-filter__tab{{ (form.when['#value']|default('1') == '1') ? ' events-filter__tab--active' : '' }}"
       role="tab"
       aria-selected="{{ (form.when['#value']|default('1') == '1') ? 'true' : 'false' }}">
      {{ 'Upcoming'|t }}
    </a>
    <a href="?when=2"
       class="events-filter__tab{{ (form.when['#value']|default('1') == '2') ? ' events-filter__tab--active' : '' }}"
       role="tab"
       aria-selected="{{ (form.when['#value']|default('1') == '2') ? 'true' : 'false' }}">
      {{ 'Past'|t }}
    </a>
  </div>

  {# Hidden form elements for Views AJAX to work correctly #}
  <div class="events-filter__hidden visually-hidden">
    {{ form.when }}
    {{ form.actions }}
    {{ form|without('when', 'actions') }}
  </div>
</div>
