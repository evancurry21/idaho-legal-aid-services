{#
/**
 * @file
 * Theme override for guide category card fields.
 * Makes the entire card clickable with proper URL slug formatting.
 */
#}

{# Extract the term name and create URL-safe slug #}
{% set term_name = fields.name.content|render|striptags|trim %}
{% set term_slug = term_name|lower|replace({' ': '-', "'": '', '"': ''}) %}
{% set term_url = '/guides/' ~ term_slug %}

{# Get description if available #}
{% set term_description = fields.description__value.content|render|striptags|trim %}

<a href="{{ term_url }}" class="guide-category-card-link" aria-label="{{ term_name }} guides">
  <h3 class="guide-category-title">{{ term_name }}</h3>
  {% if term_description %}
    <p class="guide-category-description">{{ term_description }}</p>
  {% endif %}
</a>
