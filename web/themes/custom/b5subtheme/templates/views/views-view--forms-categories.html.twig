{#
/**
 * @file
 * Theme override for the Forms landing page view.
 * Displays form categories as clickable cards with curved header.
 */
#}

{{ attach_library('b5subtheme/forms') }}

<div{{ attributes.addClass('view', 'forms-view', 'forms-landing') }}>

  {# Curved page header matching site style #}
  <section class="curved-page-header forms-curved-header">
    <div class="container">
      <h1 class="curved-page-header-title">Forms & Documents</h1>
    </div>
  </section>

  {# Intro text below curved header #}
  {% if header %}
    <div class="forms-intro-section">
      <div class="container">
        <div class="forms-intro">
          {{ header }}
        </div>
      </div>
    </div>
  {% endif %}

  {# Category cards grid #}
  <div class="forms-content">
    <div class="container">
      <div class="forms-main-content">
        {% if rows %}
          <div class="forms-category-grid" role="list" aria-label="Form categories">
            {{ rows }}
          </div>
        {% elseif empty %}
          <div class="forms-empty-state">
            {{ empty }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  {% if pager %}
    <div class="forms-pager">
      <div class="container">
        {{ pager }}
      </div>
    </div>
  {% endif %}

  {% if footer %}
    <div class="forms-footer">
      <div class="container">
        {{ footer }}
      </div>
    </div>
  {% endif %}
</div>
