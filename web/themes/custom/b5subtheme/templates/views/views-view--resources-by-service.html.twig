{#
/**
 * @file
 * Theme override for resources by service view.
 * Combines navigation and resources display.
 */
#}

{{ attach_library('b5subtheme/resources') }}

<div{{ attributes.addClass('view', 'resources-view') }}>

  {# Curved page header - only for page display, not embedded blocks #}
  {% if view.current_display starts with 'page' %}
    <section class="curved-page-header resources-curved-header">
      <div class="container">
        <h1 class="curved-page-header-title">{{ view.getTitle() ?: 'Resources' }}</h1>
      </div>
    </section>
  {% endif %}

  {#
    Hybrid filter pattern: Pills for ≤6 topics, Dropdown for >6 topics.
    JavaScript determines which to display based on topic count.
  #}
  <div class="resource-filter-section">
    <div class="container">
      <div class="resource-filter-container" role="group" aria-label="{{ 'Filter resources by topic'|t }}">

        {# Pills pattern (shown when ≤6 topics) #}
        <div class="resource-filters resource-filters--pills" style="display: none;">
          <ul class="nav nav-pills flex-wrap gap-2" role="tablist" aria-label="{{ 'Topic filters'|t }}">
            <li class="nav-item" role="presentation">
              <button
                class="nav-link pill-link active"
                role="tab"
                aria-selected="true"
                tabindex="0"
                data-filter="all">
                {{ 'All Topics'|t }}
              </button>
            </li>
          </ul>
        </div>

        {# Dropdown pattern (shown when >6 topics) - matches /forms and /guides style #}
        <div class="resource-filters resource-filters--dropdown" style="display: none;">
          <div class="resource-filter">
            <div class="resource-filter__inner">
              <div class="resource-filter__select">
                <label for="resource-topic-filter">{{ 'Filter by Topic'|t }}</label>
                <select id="resource-topic-filter" class="resource-filter__dropdown" aria-describedby="resource-filter-status">
                  <option value="all" selected>{{ 'All Topics'|t }}</option>
                  {# Options populated by JavaScript #}
                </select>
              </div>
            </div>
          </div>
          <span id="resource-filter-status" class="visually-hidden" aria-live="polite"></span>
        </div>

      </div>
    </div>
  </div>
  
  {% if header %}
    <div class="view-header">
      {{ header }}
    </div>
  {% endif %}
  
  {% if exposed %}
    <div class="view-filters">
      {{ exposed }}
    </div>
  {% endif %}
  
  {% if attachment_before %}
    <div class="attachment attachment-before">
      {{ attachment_before }}
    </div>
  {% endif %}
  
  {% if rows %}
    <div class="view-content">
      <div class="container">
        {{ rows }}
      </div>
    </div>
  {% elseif empty %}
    <div class="view-empty">
      <div class="container">
        {{ empty }}
      </div>
    </div>
  {% endif %}
  
  {% if pager %}
    {{ pager }}
  {% endif %}
  
  {% if attachment_after %}
    <div class="attachment attachment-after">
      {{ attachment_after }}
    </div>
  {% endif %}
  
  {% if more %}
    {{ more }}
  {% endif %}
  
  {% if footer %}
    <div class="view-footer">
      {{ footer }}
    </div>
  {% endif %}
  
  {% if feed_icons %}
    <div class="feed-icons">
      {{ feed_icons }}
    </div>
  {% endif %}
</div>