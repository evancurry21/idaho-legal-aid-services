{#
/**
 * @file
 * Theme override for the Forms by Topic view.
 * Displays forms within a specific category.
 */
#}

{{ attach_library('b5subtheme/forms') }}

<div{{ attributes.addClass('view', 'forms-view', 'forms-by-topic') }}>

  {# Curved page header with title #}
  <section class="curved-page-header forms-curved-header">
    <div class="container">
      <h1 class="curved-page-header-title">{{ view.getTitle() }}</h1>
    </div>
  </section>

  {# Form items listing #}
  <div class="forms-content">
    <div class="container">
      <div class="forms-main-content">
        {% if rows %}
          <div class="forms-item-list" role="list" aria-label="Forms in this category">
            {{ rows }}
          </div>
        {% elseif empty %}
          <div class="forms-empty-state">
            {{ empty }}
          </div>
        {% endif %}

        {# Back button at bottom left #}
        <div class="forms-back-nav">
          <a href="/forms" class="btn btn-primary">
            <i class="fas fa-arrow-left"></i> Back
          </a>
        </div>
      </div>
    </div>
  </div>

  {% if pager %}
    <div class="forms-pager">
      <div class="container">
        {{ pager }}
      </div>
    </div>
  {% endif %}
</div>
