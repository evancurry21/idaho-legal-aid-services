{#
/**
 * @file
 * Template for Content Section paragraph type.
 *
 * Renders a titled text section with optional styling and anchor ID.
 *
 * Available variables:
 * - paragraph: The paragraph entity
 * - paragraph.field_section_id: Optional HTML anchor ID for jump links
 * - paragraph.field_section_title: Section heading text
 * - paragraph.field_section_body: WYSIWYG body content
 * - paragraph.field_section_style: Visual style ("default" or "highlighted")
 */
#}

{#
  field_section_style is a list_string with allowed_values "default" and
  "highlighted"; field_section_id is a string with is_ascii=true. Both are
  consumed in attribute / class-string contexts where `content.field_*` would
  inject a wrapper div and break rendering. Twig autoescape applies in HTML
  attribute context, and the field-level enum/ASCII constraints prevent any
  HTML metacharacters from reaching output.
#}
{% set style = paragraph.field_section_style.value|default('default') %}
{% set section_id = paragraph.field_section_id.value %}

{% set classes = [
  'content-section',
  'content-section--' ~ style,
] %}

<section{{ attributes.addClass(classes) }}{% if section_id %} id="{{ section_id }}"{% endif %}>
  {% if paragraph.field_section_title.value %}
    {# field_section_title is a plain `string` field with no text format; there
       is no filter pipeline to bypass. Twig autoescape encodes any HTML
       metacharacters in the output. Avoiding `content.field_section_title`
       here keeps the h2 free of Drupal's field-wrapper markup and prevents
       the double-encoding that would result from `|render|striptags|trim`
       (which discards the Markup safety wrapper). #}
    <h2 class="content-section__title">
      {{ paragraph.field_section_title.value }}
    </h2>
  {% endif %}

  <div class="content-section__body content-body">
    {{ content.field_section_body }}
  </div>
</section>
