{#
  paragraph--faq-smart-section.html.twig
  Used by the "FAQ Smart Section" paragraph type.

  Fields:
    - field_faq_section_title (overall title for the FAQ section)
    - field_faq_items (references to the "faq_item" paragraphs)
    - field_search_placeholder (custom placeholder text for search)

  Features:
    - Semantic anchor IDs for deep-linking (field_anchor_id or auto-generated)
    - FAQPage schema.org markup for SEO
    - Search functionality with live results
#}

{% set paragraph_id = paragraph.entity.id() %}
{% set accordion_id = 'faq-' ~ paragraph_id %}
{% set search_id = 'faq-search-' ~ paragraph_id %}
{% set search_placeholder = content.field_search_placeholder[0]['#context']['value'] ?? 'Search FAQs and resources...' %}

{# Add FAQ Schema markup for SEO #}
{# Build FAQ items array first to avoid trailing comma issues #}
{% set faq_items = [] %}
{% for item in content.field_faq_items %}
  {% if item['#paragraph'] is defined %}
    {% set faq_items = faq_items|merge([item['#paragraph']]) %}
  {% endif %}
{% endfor %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "{{ url('<current>')|render ~ '#faq-' ~ paragraph_id }}",
  "mainEntity": [
    {% for faq in faq_items %}
        {
          "@type": "Question",
          "name": {{ faq.field_faq_question.value|default('')|json_encode|raw }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ faq.field_faq_answer.value|default('')|json_encode|raw }}
          }
        }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

<div class="faq-smart-section">
  {% if content.field_faq_section_title %}
    <h3 class="faq-section-title">
      {{ content.field_faq_section_title }}
    </h3>
  {% endif %}

  {# Search bar with global search capabilities #}
  <div class="faq-search-container">
    <label class="faq-search-label" for="{{ search_id }}">Search FAQs</label>
    <div class="input-group">
      <span class="input-group-text">
        <i class="fa-solid fa-magnifying-glass"></i>
      </span>
      <input type="text"
             class="form-control faq-search"
             id="{{ search_id }}"
             placeholder="{{ search_placeholder }}"
             aria-label="Search FAQs and resources">
      <button class="btn btn-primary faq-search-btn" type="button" id="{{ search_id }}-button">
        Search
      </button>
    </div>
    <div id="{{ search_id }}-results" class="faq-search-results mt-2 d-none" role="region" aria-live="polite" aria-atomic="true">
      {# Search results will be populated here via JS #}
    </div>
    {# Screen reader announcements for search status #}
    <div class="visually-hidden" role="status" aria-live="assertive" aria-atomic="true" id="{{ search_id }}-status"></div>
  </div>


  {# Accordion for FAQs #}
  <div class="accordion faq-accordion" id="{{ accordion_id }}">
    {% for item in content.field_faq_items %}
      {% if item['#paragraph'] is defined %}
        {% set faq_para = item['#paragraph'] %}
        {% set entity_id = faq_para.id() %}

        {# Generate anchor ID: use field_anchor_id if set, otherwise auto-generate from question #}
        {% set custom_anchor = faq_para.field_anchor_id.value|default('') %}
        {% if custom_anchor %}
          {% set item_anchor = custom_anchor %}
        {% else %}
          {# Auto-generate slug from question text #}
          {% set question_text = faq_para.field_faq_question.value|default('faq-' ~ entity_id) %}
          {% set item_anchor = question_text
            |lower
            |replace({' ': '-', '/': '-', "'": '', '"': '', '?': '', ':': '', '(': '', ')': '', ',': '', '.': '', '!': ''})
            |slice(0, 80)
            |trim('-') %}
        {% endif %}

        {# Internal IDs for Bootstrap collapse (use entity ID for uniqueness) #}
        {% set collapse_id = 'collapse-faq-' ~ entity_id %}
        {% set heading_id = 'heading-faq-' ~ entity_id %}

        <div class="accordion-item faq-item" id="{{ item_anchor }}" data-faq-anchor="{{ item_anchor }}">
          <h2 class="accordion-header" id="{{ heading_id }}">
            <button class="accordion-button collapsed" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#{{ collapse_id }}"
                    aria-expanded="false"
                    aria-controls="{{ collapse_id }}">
              {% if faq_para.field_faq_question.value %}
                {{ faq_para.field_faq_question.value }}
              {% endif %}
            </button>
          </h2>
          <div id="{{ collapse_id }}"
               class="accordion-collapse collapse"
               aria-labelledby="{{ heading_id }}"
               data-bs-parent="#{{ accordion_id }}">
            <div class="accordion-body">
              {% if faq_para.field_faq_answer.value %}
                {{ faq_para.field_faq_answer|view }}
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{{ attach_library('b5subtheme/smart-faq') }}
{{ attach_library('b5subtheme/accordion-deeplink') }}
