{#
/**
 * @file
 * Theme override for the basic structure of a single Drupal page.
 *
 * Variables:
 * - logged_in: A flag indicating if user is logged in.
 * - root_path: The root path of the current page (e.g., node, admin, user).
 * - node_type: The content type for the current node, if the page is a node.
 * - head_title: List of text elements that make up the head_title variable.
 *   May contain one or more of the following:
 *   - title: The title of the page.
 *   - name: The name of the site.
 *   - slogan: The slogan of the site.
 * - page_top: Initial rendered markup. This should be printed before 'page'.
 * - page: The rendered page markup.
 * - page_bottom: Closing rendered markup. This variable should be printed after
 *   'page'.
 * - db_offline: A flag indicating if the database is offline.
 * - placeholder_token: The token for generating head, css, js and js-bottom
 *   placeholders.
 *
 * @see template_preprocess_html()
 */
#}
{%
  set body_classes = [
    logged_in ? 'user-logged-in',
    not root_path ? 'path-frontpage' : 'path-' ~ root_path|clean_class,
    node_type ? 'page-node-type-' ~ node_type|clean_class,
    db_offline ? 'db-offline',
    (b5_body_schema == 'light' ? ' text-dark' : (b5_body_schema == 'dark' ? ' text-light' :  ' ')),
    (b5_body_bg_schema != 'none' ? " bg-#{b5_body_bg_schema}" : ' '),
    'd-flex flex-column'
  ]
%}

<!DOCTYPE html>
<html{{ html_attributes }}>
  <head>
    <head-placeholder token="{{ placeholder_token }}">
    <title>{{ head_title|safe_join(' | ') }}</title>

    {# Google tag (gtag.js) - async loader only in head; config script moved to body end #}
    {% if google_tag_id %}
      <script async src="https://www.googletagmanager.com/gtag/js?id={{ google_tag_id }}"></script>
    {% endif %}
    
    {# Critical CSS is shipped via b5subtheme/critical-styles library (see b5subtheme.info.yml). #}

    {# Preload critical resources #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;500;600;700&display=swap"></noscript>
    
    <css-placeholder token="{{ placeholder_token }}">
    <js-placeholder token="{{ placeholder_token }}">
  </head>
  <body{{ attributes.addClass(body_classes) }}>
    {#
      Keyboard navigation/accessibility link to main content section in
      page.html.twig.
    #}
    <div class="visually-hidden-focusable skip-link p-3 container">
      <a href="#main-content" class="p-2">
        {{ 'Skip to main content'|t }}
      </a>
    </div>
    {{ page_top }}
    {{ page }}
    {{ page_bottom }}
    {# Back to top button #}
    <button class="back-to-top" aria-label="{{ 'Back to top'|t }}">
      <i class="fas fa-chevron-up"></i>
    </button>
    
    {# Language switcher button #}
    {% set current_language = language %}
    {% set languages = language_links %}
    {% if languages and languages|length > 1 %}
    <div class="language-switcher-floating">
      <button class="language-switcher-toggle" aria-label="{{ 'Change language'|t }}" aria-expanded="false" aria-controls="languageMenu">
        <i class="fas fa-globe"></i>
      </button>
      <div class="language-menu" id="languageMenu">
        <ul>
          {% for lang_code, lang_data in languages %}
            <li>
              <a href="{{ lang_data.url }}" 
                 class="language-link{% if lang_code == current_language.id %} is-active{% endif %}"
                 hreflang="{{ lang_code }}"
                 data-drupal-link-system-path="{{ lang_data.url.routeName }}">
                {{ lang_data.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}
    <js-bottom-placeholder token="{{ placeholder_token }}">

    {# GA4 bootstrap is delivered by b5subtheme/ga4 library (attached from b5subtheme_preprocess_html). #}
  </body>
</html>
