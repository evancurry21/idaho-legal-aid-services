{#
/**
 * @file
 * Theme override to display a single page with centered logo and split menu.
 */
#}

{{ attach_library('b5subtheme/custom-scripts') }}
{{ attach_library('b5subtheme/mobile-menu') }}

{# Header Section - Single sticky container #}
<header class="site-header" role="banner">

  {# Utility Bar #}
  <div class="utility-bar">
    <div class="container">
      <div class="utility-bar-content" id="utilityBarContent">

        {# Legal Advice Hotline #}
        <div class="hotline">
          <a href="tel:+12087467541" aria-label="{{ 'Call Legal Advice Hotline at 208-746-7541'|t }}">
            <i class="fa-solid fa-phone-volume" aria-hidden="true"></i>
            <span class="d-none d-md-inline">{{ 'Legal Advice Hotline:'|t }}&nbsp;{{ '208-746-7541'|t }}</span>
            <span class="d-md-none">{{ 'Call Now'|t }}</span>
          </a>
        </div>

        {# Search #}
        <div class="search-col">
          <button type="button" class="search-trigger" id="searchToggle" data-search-trigger aria-label="{{ 'Open search'|t }}" aria-expanded="false" aria-controls="searchOverlay">
            <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
            <span>{{ 'Search'|t }}</span>
          </button>
        </div>

        {# Exit #}
        <div class="exit-link">
          <a href="https://www.google.com" aria-label="{{ 'Exit site securely'|t }}">
            <i class="fa-solid fa-arrow-right-from-bracket" aria-hidden="true"></i>
            <span>{{ 'Exit'|t }}</span>
          </a>
        </div>

        {# Get Help #}
        <div class="get-help">
          <button type="button" id="helpToggle" aria-label="{{ 'Get help menu'|t }}" aria-expanded="false" aria-controls="helpOverlay">
            <i class="fa-solid fa-heart" aria-hidden="true"></i>
            <span>{{ 'Get Help'|t }}</span>
          </button>
        </div>

      </div>

      {# Include search overlay #}
      {% include '@b5subtheme/includes/search-overlay.html.twig' %}
    </div>
  </div>

  {# Main Navigation #}
  <nav class="navbar navbar-expand-xl centered-logo-navbar" role="navigation" aria-label="{{ 'Main navigation'|t }}">
    <div class="container">

      {# Desktop: Split navigation with centered logo #}
      <div class="d-none d-xl-grid split-navigation">
        {# Left navigation: items 1-3 (built in preprocess) #}
        <div class="nav-section nav-left">
          {% if main_menu_left is defined %}
            {{ main_menu_left }}
          {% else %}
            {{ drupal_menu('main') }}
          {% endif %}
        </div>

        {# Centered Logo #}
        <a href="{{ path('<front>') }}" class="navbar-brand site-logo" title="{{ 'Home'|t }}" rel="home">
          <img src="/themes/custom/b5subtheme/images/Primary Logo & Tagline(2)_0.svg" alt="{{ 'Idaho Legal Aid Services'|t }}" />
        </a>

        {# Right navigation: items 4-6 (built in preprocess) #}
        <div class="nav-section nav-right">
          {% if main_menu_right is defined %}
            {{ main_menu_right }}
          {% else %}
            {{ drupal_menu('main') }}
          {% endif %}
        </div>
      </div>

      {# Tablet/Mobile: Logo on left #}
      <a href="{{ path('<front>') }}" class="navbar-brand site-logo d-xl-none" title="{{ 'Home'|t }}" rel="home">
        <img src="/themes/custom/b5subtheme/images/Primary Logo & Tagline(2)_0.svg" alt="{{ 'Idaho Legal Aid Services'|t }}" />
      </a>

      {# Mobile toggle button - triggers custom slide-out menu #}
      <button class="navbar-toggler d-xl-none"
              type="button"
              aria-controls="mobileMenuOverlay"
              aria-expanded="false"
              aria-label="{{ 'Toggle navigation'|t }}">
        <span class="navbar-toggler-icon"></span>
      </button>

    </div>
  </nav>

</header>

{# Main Content #}
<main role="main" id="main-content" tabindex="-1" class="main-content">
  {% if page.breadcrumb %}
    {{ page.breadcrumb }}
  {% endif %}

  {#
    Layout control variables come from b5subtheme_preprocess_page():
    - is_views_page: TRUE if this is a views page (detected by route)
    - views_page_id: The view machine name (e.g., 'guides', 'forms')
    - skip_page_header: TRUE if template handles its own curved header
    - skip_page_footer: TRUE if template handles its own blue footer curve
    - is_custom_layout: TRUE if using custom (non-standard) layout

    This replaces fragile path-based checks like "current_path starts with /forms".
  #}

  {# Determine layout type using preprocess variables #}
  {% set use_standard_layout = not is_front and not is_custom_layout %}

  {# Manual override from node template (e.g., node--donate sets disable_standard_layout) #}
  {% if disable_standard_layout is defined and disable_standard_layout %}
    {% set use_standard_layout = false %}
  {% endif %}

  {# Sidebar classes #}
  {% set sidebar_first_classes = (page.sidebar_first and page.sidebar_second)
    ? 'col-12 col-sm-6 col-lg-3'
    : 'col-12 col-lg-3' %}

  {% set sidebar_second_classes = (page.sidebar_first and page.sidebar_second)
    ? 'col-12 col-sm-6 col-lg-3'
    : 'col-12 col-lg-3' %}

  {% set content_classes = (page.sidebar_first and page.sidebar_second)
    ? 'col-12 col-lg-6'
    : ((page.sidebar_first or page.sidebar_second)
      ? 'col-12 col-lg-9'
      : 'col-12'
    ) %}

  {# Standard Layout with Gray Curved Header #}
  {% if use_standard_layout %}

    {# Gray Curved Header #}
    {% if node and node.getTitle() %}
      <section class="curved-page-header">
        <div class="container">
          {% set title_lower = node.getTitle()|lower %}
          {% if title_lower == 'about idaho legal aid services' %}
            <h1 class="curved-page-header-title">
              <span class="d-none d-sm-inline">{{ node.getTitle() }}</span>
              <span class="d-sm-none">ABOUT ILAS</span>
            </h1>
          {% elseif title_lower == 'employment opportunities' %}
            <h1 class="curved-page-header-title">
              <span class="d-none d-sm-inline">{{ node.getTitle() }}</span>
              <span class="d-sm-none">CAREERS</span>
            </h1>
          {% else %}
            <h1 class="curved-page-header-title">{{ node.getTitle() }}</h1>
          {% endif %}
        </div>
      </section>
    {% endif %}

    {# Standard Content Layout #}
    <div class="container">
      <div class="row">
        {% if page.sidebar_first %}
          <div class="order-2 order-lg-1 {{ sidebar_first_classes }}">
            {{ page.sidebar_first }}
          </div>
        {% endif %}

        <div class="order-1 order-lg-2 {{ content_classes }} standard-layout">
          {{ page.content }}
        </div>

        {% if page.sidebar_second %}
          <div class="order-3 {{ sidebar_second_classes }}">
            {{ page.sidebar_second }}
          </div>
        {% endif %}
      </div>
    </div>

    {# Blue Section Below #}
    <div class="curved-section-blue">
      <div class="curved-section-container">
        {# Additional content can go here #}
      </div>
    </div>

  {% else %}

    {# Custom Content Types - Include curved header/footer but no container wrapper #}
    {# is_custom_layout is set in b5subtheme_preprocess_page() based on node type or view ID #}
    {% if is_custom_layout %}

      {# Gray Curved Header (skip for content types/views that render their own) #}
      {# skip_page_header is set in preprocess for home_page, views with own headers, etc. #}
      {% if not skip_page_header and node and node.getTitle() %}
        <section class="curved-page-header">
          <div class="container">
            {% set title_lower_custom = node.getTitle()|lower %}
            {% if title_lower_custom == 'employment opportunities' %}
              <h1 class="curved-page-header-title">
                <span class="d-none d-sm-inline">{{ node.getTitle() }}</span>
                <span class="d-sm-none">CAREERS</span>
              </h1>
            {% else %}
              <h1 class="curved-page-header-title">{{ node.getTitle() }}</h1>
            {% endif %}
          </div>
        </section>
      {% endif %}

      {# Render content directly #}
      {{ page.content }}

      {# Blue Section Below (skip for content types that have their own) #}
      {# skip_page_footer is set in preprocess for home_page, donate, etc. #}
      {% if not skip_page_footer %}
        <div class="curved-section-blue">
          <div class="curved-section-container">
            {# Additional content can go here #}
          </div>
        </div>
      {% endif %}

    {% else %}
      {# Other non-standard pages (like front page) #}
      <div class="container">
        <div class="row">
          {% if page.sidebar_first %}
            <div class="order-2 order-lg-1 {{ sidebar_first_classes }}">
              {{ page.sidebar_first }}
            </div>
          {% endif %}

          <div class="order-1 order-lg-2 {{ content_classes }}">
            {{ page.content }}
          </div>

          {% if page.sidebar_second %}
            <div class="order-3 {{ sidebar_second_classes }}">
              {{ page.sidebar_second }}
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

  {% endif %}
</main>

{# Include footer #}
{% include '@b5subtheme/layout/footer.html.twig' %}

{# Include help overlay #}
{% include '@b5subtheme/includes/help-overlay.html.twig' %}
{% include '@b5subtheme/includes/mobile-menu.html.twig' %}

{# Announcement Overlay - rendered at page root level for proper z-index stacking #}
{% if announcement_overlay %}
  {{ announcement_overlay }}
{% endif %}
