{#
/**
 * @file
 * Navigation template for Gin toolbar on front-end pages.
 * This template ensures the Gin navigation renders correctly
 * when b5subtheme is the active theme.
 */
#}
{{ attach_library('b5subtheme/admin-toolbar-state') }}
<aside class="admin-toolbar" id="admin-toolbar" data-drupal-admin-styles>
  <div class="admin-toolbar__displace-placeholder"></div>

  {% set title_menu = 'admin-toolbar-title' %}

  <nav id="menu-builder" class="admin-toolbar__content" aria-labelledby="{{ title_menu }}">
    <h3 id="{{ title_menu }}" class="visually-hidden">{{ 'Administrative toolbar content'|t }}</h3>

    <div class="admin-toolbar__header">
      <div class="navigation-menu-wrapper menu--logo admin-toolbar__logo">
        <ul class="toolbar-menu" data-once="toolbar-menu" aria-labelledby="menu--logo">
          <li class="toolbar-menu__item toolbar-menu__item--level-1">
            {% if icon_path %}
              <a class="toolbar-link" href="{{ path('<front>') }}">
                <img alt="{{ 'Home'|t }}" src="{{ file_url(icon_path) }}" loading="eager" />
              </a>
            {% else %}
              <a href="{{ path('<front>') }}" class="toolbar-link toolbar-link--has-icon toolbar-link--gin-home">
                <span>{{ 'Home'|t }}</span>
              </a>
            {% endif %}
          </li>
        </ul>
      </div>
    </div>

    {{ menu_top }}
    {% for section in menu_middle %}
      {{ section }}
    {% endfor %}

    <div class="admin-toolbar__sticky-section">
      {{ menu_bottom }}
    </div>
  </nav>
</aside>
{# Admin toolbar expanded-state restore is handled by b5subtheme/admin-toolbar-state library. #}
