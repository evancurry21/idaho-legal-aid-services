{#
/**
 * @file
 * Premium Employment Application - Multi-Step Wizard
 * Accessible, secure, and user-friendly employment application
 * Properly integrated with Drupal 11 webform system
 */
#}

{{ attach_library('b5subtheme/premium-application') }}

<article{{ attributes.addClass('node', 'node--type-' ~ node.bundle|clean_class, 'premium-application-page') }}>

  <div{{ content_attributes.addClass('node__content') }}>

    {% if application_submitted %}
      {# Server-rendered success page — works without JavaScript #}
      <div class="application-success-server" role="main">
        <div class="container">
          <div class="success-content">
            <div class="success-icon-wrapper">
              <i class="fas fa-check-circle" aria-hidden="true"></i>
            </div>
            <h1>Application Submitted Successfully</h1>
            <p class="success-message">Thank you for your interest in joining our team. We've received your application and will review it carefully.</p>

            {% if application_id %}
              <div class="application-reference">
                <span class="reference-label">Your Application Reference:</span>
                <span class="reference-id">{{ application_id }}</span>
              </div>
            {% endif %}

            {% if application_position %}
              <p class="success-position">
                <strong>Position:</strong>
                {{ application_position }}{% if application_location %} &mdash; {{ application_location }}{% endif %}
              </p>
            {% endif %}

            <div class="next-steps">
              <h2>What happens next?</h2>
              <ul>
                <li>We'll acknowledge receipt of your application within 24 hours</li>
                <li>Our team will review your qualifications</li>
                <li>If you're a good fit, we'll contact you within 1-2 weeks for next steps</li>
              </ul>
            </div>

            <div class="success-actions">
              <a href="/employment" class="btn btn-primary">
                <i class="fas fa-briefcase" aria-hidden="true"></i> View Other Positions
              </a>
              <a href="/" class="btn btn-outline-secondary">Return Home</a>
            </div>
          </div>
        </div>
      </div>
    {% else %}

    {# Skip Link for Accessibility #}
    <a href="#application-form" class="visually-hidden-focusable">Skip to application form</a>

    {# Application Form - Proper Drupal Integration #}
    <form id="application-form"
          class="application-wizard"
          action="/employment-application/submit" 
          method="post" 
          enctype="multipart/form-data"
          novalidate
          aria-label="Employment Application Form"
          data-drupal-webform-id="employment_application">
      
      {# CSRF Token + Nonce - Populated by JavaScript from /employment-application/token #}
      <input type="hidden" name="form_token" id="form-token" value="">
      <input type="hidden" name="form_nonce" id="form-nonce" value="">
      <input type="hidden" name="form_id" value="webform_submission_employment_application_form">
      <input type="hidden" name="form_build_id" id="form-build-id" value="">
      <input type="hidden" name="op" value="Submit">

      {# Time-gate: form render timestamp for bot detection #}
      <input type="hidden" name="form_start_time" id="form-start-time" value="{{ "now"|date("U") }}">

      {# Honeypot: hidden field that bots will fill, humans won't see #}
      <div style="position: absolute; left: -9999px; top: -9999px;" aria-hidden="true">
        <label for="fax_number">Fax Number</label>
        <input type="text" name="fax_number" id="fax_number" tabindex="-1" autocomplete="off" value="">
      </div>

      {# Job data fields - populated by JavaScript from jobs API #}
      <input type="hidden" name="job_uuid" id="job_uuid" value="">
      <input type="hidden" name="job_title" id="job_title" value="">
      <input type="hidden" name="job_location" id="job_location" value="">
      <input type="hidden" name="position_applied" id="position_applied" value="">

      <div class="container">
        
        {# Progress Indicator #}
        <nav class="wizard-progress" role="navigation" aria-label="Application progress">
          <div class="progress-container">
            <ol class="progress-steps" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
              <li class="step active" data-step="1" aria-current="step">
                <button type="button" class="step-button" aria-label="Step 1: Personal Info">
                  <span class="step-circle">1</span>
                  <span class="step-label">Personal Info</span>
                </button>
              </li>
              <li class="step" data-step="2">
                <button type="button" class="step-button" aria-label="Step 2: Position Details">
                  <span class="step-circle">2</span>
                  <span class="step-label">Position Details</span>
                </button>
              </li>
              <li class="step" data-step="3">
                <button type="button" class="step-button" aria-label="Step 3: Questions">
                  <span class="step-circle">3</span>
                  <span class="step-label">Questions</span>
                </button>
              </li>
              <li class="step" data-step="4">
                <button type="button" class="step-button" aria-label="Step 4: Documents">
                  <span class="step-circle">4</span>
                  <span class="step-label">Documents</span>
                </button>
              </li>
              <li class="step" data-step="5">
                <button type="button" class="step-button" aria-label="Step 5: Review">
                  <span class="step-circle">5</span>
                  <span class="step-label">Review</span>
                </button>
              </li>
            </ol>
          </div>
        </nav>

        {# Main Application Form Content #}
        <div class="wizard-content">
          
          {# Step 1: Personal Information #}
          <fieldset class="wizard-step active" data-step="1" role="group" aria-labelledby="step1-heading">
            <div class="step-header">
              <h2 id="step1-heading">Let's start with your basic information</h2>
            </div>
            
            <div class="step-content">
              <div class="form-grid">
                <div class="form-group">
                  <label for="full_name" class="form-label required">
                    Full Name
                    <span class="visually-hidden">(required)</span>
                  </label>
                  <input type="text" 
                         id="full_name" 
                         name="full_name" 
                         class="form-control" 
                         required
                         aria-required="true"
                         aria-describedby="full_name_error"
                         data-validate="minLength:2,maxLength:100"
                         autocomplete="name">
                  <div class="form-feedback" id="full_name_error" role="alert" aria-live="polite"></div>
                </div>
                
                <div class="form-group">
                  <label for="email" class="form-label required">
                    Email Address
                    <span class="visually-hidden">(required)</span>
                  </label>
                  <input type="email" 
                         id="email" 
                         name="email" 
                         class="form-control" 
                         required
                         aria-required="true"
                         aria-describedby="email_error email_help"
                         data-validate="email"
                         autocomplete="email">
                  <div class="form-feedback" id="email_error" role="alert" aria-live="polite"></div>
                  <small id="email_help" class="form-help">We'll send updates to this email address</small>
                </div>
                
                <div class="form-group">
                  <label for="phone" class="form-label required">
                    Phone Number
                    <span class="visually-hidden">(required)</span>
                  </label>
                  <input type="tel" 
                         id="phone" 
                         name="phone" 
                         class="form-control" 
                         required
                         aria-required="true"
                         aria-describedby="phone_error"
                         data-validate="phone"
                         autocomplete="tel"
                         placeholder="(555) 123-4567">
                  <div class="form-feedback" id="phone_error" role="alert" aria-live="polite"></div>
                </div>
                
                <div class="form-group full-width">
                  <div class="address-grid">
                    <!-- Street Address - Full Width First Row -->
                    <div class="form-group address-street">
                      <label for="address_address" class="form-label required">Street Address</label>
                      <input type="text" 
                             id="address_address" 
                             name="address[address]" 
                             class="form-control"
                             autocomplete="street-address">
                    </div>
                    
                    <!-- City, State, ZIP - Second Row, Equal Width -->
                    <div class="form-group address-city">
                      <label for="address_city" class="form-label required">City</label>
                      <input type="text" 
                             id="address_city" 
                             name="address[city]" 
                             class="form-control"
                             autocomplete="address-level2">
                    </div>
                    <div class="form-group address-state">
                      <label for="address_state_province" class="form-label required">State</label>
                      <select id="address_state_province" 
                              name="address[state_province]" 
                              class="form-control"
                              autocomplete="address-level1">
                        <option value="">Select State</option>
                        <option value="AL">Alabama</option>
                        <option value="AK">Alaska</option>
                        <option value="AZ">Arizona</option>
                        <option value="AR">Arkansas</option>
                        <option value="CA">California</option>
                        <option value="CO">Colorado</option>
                        <option value="CT">Connecticut</option>
                        <option value="DE">Delaware</option>
                        <option value="DC">District of Columbia</option>
                        <option value="FL">Florida</option>
                        <option value="GA">Georgia</option>
                        <option value="HI">Hawaii</option>
                        <option value="ID">Idaho</option>
                        <option value="IL">Illinois</option>
                        <option value="IN">Indiana</option>
                        <option value="IA">Iowa</option>
                        <option value="KS">Kansas</option>
                        <option value="KY">Kentucky</option>
                        <option value="LA">Louisiana</option>
                        <option value="ME">Maine</option>
                        <option value="MD">Maryland</option>
                        <option value="MA">Massachusetts</option>
                        <option value="MI">Michigan</option>
                        <option value="MN">Minnesota</option>
                        <option value="MS">Mississippi</option>
                        <option value="MO">Missouri</option>
                        <option value="MT">Montana</option>
                        <option value="NE">Nebraska</option>
                        <option value="NV">Nevada</option>
                        <option value="NH">New Hampshire</option>
                        <option value="NJ">New Jersey</option>
                        <option value="NM">New Mexico</option>
                        <option value="NY">New York</option>
                        <option value="NC">North Carolina</option>
                        <option value="ND">North Dakota</option>
                        <option value="OH">Ohio</option>
                        <option value="OK">Oklahoma</option>
                        <option value="OR">Oregon</option>
                        <option value="PA">Pennsylvania</option>
                        <option value="RI">Rhode Island</option>
                        <option value="SC">South Carolina</option>
                        <option value="SD">South Dakota</option>
                        <option value="TN">Tennessee</option>
                        <option value="TX">Texas</option>
                        <option value="UT">Utah</option>
                        <option value="VT">Vermont</option>
                        <option value="VA">Virginia</option>
                        <option value="WA">Washington</option>
                        <option value="WV">West Virginia</option>
                        <option value="WI">Wisconsin</option>
                        <option value="WY">Wyoming</option>
                      </select>
                    </div>
                    <div class="form-group address-zip">
                      <label for="address_postal_code" class="form-label required">ZIP Code</label>
                      <input type="text"
                             id="address_postal_code"
                             name="address[postal_code]"
                             class="form-control"
                             autocomplete="postal-code"
                             pattern="[0-9]{5}(-[0-9]{4})?"
                             title="5-digit ZIP code (e.g. 83702) or ZIP+4 (e.g. 83702-1234)"
                             data-validate="zip"
                             aria-describedby="postal_code_help">
                      <small id="postal_code_help" class="form-text text-muted">e.g. 83702 or 83702-1234</small>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </fieldset>

          {# Step 2: Position Information - Dynamic Posted Jobs Only #}
          <fieldset class="wizard-step" data-step="2" role="group" aria-labelledby="step2-heading" hidden>
            <div class="step-header">
              <h2 id="step2-heading">Select the position you're applying for</h2>
            </div>

            <div class="step-content">
              {# Job Locked Confirmation Card - shown when arriving via deep link #}
              <div id="job-locked-confirmation"
                   class="job-confirmation-card"
                   role="region"
                   aria-labelledby="job-confirmation-heading"
                   tabindex="-1"
                   style="display: none;">

                {# Header with checkmark #}
                <div class="job-confirmation-card__header">
                  <div class="job-confirmation-card__check" aria-hidden="true">
                    <i class="fas fa-check"></i>
                  </div>
                  <div class="job-confirmation-card__intro">
                    <span class="job-confirmation-card__label" id="job-confirmation-heading">You're applying for:</span>
                    <h3 class="job-confirmation-card__title" id="job-locked-title"></h3>
                  </div>
                </div>

                {# Job Details Grid #}
                <div class="job-confirmation-card__details" role="list" aria-label="Position details">
                  <div class="job-detail-item" role="listitem" id="job-detail-location" style="display: none;">
                    <span class="job-detail-item__icon" aria-hidden="true">
                      <i class="fas fa-map-marker-alt"></i>
                    </span>
                    <span class="job-detail-item__label visually-hidden">Location:</span>
                    <span class="job-detail-item__value" data-field="location"></span>
                  </div>

                  <div class="job-detail-item" role="listitem" id="job-detail-type" style="display: none;">
                    <span class="job-detail-item__icon" aria-hidden="true">
                      <i class="fas fa-clock"></i>
                    </span>
                    <span class="job-detail-item__label visually-hidden">Employment Type:</span>
                    <span class="job-detail-item__value" data-field="employment_type"></span>
                  </div>

                  <div class="job-detail-item" role="listitem" id="job-detail-salary" style="display: none;">
                    <span class="job-detail-item__icon" aria-hidden="true">
                      <i class="fas fa-dollar-sign"></i>
                    </span>
                    <span class="job-detail-item__label visually-hidden">Salary Range:</span>
                    <span class="job-detail-item__value" data-field="salary_range"></span>
                  </div>

                  <div class="job-detail-item" role="listitem" id="job-detail-arrangement" style="display: none;">
                    <span class="job-detail-item__icon" aria-hidden="true">
                      <i class="fas fa-building"></i>
                    </span>
                    <span class="job-detail-item__label visually-hidden">Work Arrangement:</span>
                    <span class="job-detail-item__value" data-field="work_arrangement"></span>
                  </div>

                  <div class="job-detail-item" role="listitem" id="job-detail-deadline" style="display: none;">
                    <span class="job-detail-item__icon" aria-hidden="true">
                      <i class="fas fa-calendar-alt"></i>
                    </span>
                    <span class="job-detail-item__label visually-hidden">Application Deadline:</span>
                    <span class="job-detail-item__value" data-field="deadline"></span>
                  </div>

                  <div class="job-detail-item job-detail-item--open" role="listitem" id="job-detail-open-until-filled" style="display: none;">
                    <span class="job-detail-item__icon" aria-hidden="true">
                      <i class="fas fa-infinity"></i>
                    </span>
                    <span class="job-detail-item__value">Open until filled</span>
                  </div>
                </div>

                {# Actions #}
                <div class="job-confirmation-card__actions">
                  <a href="/employment" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2" aria-hidden="true"></i>
                    Back to Careers
                  </a>
                  <button type="button" id="unlock-job-btn" class="btn btn-outline-primary">
                    <i class="fas fa-exchange-alt me-2" aria-hidden="true"></i>
                    Choose a Different Position
                  </button>
                </div>

                {# Screen reader announcement #}
                <div class="visually-hidden" aria-live="polite" id="job-locked-announcement"></div>
              </div>

              {# Job Selection - shown when not locked #}
              <div id="job-selection-panel" class="form-grid">
                <div class="form-group full-width">
                  <label for="job_selected" class="form-label required">
                    Position Applying For
                    <span class="visually-hidden">(required)</span>
                  </label>
                  <select id="job_selected"
                          class="form-control"
                          required
                          aria-required="true"
                          aria-describedby="job_selected_error job_selected_help">
                    <option value="">Loading positions...</option>
                  </select>
                  <div class="form-feedback" id="job_selected_error" role="alert" aria-live="polite"></div>
                  <small id="job_selected_help" class="form-help">Select from currently posted positions</small>
                </div>

                {# No positions available message #}
                <div id="no-positions-message" class="alert alert-info full-width" style="display: none;">
                  <i class="fas fa-info-circle" aria-hidden="true"></i>
                  <span>No positions are currently available. Please check back later or <a href="/employment">view our careers page</a>.</span>
                </div>
              </div>

              {# Start date and salary - always visible regardless of job lock state #}
              <div class="form-grid" id="step2-additional-fields">
                <div class="form-group">
                  <label for="available_start_date" class="form-label required">
                    Earliest Available Start Date
                    <span class="visually-hidden">(required)</span>
                  </label>
                  <input type="date"
                         id="available_start_date"
                         name="available_start_date"
                         class="form-control"
                         required
                         aria-required="true"
                         aria-describedby="available_start_date_error"
                         min="{{ 'now'|date('Y-m-d') }}">
                  <div class="form-feedback" id="available_start_date_error" role="alert" aria-live="polite"></div>
                </div>

                <div class="form-group">
                  <label for="salary_requirements" class="form-label">Salary Requirements</label>
                  <input type="text"
                         id="salary_requirements"
                         name="salary_requirements"
                         class="form-control"
                         placeholder="e.g., $50,000 - $60,000 annually">
                  <small class="form-help">Optional</small>
                </div>
              </div>
            </div>
          </fieldset>

          {# Step 3: Application Questions #}
          <fieldset class="wizard-step" data-step="3" role="group" aria-labelledby="step3-heading" hidden>
            <div class="step-header">
              <h2 id="step3-heading">Application Questions</h2>
            </div>
            
            <div class="step-content">
              <div class="form-grid">
                
                {# Attorney-Specific Questions #}
                <div id="attorney-questions" class="attorney-specific-section" style="display: none;">
                  
                  <div class="form-group">
                    <label for="idaho_bar_licensed" class="form-label required">
                      Are you currently licensed to practice law in Idaho?
                      <span class="visually-hidden">(required)</span>
                    </label>
                    <select id="idaho_bar_licensed" 
                            name="idaho_bar_licensed" 
                            class="form-control" 
                            required
                            aria-required="true">
                      <option value="">Please select</option>
                      <option value="yes">Yes</option>
                      <option value="no">No</option>
                      <option value="licensed_other_state">Licensed in Another State</option>
                    </select>
                  </div>

                  <div class="form-group">
                    <label for="aba_law_school" class="form-label required">
                      Have you graduated from an ABA-accredited law school?
                      <span class="visually-hidden">(required)</span>
                    </label>
                    <select id="aba_law_school" 
                            name="aba_law_school" 
                            class="form-control" 
                            required
                            aria-required="true">
                      <option value="">Please select</option>
                      <option value="yes">Yes</option>
                      <option value="no">No</option>
                    </select>
                  </div>

                  <div class="form-group">
                    <label for="bar_discipline" class="form-label required">
                      Have you ever been subject to discipline by any state bar association?
                      <span class="visually-hidden">(required)</span>
                    </label>
                    <select id="bar_discipline" 
                            name="bar_discipline" 
                            class="form-control" 
                            required
                            aria-required="true">
                      <option value="">Please select</option>
                      <option value="yes">Yes</option>
                      <option value="no">No</option>
                    </select>
                  </div>

                </div>

                {# Universal Questions for All Positions #}
                <div class="universal-questions-section">

                  {# Sensitive Background Section #}
                  <div class="sensitive-questions-section">
                    <p class="sensitive-questions-intro">We have a few questions we ask applicants due to the sensitive nature of some of our legal work.</p>
                    
                    <div class="form-group">
                      <label for="criminal_conviction" class="form-label required">
                        Have you ever been charged with or convicted of a misdemeanor or felony related to domestic violence or other violent crime(s)?
                        <span class="visually-hidden">(required)</span>
                      </label>
                      <select id="criminal_conviction" 
                              name="criminal_conviction" 
                              class="form-control" 
                              required
                              aria-required="true">
                        <option value="">Please select</option>
                        <option value="yes">Yes</option>
                        <option value="no">No</option>
                      </select>
                    </div>

                    <div class="form-group">
                      <label for="protection_order" class="form-label required">
                        Have you ever been the subject of a civil protection order or restraining order?
                        <span class="visually-hidden">(required)</span>
                      </label>
                      <select id="protection_order" 
                              name="protection_order" 
                              class="form-control" 
                              required
                              aria-required="true">
                        <option value="">Please select</option>
                        <option value="yes">Yes</option>
                        <option value="no">No</option>
                      </select>
                    </div>

                    <div class="form-group">
                      <label for="sexual_harassment" class="form-label required">
                        Have you ever been found by an employer to have engaged in sexual harassment?
                        <span class="visually-hidden">(required)</span>
                      </label>
                      <select id="sexual_harassment" 
                              name="sexual_harassment" 
                              class="form-control" 
                              required
                              aria-required="true">
                        <option value="">Please select</option>
                        <option value="yes">Yes</option>
                        <option value="no">No</option>
                      </select>
                    </div>

                  </div>
                </div>
              </div>
            </div>
          </fieldset>

          {# Step 4: Documents #}
          <fieldset class="wizard-step" data-step="4" role="group" aria-labelledby="step4-heading" hidden>
            <div class="step-header">
              <h2 id="step4-heading">Upload your supporting documents</h2>
            </div>
            
            <div class="step-content">
              <div class="document-upload-section">
                
                {# Resume and Cover Letter on same row #}
                <div class="upload-row">
                  <div class="upload-group required-doc">
                    <label class="upload-label required" for="resume">
                      Resume/CV
                      <span class="visually-hidden">(required)</span>
                    </label>
                    <div class="file-upload-area" data-field="resume" role="region" aria-label="Resume upload area">
                      <div class="upload-placeholder">
                        <i class="fas fa-cloud-upload-alt" aria-hidden="true"></i>
                        <h4>Drop your resume here or click to browse</h4>
                        <p>PDF, DOC, or DOCX • Max 5MB</p>
                      </div>
                      <input type="file" 
                             id="resume" 
                             name="resume" 
                             accept=".pdf,.doc,.docx" 
                             class="file-input" 
                             required
                             aria-required="true"
                             aria-describedby="resume_error">
                      <div class="upload-progress" style="display: none;" role="status" aria-live="polite">
                        <div class="progress-bar"></div>
                        <span class="progress-text">Uploading...</span>
                      </div>
                      <div class="file-preview" style="display: none;">
                        <div class="file-info">
                          <i class="fas fa-file-alt" aria-hidden="true"></i>
                          <span class="file-name"></span>
                          <span class="file-size"></span>
                        </div>
                        <button type="button" class="remove-file" aria-label="Remove file">
                          <i class="fas fa-times" aria-hidden="true"></i>
                        </button>
                      </div>
                      <div class="form-feedback" id="resume_error" role="alert" aria-live="polite"></div>
                    </div>
                  </div>

                  <div class="upload-group">
                    <label class="upload-label" for="cover_letter">Cover Letter</label>
                    <div class="file-upload-area" data-field="cover_letter" role="region" aria-label="Cover letter upload area">
                      <div class="upload-placeholder">
                        <i class="fas fa-cloud-upload-alt" aria-hidden="true"></i>
                        <h4>Drop your cover letter here or click to browse</h4>
                        <p>PDF, DOC, or DOCX • Max 5MB</p>
                      </div>
                      <input type="file" 
                             id="cover_letter" 
                             name="cover_letter" 
                             accept=".pdf,.doc,.docx" 
                             class="file-input"
                             aria-describedby="cover_letter_help">
                      <div class="upload-progress" style="display: none;" role="status" aria-live="polite">
                        <div class="progress-bar"></div>
                        <span class="progress-text">Uploading...</span>
                      </div>
                      <div class="file-preview" style="display: none;">
                        <div class="file-info">
                          <i class="fas fa-file-alt" aria-hidden="true"></i>
                          <span class="file-name"></span>
                          <span class="file-size"></span>
                        </div>
                        <button type="button" class="remove-file" aria-label="Remove file">
                          <i class="fas fa-times" aria-hidden="true"></i>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>

                {# Additional Documents full width underneath #}
                <div class="upload-group">
                  <label class="upload-label" for="additional_documents">Additional Documents</label>
                  <div class="file-upload-area" data-field="additional_documents" role="region" aria-label="Additional documents upload area">
                    <div class="upload-placeholder">
                      <i class="fas fa-cloud-upload-alt" aria-hidden="true"></i>
                      <h4>Drop additional documents here or click to browse</h4>
                      <p>Certifications, Writing Samples, Portfolio • PDF, DOC, DOCX • Max 5MB each</p>
                    </div>
                    <input type="file" 
                           id="additional_documents" 
                           name="additional_documents[]" 
                           accept=".pdf,.doc,.docx" 
                           class="file-input" 
                           multiple
                           aria-describedby="additional_documents_help">
                    <div class="upload-progress" style="display: none;" role="status" aria-live="polite">
                      <div class="progress-bar"></div>
                      <span class="progress-text">Uploading...</span>
                    </div>
                    <div class="file-preview" style="display: none;">
                      <div class="file-info">
                        <i class="fas fa-file-alt" aria-hidden="true"></i>
                        <span class="file-name"></span>
                        <span class="file-size"></span>
                      </div>
                      <button type="button" class="remove-file" aria-label="Remove file">
                        <i class="fas fa-times" aria-hidden="true"></i>
                      </button>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </fieldset>

          {# Step 5: Additional Information & Review #}
          <fieldset class="wizard-step" data-step="5" role="group" aria-labelledby="step5-heading" hidden>
            <div class="step-header">
              <h2 id="step5-heading">Additional Information & Review</h2>
            </div>
            
            <div class="step-content">
              <div class="form-grid">
                
                <div class="form-group">
                  <label for="referral_source" class="form-label">How did you hear about us?</label>
                  <select id="referral_source" 
                          name="referral_source" 
                          class="form-control">
                    <option value="">Please select</option>
                    <option value="company_website">Company Website</option>
                    <option value="job_board">Job Board</option>
                    <option value="social_media">Social Media</option>
                    <option value="employee_referral">Employee Referral</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                
                <div class="form-group referral-details" style="display: none;">
                  <label for="referral_details" class="form-label">Please provide details</label>
                  <input type="text" 
                         id="referral_details" 
                         name="referral_details" 
                         class="form-control">
                </div>
                
                <div class="form-group full-width">
                  <label for="additional_comments" class="form-label">Additional Comments</label>
                  <textarea id="additional_comments" 
                            name="additional_comments" 
                            class="form-control auto-resize" 
                            rows="4"
                            placeholder="Share anything else you'd like us to know about your application..."></textarea>
                </div>

                {# Accommodation Request (ADA/Section 503) #}
                <div class="form-group full-width">
                  <div class="accommodation-notice">
                    <p class="accommodation-notice__text">
                      Idaho Legal Aid Services is committed to providing reasonable accommodations to qualified individuals with disabilities.
                      If you need an accommodation to complete this application or participate in the interview process, please describe your request below.
                    </p>
                    <label for="accommodation_request" class="form-label">Accommodation Request <span class="optional-label">(optional)</span></label>
                    <textarea id="accommodation_request"
                              name="accommodation_request"
                              class="form-control auto-resize"
                              rows="3"
                              placeholder="Describe any accommodations you may need..."></textarea>
                  </div>
                </div>

                {# EEO Statement #}
                <div class="form-group full-width">
                  <div class="eeo-statement">
                    <p class="eeo-statement__text">
                      Idaho Legal Aid Services is an Equal Opportunity Employer. We do not discriminate on the basis of race, color, religion, sex, national origin, age, disability, genetic information, veteran status, sexual orientation, gender identity, or any other legally protected characteristic.
                    </p>
                  </div>
                </div>

                {# Privacy Notice #}
                <div class="form-group full-width">
                  <div class="privacy-notice">
                    <p class="privacy-notice__text">
                      The personal information you provide in this application will be used solely for the purpose of evaluating your candidacy for employment.
                      Your data will be stored securely and retained in accordance with our data retention policies.
                      For more information about how we collect, use, and protect your personal data, please review our <a href="/privacy-policy" target="_blank" rel="noopener">Privacy Policy</a>.
                    </p>
                  </div>
                </div>

                <div class="form-group full-width">
                  <fieldset class="application-agreements" role="group" aria-labelledby="agreements-heading">
                    <legend id="agreements-heading" class="visually-hidden">Application Agreements</legend>

                    <div class="agreement-item">
                      <label class="checkbox-label">
                        <input type="checkbox"
                               id="agreement"
                               name="agreement"
                               required
                               aria-required="true"
                               aria-describedby="agreement_error"
                               value="1">
                        <span class="checkmark"></span>
                        I certify that the information provided in this application is true and complete to the best of my knowledge.
                      </label>
                      <div class="form-feedback" id="agreement_error" role="alert" aria-live="polite"></div>
                    </div>
                  </fieldset>
                </div>

              </div>
            </div>
          </fieldset>

          {# Navigation Controls #}
          <nav class="wizard-navigation" role="navigation" aria-label="Form navigation">
            <div class="nav-left">
              <button type="button" 
                      class="btn btn-primary btn-prev" 
                      style="display: none;"
                      aria-label="Go to previous step">
                <i class="fas fa-arrow-left" aria-hidden="true"></i> Previous
              </button>
            </div>
            
            <div class="nav-center">
              <div class="step-indicator" aria-live="polite" aria-atomic="true">
                Step <span class="current-step">1</span> of <span class="total-steps">5</span>
              </div>
            </div>
            
            <div class="nav-right">
              <button type="button" 
                      class="btn btn-primary btn-next"
                      aria-label="Go to next step">
                Next <i class="fas fa-arrow-right" aria-hidden="true"></i>
              </button>
              <button type="submit" 
                      class="btn btn-success btn-submit" 
                      style="display: none;"
                      aria-label="Submit application">
                <i class="fas fa-paper-plane" aria-hidden="true"></i> Submit Application
              </button>
            </div>
          </nav>

        </div>

        {# Auto-save Indicator #}
        <div class="auto-save-status" role="status" aria-live="polite" aria-atomic="true">
          <i class="fas fa-check-circle" aria-hidden="true"></i>
          <span class="save-text">All changes saved</span>
        </div>

        {# Save & Resume Later #}
        <div class="save-resume-section">
          <button type="button" class="btn btn-outline-secondary btn-save-resume" aria-expanded="false" aria-controls="save-resume-form">
            <i class="fas fa-envelope" aria-hidden="true"></i> Save &amp; Resume Later
          </button>
          <div id="save-resume-form" class="save-resume-form" style="display: none;" role="region" aria-label="Save and resume later">
            <p class="save-resume-description">Enter your email and we'll send you a link to resume this application from any device. The link expires in 7 days.</p>
            <div class="save-resume-input-group">
              <label for="save-resume-email" class="visually-hidden">Email address for resume link</label>
              <input type="email"
                     id="save-resume-email"
                     class="form-control"
                     placeholder="Your email address"
                     autocomplete="email"
                     required
                     aria-describedby="save-resume-help">
              <button type="button" class="btn btn-primary btn-send-resume-link">
                <i class="fas fa-paper-plane" aria-hidden="true"></i> Send Link
              </button>
            </div>
            <small id="save-resume-help" class="form-text text-muted">We'll only use this email to send your resume link.</small>
            <div class="save-resume-status" role="status" aria-live="polite"></div>
          </div>
        </div>

      </div>
    </form>

    {# Success Modal #}
    <div class="application-success-modal" 
         style="display: none;" 
         role="dialog" 
         aria-modal="true"
         aria-labelledby="success-title"
         aria-describedby="success-message">
      <div class="modal-content">
        <div class="success-icon">
          <i class="fas fa-check-circle" aria-hidden="true"></i>
        </div>
        <h2 id="success-title">Application Submitted Successfully!</h2>
        <p id="success-message">Thank you for your interest in joining our team. We've received your application and will review it carefully.</p>
        <div class="next-steps">
          <h3>What happens next?</h3>
          <ul>
            <li>We'll acknowledge receipt of your application within 24 hours</li>
            <li>Our team will review your qualifications</li>
            <li>If you're a good fit, we'll contact you within 1-2 weeks for next steps</li>
          </ul>
        </div>
        <div class="modal-actions">
          <a href="/employment" class="btn btn-primary back-button">
            <i class="fas fa-arrow-left" aria-hidden="true"></i>
            <span>{{ 'Back to Employment'|t }}</span>
          </a>
          <a href="/" class="btn btn-outline-secondary">Return Home</a>
        </div>
      </div>
    </div>

    {% endif %}

  </div>

</article>
