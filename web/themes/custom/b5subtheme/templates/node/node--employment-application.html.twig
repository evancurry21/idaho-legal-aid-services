{#
/**
 * @file
 * Premium Employment Application - Multi-Step Wizard
 * Accessible, secure, and user-friendly employment application
 * Properly integrated with Drupal 11 webform system
 */
#}

{{ attach_library('b5subtheme/premium-application') }}

<article{{ attributes.addClass('node', 'node--type-' ~ node.bundle|clean_class, 'premium-application-page', 'hide-page-title') }}>

  <div{{ content_attributes.addClass('node__content') }}>
    
    {# Skip Link for Accessibility #}
    <a href="#application-form" class="visually-hidden-focusable">Skip to application form</a>
    
    {# Application Header #}
    <header class="application-header" role="banner">
      <div class="application-header-content">
        <h1 class="application-title">Join Our Mission</h1>
        <p class="application-subtitle">Help us provide essential legal services to our community</p>
        <div class="application-meta">
          <span class="completion-time">
            <i class="fas fa-clock" aria-hidden="true"></i> 
            <span class="visually-hidden">Estimated time:</span> Takes 5-8 minutes
          </span>
          <span class="auto-save-notice">
            <i class="fas fa-save" aria-hidden="true"></i> 
            <span class="visually-hidden">Feature:</span> Progress automatically saved
          </span>
        </div>
      </div>
    </header>

    {# Application Form - Proper Drupal Integration #}
    <form id="application-form" 
          class="application-wizard" 
          action="/webform/employment_application" 
          method="post" 
          enctype="multipart/form-data"
          novalidate
          aria-label="Employment Application Form"
          data-drupal-webform-id="employment_application">
      
      {# CSRF Token - Will be populated by JavaScript #}
      <input type="hidden" name="form_token" id="form-token" value="">
      <input type="hidden" name="form_id" value="webform_submission_employment_application_form">
      <input type="hidden" name="form_build_id" id="form-build-id" value="">
      <input type="hidden" name="op" value="Submit">
      
      <div class="container">
        
        {# Progress Indicator #}
        <nav class="wizard-progress" role="navigation" aria-label="Application progress">
          <div class="progress-container">
            <div class="progress-bar-bg" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
              <div class="progress-bar-fill" data-progress="0"></div>
            </div>
            <ol class="progress-steps">
              <li class="step active" data-step="1" aria-current="step">
                <button type="button" class="step-button" aria-label="Step 1: Personal Info">
                  <span class="step-circle">1</span>
                  <span class="step-label">Personal Info</span>
                </button>
              </li>
              <li class="step" data-step="2">
                <button type="button" class="step-button" aria-label="Step 2: Position Details">
                  <span class="step-circle">2</span>
                  <span class="step-label">Position Details</span>
                </button>
              </li>
              <li class="step" data-step="3">
                <button type="button" class="step-button" aria-label="Step 3: Experience">
                  <span class="step-circle">3</span>
                  <span class="step-label">Experience</span>
                </button>
              </li>
              <li class="step" data-step="4">
                <button type="button" class="step-button" aria-label="Step 4: Documents">
                  <span class="step-circle">4</span>
                  <span class="step-label">Documents</span>
                </button>
              </li>
              <li class="step" data-step="5">
                <button type="button" class="step-button" aria-label="Step 5: Review">
                  <span class="step-circle">5</span>
                  <span class="step-label">Review</span>
                </button>
              </li>
            </ol>
          </div>
        </nav>

        {# Main Application Form Content #}
        <div class="wizard-content">
          
          {# Step 1: Personal Information #}
          <fieldset class="wizard-step active" data-step="1" role="group" aria-labelledby="step1-heading">
            <div class="step-header">
              <h2 id="step1-heading">Let's start with your basic information</h2>
              <p>We'll use this to contact you about your application</p>
            </div>
            
            <div class="step-content">
              <div class="form-grid">
                <div class="form-group">
                  <label for="full_name" class="form-label required">
                    Full Name
                    <span class="visually-hidden">(required)</span>
                  </label>
                  <input type="text" 
                         id="full_name" 
                         name="full_name" 
                         class="form-control" 
                         required
                         aria-required="true"
                         aria-describedby="full_name_error"
                         data-validate="minLength:2,maxLength:100"
                         autocomplete="name">
                  <div class="form-feedback" id="full_name_error" role="alert" aria-live="polite"></div>
                </div>
                
                <div class="form-group">
                  <label for="email" class="form-label required">
                    Email Address
                    <span class="visually-hidden">(required)</span>
                  </label>
                  <input type="email" 
                         id="email" 
                         name="email" 
                         class="form-control" 
                         required
                         aria-required="true"
                         aria-describedby="email_error email_help"
                         data-validate="email"
                         autocomplete="email">
                  <div class="form-feedback" id="email_error" role="alert" aria-live="polite"></div>
                  <small id="email_help" class="form-help">We'll send updates about your application to this email</small>
                </div>
                
                <div class="form-group">
                  <label for="phone" class="form-label required">
                    Phone Number
                    <span class="visually-hidden">(required)</span>
                  </label>
                  <input type="tel" 
                         id="phone" 
                         name="phone" 
                         class="form-control" 
                         required
                         aria-required="true"
                         aria-describedby="phone_error"
                         data-validate="phone"
                         autocomplete="tel"
                         placeholder="(555) 123-4567">
                  <div class="form-feedback" id="phone_error" role="alert" aria-live="polite"></div>
                </div>
                
                <div class="form-group full-width">
                  <fieldset>
                    <legend class="form-label required">Address</legend>
                    <div class="address-grid">
                      <div class="form-group">
                        <label for="address_address" class="form-label">Street Address</label>
                        <input type="text" 
                               id="address_address" 
                               name="address[address]" 
                               class="form-control"
                               autocomplete="street-address">
                      </div>
                      <div class="form-group">
                        <label for="address_city" class="form-label">City</label>
                        <input type="text" 
                               id="address_city" 
                               name="address[city]" 
                               class="form-control"
                               autocomplete="address-level2">
                      </div>
                      <div class="form-group">
                        <label for="address_state_province" class="form-label">State</label>
                        <select id="address_state_province" 
                                name="address[state_province]" 
                                class="form-control"
                                autocomplete="address-level1">
                          <option value="">Select State</option>
                          <option value="ID">Idaho</option>
                          <option value="WA">Washington</option>
                          <option value="OR">Oregon</option>
                          <option value="MT">Montana</option>
                          <option value="UT">Utah</option>
                        </select>
                      </div>
                      <div class="form-group">
                        <label for="address_postal_code" class="form-label">ZIP Code</label>
                        <input type="text" 
                               id="address_postal_code" 
                               name="address[postal_code]" 
                               class="form-control"
                               autocomplete="postal-code">
                      </div>
                    </div>
                  </fieldset>
                </div>
              </div>
            </div>
          </fieldset>

          {# Step 2: Position Information #}
          <fieldset class="wizard-step" data-step="2" role="group" aria-labelledby="step2-heading" hidden>
            <div class="step-header">
              <h2 id="step2-heading">Tell us about the position you're interested in</h2>
              <p>Help us understand your career goals and availability</p>
            </div>
            
            <div class="step-content">
              <div class="form-grid">
                <div class="form-group full-width">
                  <label for="position_applied" class="form-label required">
                    Position Applied For
                    <span class="visually-hidden">(required)</span>
                  </label>
                  <select id="position_applied" 
                          name="position_applied" 
                          class="form-control" 
                          required
                          aria-required="true"
                          aria-describedby="position_applied_error">
                    <option value="">Select a position</option>
                    <option value="managing_attorney">Managing Attorney</option>
                    <option value="staff_attorney">Staff Attorney</option>
                    <option value="paralegal">Paralegal</option>
                    <option value="legal_assistant">Legal Assistant</option>
                    <option value="administrative">Administrative Support</option>
                    <option value="outreach">Community Outreach</option>
                    <option value="other">Other (please specify)</option>
                  </select>
                  <div class="form-feedback" id="position_applied_error" role="alert" aria-live="polite"></div>
                </div>
                
                <div class="form-group other-position" style="display: none;" aria-hidden="true">
                  <label for="position_other" class="form-label">Please specify position</label>
                  <input type="text" 
                         id="position_other" 
                         name="position_other" 
                         class="form-control"
                         aria-describedby="position_other_error">
                  <div class="form-feedback" id="position_other_error" role="alert" aria-live="polite"></div>
                </div>
                
                <div class="form-group">
                  <label for="available_start_date" class="form-label required">
                    Earliest Available Start Date
                    <span class="visually-hidden">(required)</span>
                  </label>
                  <input type="date" 
                         id="available_start_date" 
                         name="available_start_date" 
                         class="form-control"
                         required
                         aria-required="true"
                         aria-describedby="available_start_date_error"
                         min="{{ 'now'|date('Y-m-d') }}">
                  <div class="form-feedback" id="available_start_date_error" role="alert" aria-live="polite"></div>
                </div>
                
                <div class="form-group">
                  <label for="salary_requirements" class="form-label">Salary Requirements</label>
                  <input type="text" 
                         id="salary_requirements" 
                         name="salary_requirements" 
                         class="form-control"
                         placeholder="e.g., $50,000 - $60,000 annually">
                  <small class="form-help">Optional - We believe in fair compensation for all positions</small>
                </div>
              </div>
            </div>
          </fieldset>

          {# Step 3: Experience & Education #}
          <fieldset class="wizard-step" data-step="3" role="group" aria-labelledby="step3-heading" hidden>
            <div class="step-header">
              <h2 id="step3-heading">Share your experience and qualifications</h2>
              <p>Tell us about your background and what you bring to our team</p>
            </div>
            
            <div class="step-content">
              <div class="form-grid">
                
                {# Work Experience Section #}
                <div class="form-group full-width">
                  <fieldset class="multiple-items-section">
                    <legend class="form-label">Work Experience</legend>
                    <div id="work-experience-container" class="multiple-items-container">
                      <div class="multiple-item" data-item="0">
                        <div class="item-header">
                          <h4>Work Experience #1</h4>
                          <button type="button" class="remove-item" aria-label="Remove this work experience" style="display: none;">×</button>
                        </div>
                        <div class="item-content">
                          <div class="form-row">
                            <div class="form-group">
                              <label for="work_experience_0_employer" class="form-label required">Employer</label>
                              <input type="text" 
                                     id="work_experience_0_employer" 
                                     name="work_experience[0][employer]" 
                                     class="form-control" 
                                     required
                                     aria-required="true">
                            </div>
                            <div class="form-group">
                              <label for="work_experience_0_job_title" class="form-label required">Job Title</label>
                              <input type="text" 
                                     id="work_experience_0_job_title" 
                                     name="work_experience[0][job_title]" 
                                     class="form-control" 
                                     required
                                     aria-required="true">
                            </div>
                          </div>
                          <div class="form-row">
                            <div class="form-group">
                              <label for="work_experience_0_start_date" class="form-label required">Start Date</label>
                              <input type="date" 
                                     id="work_experience_0_start_date" 
                                     name="work_experience[0][start_date]" 
                                     class="form-control" 
                                     required
                                     aria-required="true">
                            </div>
                            <div class="form-group">
                              <label for="work_experience_0_end_date" class="form-label">End Date</label>
                              <input type="date" 
                                     id="work_experience_0_end_date" 
                                     name="work_experience[0][end_date]" 
                                     class="form-control">
                            </div>
                          </div>
                          <div class="form-group">
                            <label class="checkbox-label">
                              <input type="checkbox" 
                                     id="work_experience_0_current_position" 
                                     name="work_experience[0][current_position]"
                                     value="1">
                              <span class="checkmark"></span>
                              I currently work here
                            </label>
                          </div>
                          <div class="form-group">
                            <label for="work_experience_0_responsibilities" class="form-label">Key Responsibilities</label>
                            <textarea id="work_experience_0_responsibilities" 
                                      name="work_experience[0][responsibilities]" 
                                      class="form-control auto-resize" 
                                      rows="3"></textarea>
                          </div>
                        </div>
                      </div>
                    </div>
                    <button type="button" id="add-work-experience" class="btn btn-outline-primary">
                      <i class="fas fa-plus" aria-hidden="true"></i> Add Another Work Experience
                    </button>
                  </fieldset>
                </div>

                {# Education Section #}
                <div class="form-group full-width">
                  <fieldset class="multiple-items-section">
                    <legend class="form-label">Education</legend>
                    <div id="education-container" class="multiple-items-container">
                      <div class="multiple-item" data-item="0">
                        <div class="item-header">
                          <h4>Education #1</h4>
                          <button type="button" class="remove-item" aria-label="Remove this education entry" style="display: none;">×</button>
                        </div>
                        <div class="item-content">
                          <div class="form-row">
                            <div class="form-group">
                              <label for="education_0_institution" class="form-label">Institution</label>
                              <input type="text" 
                                     id="education_0_institution" 
                                     name="education[0][institution]" 
                                     class="form-control">
                            </div>
                            <div class="form-group">
                              <label for="education_0_degree" class="form-label">Degree/Certificate</label>
                              <input type="text" 
                                     id="education_0_degree" 
                                     name="education[0][degree]" 
                                     class="form-control">
                            </div>
                          </div>
                          <div class="form-group">
                            <label for="education_0_graduation_date" class="form-label">Graduation Date</label>
                            <input type="date" 
                                   id="education_0_graduation_date" 
                                   name="education[0][graduation_date]" 
                                   class="form-control">
                          </div>
                        </div>
                      </div>
                    </div>
                    <button type="button" id="add-education" class="btn btn-outline-primary">
                      <i class="fas fa-plus" aria-hidden="true"></i> Add Another Education Entry
                    </button>
                  </fieldset>
                </div>
              </div>
            </div>
          </fieldset>

          {# Step 4: Documents #}
          <fieldset class="wizard-step" data-step="4" role="group" aria-labelledby="step4-heading" hidden>
            <div class="step-header">
              <h2 id="step4-heading">Upload your supporting documents</h2>
              <p>Share your resume and any additional documents that showcase your qualifications</p>
            </div>
            
            <div class="step-content">
              <div class="document-upload-section">
                
                <div class="upload-group required-doc">
                  <label class="upload-label required" for="resume">
                    Resume/CV
                    <span class="visually-hidden">(required)</span>
                  </label>
                  <div class="file-upload-area" data-field="resume" role="region" aria-label="Resume upload area">
                    <div class="upload-placeholder">
                      <i class="fas fa-cloud-upload-alt" aria-hidden="true"></i>
                      <h4>Drop your resume here or click to browse</h4>
                      <p>PDF, DOC, or DOCX • Max 5MB</p>
                    </div>
                    <input type="file" 
                           id="resume" 
                           name="resume" 
                           accept=".pdf,.doc,.docx" 
                           class="file-input" 
                           required
                           aria-required="true"
                           aria-describedby="resume_error">
                    <div class="upload-progress" style="display: none;" role="status" aria-live="polite">
                      <div class="progress-bar"></div>
                      <span class="progress-text">Uploading...</span>
                    </div>
                    <div class="file-preview" style="display: none;">
                      <div class="file-info">
                        <i class="fas fa-file-alt" aria-hidden="true"></i>
                        <span class="file-name"></span>
                        <span class="file-size"></span>
                      </div>
                      <button type="button" class="remove-file" aria-label="Remove file">
                        <i class="fas fa-times" aria-hidden="true"></i>
                      </button>
                    </div>
                    <div class="form-feedback" id="resume_error" role="alert" aria-live="polite"></div>
                  </div>
                </div>

                <div class="upload-group">
                  <label class="upload-label" for="cover_letter">Cover Letter</label>
                  <div class="file-upload-area" data-field="cover_letter" role="region" aria-label="Cover letter upload area">
                    <div class="upload-placeholder">
                      <i class="fas fa-cloud-upload-alt" aria-hidden="true"></i>
                      <h4>Drop your cover letter here or click to browse</h4>
                      <p>PDF, DOC, or DOCX • Max 5MB</p>
                    </div>
                    <input type="file" 
                           id="cover_letter" 
                           name="cover_letter" 
                           accept=".pdf,.doc,.docx" 
                           class="file-input"
                           aria-describedby="cover_letter_help">
                    <div class="upload-progress" style="display: none;" role="status" aria-live="polite">
                      <div class="progress-bar"></div>
                      <span class="progress-text">Uploading...</span>
                    </div>
                    <div class="file-preview" style="display: none;">
                      <div class="file-info">
                        <i class="fas fa-file-alt" aria-hidden="true"></i>
                        <span class="file-name"></span>
                        <span class="file-size"></span>
                      </div>
                      <button type="button" class="remove-file" aria-label="Remove file">
                        <i class="fas fa-times" aria-hidden="true"></i>
                      </button>
                    </div>
                    <small id="cover_letter_help" class="form-help">Optional but recommended</small>
                  </div>
                </div>

                <div class="upload-group">
                  <label class="upload-label" for="additional_documents">Additional Documents</label>
                  <div class="file-upload-area" data-field="additional_documents" role="region" aria-label="Additional documents upload area">
                    <div class="upload-placeholder">
                      <i class="fas fa-cloud-upload-alt" aria-hidden="true"></i>
                      <h4>Drop additional documents here or click to browse</h4>
                      <p>Certifications, writing samples, portfolio • PDF, DOC, DOCX • Max 5MB each</p>
                    </div>
                    <input type="file" 
                           id="additional_documents" 
                           name="additional_documents[]" 
                           accept=".pdf,.doc,.docx" 
                           class="file-input" 
                           multiple
                           aria-describedby="additional_documents_help">
                    <div class="upload-progress" style="display: none;" role="status" aria-live="polite">
                      <div class="progress-bar"></div>
                      <span class="progress-text">Uploading...</span>
                    </div>
                    <div class="file-preview" style="display: none;">
                      <div class="file-info">
                        <i class="fas fa-file-alt" aria-hidden="true"></i>
                        <span class="file-name"></span>
                        <span class="file-size"></span>
                      </div>
                      <button type="button" class="remove-file" aria-label="Remove file">
                        <i class="fas fa-times" aria-hidden="true"></i>
                      </button>
                    </div>
                    <small id="additional_documents_help" class="form-help">Upload any additional supporting documents</small>
                  </div>
                </div>

              </div>
            </div>
          </fieldset>

          {# Step 5: Additional Information & Review #}
          <fieldset class="wizard-step" data-step="5" role="group" aria-labelledby="step5-heading" hidden>
            <div class="step-header">
              <h2 id="step5-heading">Additional Information & Review</h2>
              <p>Final details and review of your application</p>
            </div>
            
            <div class="step-content">
              <div class="form-grid">
                
                <div class="form-group">
                  <label for="referral_source" class="form-label">How did you hear about us?</label>
                  <select id="referral_source" 
                          name="referral_source" 
                          class="form-control">
                    <option value="">Please select</option>
                    <option value="company_website">Company Website</option>
                    <option value="job_board">Job Board</option>
                    <option value="social_media">Social Media</option>
                    <option value="employee_referral">Employee Referral</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                
                <div class="form-group referral-details" style="display: none;">
                  <label for="referral_details" class="form-label">Please provide details</label>
                  <input type="text" 
                         id="referral_details" 
                         name="referral_details" 
                         class="form-control">
                </div>
                
                <div class="form-group full-width">
                  <label for="additional_comments" class="form-label">Additional Comments</label>
                  <textarea id="additional_comments" 
                            name="additional_comments" 
                            class="form-control auto-resize" 
                            rows="4"
                            placeholder="Share anything else you'd like us to know about your application..."></textarea>
                </div>

                <fieldset class="application-agreements" role="group" aria-labelledby="agreements-heading">
                  <legend id="agreements-heading" class="visually-hidden">Application Agreements</legend>
                  
                  <div class="agreement-item">
                    <label class="checkbox-label">
                      <input type="checkbox" 
                             id="agreement" 
                             name="agreement" 
                             required
                             aria-required="true"
                             aria-describedby="agreement_error"
                             value="1">
                      <span class="checkmark"></span>
                      I certify that the information provided in this application is true and complete to the best of my knowledge.
                    </label>
                    <div class="form-feedback" id="agreement_error" role="alert" aria-live="polite"></div>
                  </div>
                </fieldset>

              </div>
            </div>
          </fieldset>

          {# Navigation Controls #}
          <nav class="wizard-navigation" role="navigation" aria-label="Form navigation">
            <div class="nav-left">
              <button type="button" 
                      class="btn btn-outline-secondary btn-prev" 
                      style="display: none;"
                      aria-label="Go to previous step">
                Previous
              </button>
            </div>
            
            <div class="nav-center">
              <div class="step-indicator" aria-live="polite" aria-atomic="true">
                Step <span class="current-step">1</span> of <span class="total-steps">5</span>
              </div>
            </div>
            
            <div class="nav-right">
              <button type="button" 
                      class="btn btn-primary btn-next"
                      aria-label="Go to next step">
                Next
              </button>
              <button type="submit" 
                      class="btn btn-success btn-submit" 
                      style="display: none;"
                      aria-label="Submit application">
                <i class="fas fa-paper-plane" aria-hidden="true"></i> Submit Application
              </button>
            </div>
          </nav>

        </div>

        {# Auto-save Indicator #}
        <div class="auto-save-status" role="status" aria-live="polite" aria-atomic="true">
          <i class="fas fa-check-circle" aria-hidden="true"></i>
          <span class="save-text">All changes saved</span>
        </div>

      </div>
    </form>

    {# Success Modal #}
    <div class="application-success-modal" 
         style="display: none;" 
         role="dialog" 
         aria-modal="true"
         aria-labelledby="success-title"
         aria-describedby="success-message">
      <div class="modal-content">
        <div class="success-icon">
          <i class="fas fa-check-circle" aria-hidden="true"></i>
        </div>
        <h2 id="success-title">Application Submitted Successfully!</h2>
        <p id="success-message">Thank you for your interest in joining our team. We've received your application and will review it carefully.</p>
        <div class="next-steps">
          <h3>What happens next?</h3>
          <ul>
            <li>We'll acknowledge receipt of your application within 24 hours</li>
            <li>Our team will review your qualifications</li>
            <li>If you're a good fit, we'll contact you within 1-2 weeks for next steps</li>
          </ul>
        </div>
        <div class="modal-actions">
          <a href="/employment" class="btn btn-primary">Back to Employment</a>
          <a href="/" class="btn btn-outline-secondary">Return Home</a>
        </div>
      </div>
    </div>

  </div>

</article>