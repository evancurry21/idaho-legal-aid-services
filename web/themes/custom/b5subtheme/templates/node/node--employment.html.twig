{#
/**
 * @file
 * Template for Employment content type (redesigned).
 *
 * Uses standard page layout with curved header and footer.
 * Includes JobPosting schema for Google Jobs rich results.
 *
 * Sections:
 * 1. Intro / Content Body
 * 2. Quick Facts
 * 3. Current Openings (Job Listings)
 * 4. Content Sections (For Attorneys, Support Staff, Why ILAS, etc.)
 * 5. Benefits Snapshot
 * 6. EEO Statement
 *
 * Available variables:
 * - content: Rendered content fields
 * - attributes: HTML attributes for the article element
 * - node: The node entity
 */
#}

{{ attach_library('b5subtheme/sticky-jobs-bar') }}

{# JobPosting JSON-LD is owned by ilas_seo's GraphBuilder service
   (web/modules/custom/ilas_seo/src/StructuredData/GraphBuilder.php) and
   emitted from ilas_seo_page_attachments(). Do not add a <script> block
   here — schema generation belongs in PHP, not Twig. #}

{# ========== Main Article ========== #}
<article{{ attributes.addClass('node', 'node--employment', 'employment-page') }}>
  <div class="container">

    {# ===== 1. INTRO SECTION ===== #}
    <section class="employment-page__intro">
      {% if content.field_main_content %}
        <div class="content-body">
          {{ content.field_main_content }}
        </div>
      {% endif %}

      {# View Open Positions CTA - observed by sticky bar JS #}
      <div class="employment-page__intro-cta text-center" id="intro-cta-trigger">
        <a href="#current-openings" class="btn btn-primary btn-lg">
          View Open Positions
          <i class="fas fa-arrow-down ms-2" aria-hidden="true"></i>
        </a>
      </div>
    </section>

  </div>{# End container for intro #}

  {# ===== 2. QUICK FACTS SECTION (full-bleed with curved gray background) ===== #}
  {% if content.field_quick_facts|render|trim %}
    <section class="employment-page__quick-facts-section">
      <div class="container">
        <h2 class="section-heading text-center">Statewide Reach. Local Impact.</h2>
        <div class="quick-facts-grid">
          {{ content.field_quick_facts }}
        </div>
      </div>
    </section>
  {% endif %}

  <div class="container">
    {# ===== 3. CURRENT OPENINGS ===== #}
    {% if content.field_job_listings|render|trim %}
      <section class="employment-page__listings" id="current-openings">
        {# Title #}
        {% if node.field_job_listings_title.value %}
          <h2 class="section-title text-center">{{ node.field_job_listings_title.value }}</h2>
        {% endif %}

        {# Jump Links Navigation #}
        {# Job category pills (filled) + "Our Hiring Process" (outline) with CSS separator #}
        {% if node.field_job_listings|length > 0 %}
        <nav class="employment-page__jump-nav" aria-label="Job categories">
          <ul class="jump-nav-list">
            {% for category in node.field_job_listings %}
              {% if category.entity %}
                {% set cat_id = category.entity.field_category_id.value %}
                {% set cat_name = category.entity.field_category_name.value %}
                {# Check if this is the hiring process section (not a job category) #}
                {% set is_hiring_process = cat_id == 'hiring-process' or cat_id == 'our-hiring-process' or cat_name|lower matches '/hiring process/' %}
                {% if not is_hiring_process %}
                  <li>
                    <a href="#{{ cat_id }}" class="jump-nav-pill">
                      {{ cat_name }}
                    </a>
                  </li>
                {% endif %}
              {% endif %}
            {% endfor %}
          </ul>
          {# Separator + "Our Hiring Process" outline pill #}
          {% for category in node.field_job_listings %}
            {% if category.entity %}
              {% set cat_id = category.entity.field_category_id.value %}
              {% set cat_name = category.entity.field_category_name.value %}
              {% set is_hiring_process = cat_id == 'hiring-process' or cat_id == 'our-hiring-process' or cat_name|lower matches '/hiring process/' %}
              {% if is_hiring_process %}
                <span class="jump-nav-separator" aria-hidden="true"></span>
                <a href="#{{ cat_id }}" class="jump-nav-process-link">
                  {{ cat_name }}
                </a>
              {% endif %}
            {% endif %}
          {% endfor %}
        </nav>
        {% endif %}

        {# Job listings accordion #}
        {{ content.field_job_listings }}
      </section>
    {% endif %}

    {# ===== 4. CONTENT SECTIONS (Tabbed Interface) ===== #}
    {% if content_sections_tabs|length > 0 %}
      {{ attach_library('b5subtheme/content-tabs') }}
      <section class="employment-page__sections-tabbed" id="about-working-here">
        <h2 class="section-title text-center">About Working at ILAS</h2>

        {# Tab Navigation #}
        <nav class="content-tabs-nav" aria-label="Content sections">
          <ul class="nav nav-tabs content-tabs" id="contentSectionTabs" role="tablist">
            {% for section in content_sections_tabs %}
              <li class="nav-item" role="presentation">
                <button class="nav-link content-tab{% if section.is_first %} active{% endif %}"
                        id="tab-{{ section.id }}"
                        data-bs-toggle="tab"
                        data-bs-target="#panel-{{ section.id }}"
                        type="button"
                        role="tab"
                        aria-controls="panel-{{ section.id }}"
                        aria-selected="{{ section.is_first ? 'true' : 'false' }}">
                  <i class="fas {{ section.icon }} content-tab__icon" aria-hidden="true"></i>
                  <span class="content-tab__label">
                    <span class="content-tab__label-full">{{ section.tab_label }}</span>
                    <span class="content-tab__label-short">{{ section.tab_label_short }}</span>
                  </span>
                </button>
              </li>
            {% endfor %}
          </ul>
        </nav>

        {# Tab Panels #}
        <div class="tab-content content-tab-panels" id="contentSectionTabsContent">
          {% for section in content_sections_tabs %}
            <div class="tab-pane fade{% if section.is_first %} show active{% endif %} content-tab-panel"
                 id="panel-{{ section.id }}"
                 role="tabpanel"
                 aria-labelledby="tab-{{ section.id }}"
                 tabindex="0">

              <div class="content-section content-section--{{ section.style }}">
                <h3 class="content-section__title">{{ section.title }}</h3>
                <div class="content-section__body content-body">
                  {{ section.body }}
                </div>
              </div>

            </div>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {# ===== 5. BENEFITS SNAPSHOT ===== #}
    {% if content.field_benefits_snapshot|render|trim %}
      <section class="employment-page__benefits" id="benefits">
        <h2 class="section-title text-center">Benefits Snapshot</h2>

        {% if node.field_benefits_disclaimer.value %}
          <p class="benefits-disclaimer">
            {{ node.field_benefits_disclaimer.value }}
          </p>
        {% endif %}

        <div class="benefits-grid">
          {{ content.field_benefits_snapshot }}
        </div>
      </section>
    {% endif %}

    {# ===== 6. EEO STATEMENT ===== #}
    {% if content.field_eeo_statement|render|trim %}
      <section class="employment-page__eeo">
        <h2 class="section-title">Equal Opportunity Employer</h2>
        <div class="content-body">
          {{ content.field_eeo_statement }}
        </div>
      </section>
    {% endif %}

  </div>{# End container #}
</article>

{# ===== STICKY CTA BAR ===== #}
{# Appears when intro CTA scrolls out of view, hides when job listings are in view #}
<div class="sticky-jobs-bar" id="sticky-jobs-bar" aria-hidden="true">
  <div class="sticky-jobs-bar__content">
    <span class="sticky-jobs-bar__text">Ready to join our team?</span>
    <a href="#current-openings" class="sticky-jobs-bar__cta">
      View Open Positions
      <i class="fas fa-briefcase ms-2" aria-hidden="true"></i>
    </a>
  </div>
</div>
