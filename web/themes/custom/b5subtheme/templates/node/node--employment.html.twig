{#
/**
 * @file
 * Template for Employment content type (redesigned).
 *
 * Uses standard page layout with curved header and footer.
 * Includes JobPosting schema for Google Jobs rich results.
 *
 * Sections:
 * 1. Intro / Content Body
 * 2. Quick Facts
 * 3. Current Openings (Job Listings)
 * 4. Content Sections (For Attorneys, Support Staff, Why ILAS, etc.)
 * 5. Benefits Snapshot
 * 6. EEO Statement
 *
 * Available variables:
 * - content: Rendered content fields
 * - attributes: HTML attributes for the article element
 * - node: The node entity
 */
#}

{{ attach_library('b5subtheme/sticky-jobs-bar') }}

{# ========== JobPosting Schema (preserved from original) ========== #}
{% set job_postings = [] %}
{% for category in node.field_job_listings %}
  {% if category.entity %}
    {% for item_ref in category.entity.field_category_jobs %}
      {% if item_ref.entity and item_ref.entity.field_job_date_posted.value %}
        {% set job_item = item_ref.entity %}
        {% set job_posting = {
          '@type': 'JobPosting',
          'title': job_item.field_accordion_title.value,
          'description': job_item.field_accordion_body.value|striptags,
          'datePosted': job_item.field_job_date_posted.value,
          'hiringOrganization': {
            '@type': 'NGO',
            '@id': 'https://idaholegalaid.org/#organization',
            'name': 'Idaho Legal Aid Services',
            'sameAs': 'https://idaholegalaid.org',
            'logo': 'https://idaholegalaid.org/themes/custom/b5subtheme/logo.svg'
          },
          'jobLocationType': 'TELECOMMUTE',
          'applicantLocationRequirements': {
            '@type': 'State',
            'name': 'Idaho'
          }
        } %}

        {# Add optional fields if populated #}
        {% if job_item.field_job_valid_through.value %}
          {% set job_posting = job_posting|merge({'validThrough': job_item.field_job_valid_through.value}) %}
        {% endif %}

        {% if job_item.field_job_location.value %}
          {% set job_posting = job_posting|merge({
            'jobLocation': {
              '@type': 'Place',
              'address': {
                '@type': 'PostalAddress',
                'addressLocality': job_item.field_job_location.value,
                'addressRegion': 'ID',
                'addressCountry': 'US'
              }
            }
          }) %}
        {% endif %}

        {% if job_item.field_job_employment_type.value %}
          {% set job_posting = job_posting|merge({'employmentType': job_item.field_job_employment_type.value}) %}
        {% endif %}

        {% set job_postings = job_postings|merge([job_posting]) %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endfor %}

{# Output JobPosting schema if we have any job listings #}
{% if job_postings|length > 0 %}
<script type="application/ld+json">
{{ job_postings|json_encode(constant('JSON_UNESCAPED_SLASHES') b-or constant('JSON_PRETTY_PRINT'))|raw }}
</script>
{% endif %}

{# ========== Main Article ========== #}
<article{{ attributes.addClass('node', 'node--employment', 'employment-page') }}>
  <div class="container">

    {# ===== 1. INTRO SECTION ===== #}
    <section class="employment-page__intro">
      {% if content.field_main_content %}
        <div class="content-body">
          {{ content.field_main_content }}
        </div>
      {% endif %}

      {# View Open Positions CTA - observed by sticky bar JS #}
      <div class="employment-page__intro-cta text-center" id="intro-cta-trigger">
        <a href="#current-openings" class="btn btn-primary btn-lg">
          View Open Positions
          <i class="fas fa-arrow-down ms-2" aria-hidden="true"></i>
        </a>
      </div>
    </section>

  </div>{# End container for intro #}

  {# ===== 2. QUICK FACTS SECTION (full-bleed with curved gray background) ===== #}
  {% if content.field_quick_facts|render|trim %}
    <section class="employment-page__quick-facts-section">
      <div class="container">
        <h2 class="section-heading text-center">Statewide Reach. Local Impact.</h2>
        <div class="quick-facts-grid">
          {{ content.field_quick_facts }}
        </div>
      </div>
    </section>
  {% endif %}

  <div class="container">
    {# ===== 3. CURRENT OPENINGS ===== #}
    {% if content.field_job_listings|render|trim %}
      <section class="employment-page__listings" id="current-openings">
        {# Title #}
        {% if node.field_job_listings_title.value %}
          <h2 class="section-title text-center">{{ node.field_job_listings_title.value }}</h2>
        {% endif %}

        {# Jump Links Navigation #}
        {% if node.field_job_listings|length > 0 %}
        <nav class="employment-page__jump-nav" aria-label="Job categories">
          <ul class="jump-nav-list">
            {% for category in node.field_job_listings %}
              {% if category.entity %}
                <li>
                  <a href="#{{ category.entity.field_category_id.value }}" class="jump-nav-link">
                    {{ category.entity.field_category_name.value }}
                  </a>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </nav>
        {% endif %}

        {# Job listings accordion #}
        {{ content.field_job_listings }}
      </section>
    {% endif %}

    {# ===== 4. CONTENT SECTIONS ===== #}
    {% if content.field_content_sections|render|trim %}
      <div class="employment-page__sections">
        {{ content.field_content_sections }}
      </div>
    {% endif %}

    {# ===== 5. BENEFITS SNAPSHOT ===== #}
    {% if content.field_benefits_snapshot|render|trim %}
      <section class="employment-page__benefits" id="benefits">
        <h2 class="section-title text-center">Benefits Snapshot</h2>

        {% if node.field_benefits_disclaimer.value %}
          <p class="benefits-disclaimer">
            {{ node.field_benefits_disclaimer.value }}
          </p>
        {% endif %}

        <div class="benefits-grid">
          {{ content.field_benefits_snapshot }}
        </div>
      </section>
    {% endif %}

    {# ===== 6. EEO STATEMENT ===== #}
    {% if content.field_eeo_statement|render|trim %}
      <section class="employment-page__eeo">
        <h2 class="section-title">Equal Opportunity Employer</h2>
        <div class="content-body">
          {{ content.field_eeo_statement }}
        </div>
      </section>
    {% endif %}

  </div>{# End container #}
</article>

{# ===== STICKY CTA BAR ===== #}
{# Appears when intro CTA scrolls out of view, hides when job listings are in view #}
<div class="sticky-jobs-bar" id="sticky-jobs-bar" aria-hidden="true">
  <div class="sticky-jobs-bar__content">
    <span class="sticky-jobs-bar__text">Ready to join our team?</span>
    <a href="#current-openings" class="sticky-jobs-bar__cta">
      View Open Positions
      <i class="fas fa-briefcase ms-2" aria-hidden="true"></i>
    </a>
  </div>
</div>
