{#
/**
 * @file
 * Template for ADEPT Lesson content type.
 *
 * Displays interactive ADEPT autism education lessons from UC Davis MIND
 * Institute with mode-branching (embed, link-out, self-host), completion
 * tracking, and LearningResource structured data.
 *
 * Available variables:
 * - content: Rendered content fields
 * - ilas_adept.module_id: Module number (1 or 2)
 * - ilas_adept.lesson_id: Lesson number (0 = Introduction)
 * - ilas_adept.mode: Display mode (link, embed, self_host)
 * - ilas_adept.est_time: Estimated time in minutes
 * - ilas_adept.effective_url: Resolved URL (self-host or external)
 * - ilas_adept.prev: Previous lesson {url, title}
 * - ilas_adept.next: Next lesson {url, title}
 */
#}

{# ========== LearningResource Schema ========== #}
{% set current_page_url = url('<current>')|render|trim %}
{% set clean_title = label|render|striptags|trim %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LearningResource",
  "@id": "{{ current_page_url }}#learning-resource",
  "name": "{{ clean_title|e('html_attr') }}",
  "description": "{{ content.field_adept_short_desc|render|striptags|trim|slice(0, 200)|e('html_attr') }}",
  "provider": {
    "@type": "Organization",
    "@id": "https://idaholegalaid.org/#organization",
    "name": "Idaho Legal Aid Services"
  },
  "creator": {
    "@type": "Organization",
    "name": "UC Davis MIND Institute"
  },
  "educationalLevel": "Professional Development",
  "learningResourceType": "Interactive Module",
  "inLanguage": "en",
  "isPartOf": {
    "@type": "Course",
    "name": "ADEPT Module {{ ilas_adept.module_id }}"
  }{% if ilas_adept.est_time %},
  "timeRequired": "PT{{ ilas_adept.est_time }}M"{% endif %},
  "url": "{{ current_page_url }}"
}
</script>

<article{{ attributes.addClass('adept-lesson', 'adept-lesson--module-' ~ ilas_adept.module_id, 'adept-lesson--mode-' ~ ilas_adept.mode) }}
  data-adept-lesson-page
  data-adept-mode="{{ ilas_adept.mode }}"
  data-adept-title="{{ clean_title|e('html_attr') }}">

  {# Breadcrumb navigation #}
  <nav aria-label="{{ 'breadcrumb'|t }}" class="adept-breadcrumb mb-3">
    <h2 id="adept-breadcrumb" class="visually-hidden">{{ 'Breadcrumb'|t }}</h2>
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/education/adept">{{ 'ADEPT'|t }}</a></li>
      <li class="breadcrumb-item">
        <a href="/education/adept/module-{{ ilas_adept.module_id }}">{{ 'Module @num'|t({'@num': ilas_adept.module_id}) }}</a>
      </li>
      <li class="breadcrumb-item active" aria-current="page">
        {% if ilas_adept.lesson_id == 0 %}
          {{ 'Introduction'|t }}
        {% else %}
          {{ 'Lesson @num'|t({'@num': ilas_adept.lesson_id}) }}
        {% endif %}
      </li>
    </ol>
  </nav>

  {# Header #}
  <header class="adept-lesson__header mb-4">
    <h1 class="adept-lesson__title">{{ label }}</h1>
    <div class="adept-lesson__meta d-flex flex-wrap gap-2 mt-2">
      <span class="badge bg-primary adept-badge adept-badge--module">{{ 'Module @num'|t({'@num': ilas_adept.module_id}) }}</span>
      {% if ilas_adept.est_time %}
        <span class="badge adept-badge adept-badge--time">
          <i class="fa-regular fa-clock" aria-hidden="true"></i>
          {{ '~@min min'|t({'@min': ilas_adept.est_time}) }}
        </span>
      {% endif %}
      <span class="adept-completion-status badge bg-success adept-badge d-none">
        <i class="fa-solid fa-check" aria-hidden="true"></i>
        {{ 'Completed'|t }}
      </span>
    </div>
  </header>

  {# Description #}
  {% if content.field_adept_short_desc|render|trim %}
    <div class="adept-lesson__description mb-4">
      {{ content.field_adept_short_desc }}
    </div>
  {% endif %}

  {# Prerequisite gate — JS populates if prereqs unmet #}
  <div class="adept-prereq-alert alert alert-warning d-none"></div>

  {# Content area — mode dependent #}
  <div class="adept-lesson__content mb-4">
    {% if ilas_adept.mode == 'link' %}
      {# Link-out mode: opens in new tab #}
      <a href="{{ ilas_adept.effective_url }}"
         class="btn btn-primary btn-lg adept-start-lesson"
         data-adept-url="{{ ilas_adept.effective_url }}"
         target="_blank"
         rel="noopener noreferrer">
        <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
        {{ 'Start Lesson'|t }}
        <span class="visually-hidden">{{ '(opens in a new tab)'|t }}</span>
      </a>
      <p class="text-muted mt-2">
        <small>{{ 'Opens in a new tab on the UC Davis MIND Institute site.'|t }}</small>
      </p>

    {% elseif ilas_adept.mode == 'embed' or ilas_adept.mode == 'self_host' %}
      {# Embed / Self-host mode: JS injects iframe into container #}
      <button type="button"
              class="btn btn-primary btn-lg adept-start-lesson"
              data-adept-url="{{ ilas_adept.effective_url }}">
        <i class="fa-solid fa-play" aria-hidden="true"></i>
        {{ 'Start Lesson'|t }}
      </button>
      <div class="adept-embed-container d-none mt-3"
           role="region"
           aria-label="{{ 'ADEPT lesson content'|t }}"
           tabindex="-1">
        {# iframe injected by adept-tracking.js #}
      </div>
    {% endif %}
  </div>

  {# SR announcements for lesson state changes #}
  <div class="visually-hidden" role="status" aria-live="polite" aria-atomic="true" id="adept-lesson-status"></div>

  {# Mark Complete button (hidden until lesson started, disabled once completed) #}
  <div class="adept-lesson__actions mb-4">
    <button type="button"
            class="btn btn-primary adept-mark-complete d-none">
      <i class="fa-solid fa-check" aria-hidden="true"></i>
      {{ 'Mark as Complete'|t }}
    </button>
  </div>

  {# Downloads & Attachments #}
  {% set has_downloads = content.field_adept_downloads|render|trim %}
  {% set has_attachments = content.field_adept_attachments|render|trim %}
  {% if has_downloads or has_attachments %}
    <div class="adept-lesson__downloads mb-4">
      <h2>{{ 'Downloads & Resources'|t }}</h2>
      {% if has_downloads %}
        <div class="adept-download-link adept-downloads">
          {{ content.field_adept_downloads }}
        </div>
      {% endif %}
      {% if has_attachments %}
        <div class="adept-attachments">
          {{ content.field_adept_attachments }}
        </div>
      {% endif %}
    </div>
  {% endif %}

  {# Prev/Next navigation #}
  {% if ilas_adept.prev or ilas_adept.next %}
    <nav class="adept-lesson__nav d-flex justify-content-between mt-5 pt-4 border-top"
         aria-label="{{ 'Lesson navigation'|t }}">
      {% if ilas_adept.prev %}
        <a href="{{ ilas_adept.prev.url }}" class="btn adept-nav-btn"
           aria-label="{{ 'Previous: @title'|t({'@title': ilas_adept.prev.title}) }}">
          <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
          {{ ilas_adept.prev.short_title }}
        </a>
      {% else %}
        <span></span>
      {% endif %}
      {% if ilas_adept.next %}
        <a href="{{ ilas_adept.next.url }}" class="btn adept-nav-btn"
           aria-label="{{ 'Next: @title'|t({'@title': ilas_adept.next.title}) }}">
          {{ ilas_adept.next.short_title }}
          <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
        </a>
      {% endif %}
    </nav>
  {% endif %}

</article>
