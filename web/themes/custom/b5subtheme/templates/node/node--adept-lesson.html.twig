{#
/**
 * @file
 * Template for ADEPT Lesson content type.
 *
 * Displays interactive ADEPT autism education lessons from UC Davis MIND
 * Institute with mode-branching (embed, link-out, self-host), completion
 * tracking, and LearningResource structured data.
 *
 * Available variables:
 * - content: Rendered content fields
 * - adept_module_number: Module number (1 or 2)
 * - adept_lesson_number: Lesson number (0 = Introduction)
 * - adept_mode: Display mode (link, embed, self_host)
 * - adept_est_time: Estimated time in minutes
 * - adept_external_url: External URL for lesson content
 * - adept_self_host_url: Self-hosted URL (if applicable)
 * - adept_prev_lesson: Previous lesson {url, title}
 * - adept_next_lesson: Next lesson {url, title}
 */
#}

{{ attach_library('ilas_adept/tracking') }}

{# ========== LearningResource Schema ========== #}
{% set current_page_url = url('<current>')|render|trim %}
{% set clean_title = label|render|striptags|trim %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LearningResource",
  "@id": "{{ current_page_url }}#learning-resource",
  "name": "{{ clean_title|e('html_attr') }}",
  "description": "{{ content.field_adept_short_desc|render|striptags|trim|slice(0, 200)|e('html_attr') }}",
  "provider": {
    "@type": "Organization",
    "@id": "https://idaholegalaid.org/#organization",
    "name": "Idaho Legal Aid Services"
  },
  "creator": {
    "@type": "Organization",
    "name": "UC Davis MIND Institute"
  },
  "educationalLevel": "Professional Development",
  "learningResourceType": "Interactive Module",
  "inLanguage": "en",
  "isPartOf": {
    "@type": "Course",
    "name": "ADEPT Module {{ adept_module_number }}"
  }{% if adept_est_time %},
  "timeRequired": "PT{{ adept_est_time }}M"{% endif %},
  "url": "{{ current_page_url }}"
}
</script>

<article{{ attributes.addClass('adept-lesson', 'adept-lesson--module-' ~ adept_module_number, 'adept-lesson--mode-' ~ adept_mode) }}
  data-adept-module="{{ adept_module_number }}"
  data-adept-lesson="{{ adept_lesson_number }}"
  data-adept-mode="{{ adept_mode }}"
  data-adept-title="{{ clean_title|e('html_attr') }}">

  {# Breadcrumb navigation #}
  <nav aria-label="{{ 'ADEPT lesson breadcrumb'|t }}" class="adept-breadcrumb mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/education/adept">{{ 'ADEPT'|t }}</a></li>
      <li class="breadcrumb-item">
        <a href="/education/adept/module-{{ adept_module_number }}">{{ 'Module @num'|t({'@num': adept_module_number}) }}</a>
      </li>
      <li class="breadcrumb-item active" aria-current="page">
        {% if adept_lesson_number == 0 %}
          {{ 'Introduction'|t }}
        {% else %}
          {{ 'Lesson @num'|t({'@num': adept_lesson_number}) }}
        {% endif %}
      </li>
    </ol>
  </nav>

  {# Header #}
  <header class="adept-lesson__header mb-4">
    <h1 class="adept-lesson__title">{{ label }}</h1>
    <div class="adept-lesson__meta d-flex flex-wrap gap-2 mt-2">
      <span class="badge bg-primary">{{ 'Module @num'|t({'@num': adept_module_number}) }}</span>
      {% if adept_est_time %}
        <span class="badge bg-secondary">
          <i class="fa-regular fa-clock" aria-hidden="true"></i>
          {{ '~@min min'|t({'@min': adept_est_time}) }}
        </span>
      {% endif %}
      <span class="adept-completion-status badge bg-success d-none">
        <i class="fa-solid fa-check" aria-hidden="true"></i>
        {{ 'Completed'|t }}
      </span>
    </div>
  </header>

  {# Description #}
  {% if content.field_adept_short_desc|render|trim %}
    <div class="adept-lesson__description mb-4">
      {{ content.field_adept_short_desc }}
    </div>
  {% endif %}

  {# Content area — mode dependent #}
  <div class="adept-lesson__content mb-4">
    {% if adept_mode == 'link' %}
      {# Link-out mode: opens in new tab #}
      <a href="{{ adept_external_url }}"
         class="btn btn-primary btn-lg adept-start-lesson"
         data-adept-url="{{ adept_external_url }}"
         target="_blank"
         rel="noopener noreferrer">
        <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
        {{ 'Start Lesson'|t }}
      </a>
      <p class="text-muted mt-2">
        <small>{{ 'Opens in a new tab on the UC Davis MIND Institute site.'|t }}</small>
      </p>

    {% elseif adept_mode == 'embed' or adept_mode == 'self_host' %}
      {# Embed / Self-host mode: JS injects iframe into container #}
      {% set embed_url = (adept_mode == 'self_host' and adept_self_host_url) ? adept_self_host_url : adept_external_url %}
      <button type="button"
              class="btn btn-primary btn-lg adept-start-lesson"
              data-adept-url="{{ embed_url }}">
        <i class="fa-solid fa-play" aria-hidden="true"></i>
        {{ 'Start Lesson'|t }}
      </button>
      <div class="adept-embed-container d-none mt-3"
           role="region"
           aria-label="{{ 'ADEPT lesson content'|t }}">
        {# iframe injected by adept-tracking.js #}
      </div>
    {% endif %}
  </div>

  {# Mark Complete button (hidden until lesson started, disabled once completed) #}
  <div class="adept-lesson__actions mb-4">
    <button type="button"
            class="btn btn-outline-primary adept-mark-complete d-none">
      <i class="fa-solid fa-check" aria-hidden="true"></i>
      {{ 'Mark as Complete'|t }}
    </button>
  </div>

  {# Downloads #}
  {% if content.field_adept_downloads|render|trim %}
    <div class="adept-lesson__downloads mb-4">
      <h2>{{ 'Downloads & Resources'|t }}</h2>
      <div class="adept-download-link">
        {{ content.field_adept_downloads }}
      </div>
    </div>
  {% endif %}

  {# Prev/Next navigation #}
  {% if adept_prev_lesson or adept_next_lesson %}
    <nav class="adept-lesson__nav d-flex justify-content-between mt-5 pt-4 border-top"
         aria-label="{{ 'Lesson navigation'|t }}">
      {% if adept_prev_lesson %}
        <a href="{{ adept_prev_lesson.url }}" class="btn btn-outline-secondary">
          <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
          {{ adept_prev_lesson.title }}
        </a>
      {% else %}
        <span></span>
      {% endif %}
      {% if adept_next_lesson %}
        <a href="{{ adept_next_lesson.url }}" class="btn btn-outline-secondary">
          {{ adept_next_lesson.title }}
          <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
        </a>
      {% endif %}
    </nav>
  {% endif %}

</article>
