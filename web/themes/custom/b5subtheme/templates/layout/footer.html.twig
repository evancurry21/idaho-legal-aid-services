{#
/**
 * @file
 * Theme override for footer.
 */
#}

<footer class="site-footer" role="contentinfo">
  {# Upper Footer #}
  <div class="footer-upper-wrapper">
    <div class="container">
      <div class="row">
        
        {# Left Column: Legal Advice Hotline & Administrative Office #}
        <div class="col-md-4">
          <div class="footer-section">
            {# Legal Advice Hotline #}
            <div class="footer-contact-block">
              <h3 class="footer-heading">
                <a href="/legal-advice-line" class="footer-link">
                  {{ 'Legal Advice Hotline'|t }}
                </a>
              </h3>
              <p class="footer-contact">
                <a href="tel:+12087467541" class="footer-link" aria-label="Call 208-746-7541">
                  {{ '(208) 746-7541'|t }}
                </a>
              </p>
            </div>

            {# Administrative Office #}
            <div class="footer-contact-block footer-admin-office">
              <h3 class="footer-heading">{{ 'Administrative Office'|t }}</h3>
              <p class="footer-address">1447 S. Tyrell Lane</p>
              <p class="footer-address">Boise, ID 83706</p>
            </div>
          </div>
        </div>
        
        {# Middle Column: Offices #}
        <div class="col-md-4 text-center">
          <div class="footer-section">
            <h3 class="footer-heading">
              <a href="/locations" class="footer-link">{{ 'Offices'|t }}</a>
            </h3>
            <ul class="footer-links list-unstyled two-column-list">
              <li>
                <a href="/administrative-office" class="footer-link">
                  <span class="d-none d-md-inline">{{ 'Administrative Office'|t }}</span>
                  <span class="d-md-none">{{ 'Admin'|t }}</span>
                </a>
              </li>
              <li>
                <a href="/boise-office" class="footer-link">
                  <span class="d-none d-md-inline">{{ 'Boise Office'|t }}</span>
                  <span class="d-md-none">{{ 'Boise'|t }}</span>
                </a>
              </li>
              <li>
                <a href="/coeur-dalene-office" class="footer-link">
                  <span class="d-none d-md-inline">{{ "Coeur d'Alene Office"|t }}</span>
                  <span class="d-md-none">{{ "Coeur d'Alene"|t }}</span>
                </a>
              </li>
              <li>
                <a href="/idaho-falls-office" class="footer-link">
                  <span class="d-none d-md-inline">{{ 'Idaho Falls Office'|t }}</span>
                  <span class="d-md-none">{{ 'Idaho Falls'|t }}</span>
                </a>
              </li>
              <li>
                <a href="/lewiston-office" class="footer-link">
                  <span class="d-none d-md-inline">{{ 'Lewiston Office'|t }}</span>
                  <span class="d-md-none">{{ 'Lewiston'|t }}</span>
                </a>
              </li>
              <li>
                <a href="/nampa-office" class="footer-link">
                  <span class="d-none d-md-inline">{{ 'Nampa Office'|t }}</span>
                  <span class="d-md-none">{{ 'Nampa'|t }}</span>
                </a>
              </li>
              <li>
                <a href="/pocatello-office" class="footer-link">
                  <span class="d-none d-md-inline">{{ 'Pocatello Office'|t }}</span>
                  <span class="d-md-none">{{ 'Pocatello'|t }}</span>
                </a>
              </li>
              <li>
                <a href="/twin-falls-office" class="footer-link">
                  <span class="d-none d-md-inline">{{ 'Twin Falls Office'|t }}</span>
                  <span class="d-md-none">{{ 'Twin Falls'|t }}</span>
                </a>
              </li>
            </ul>
          </div>
        </div>
        
        {# Right Column: Connect With Us & Accreditations #}
        <div class="col-md-4 text-center">
          <div class="footer-section">
            {# Connect With Us #}
            <div class="footer-social-block">
              <h3 class="footer-heading">{{ 'Connect With Us'|t }}</h3>
              <div class="footer-social">
                <a href="https://facebook.com/IdahoLegalAid" 
                   aria-label="Facebook"
                   target="_blank"
                   rel="noopener noreferrer">
                  <i class="fab fa-facebook"></i>
                </a>
                <a href="https://www.linkedin.com/company/idaho-legal-aid-services-inc." 
                   aria-label="LinkedIn"
                   target="_blank"
                   rel="noopener noreferrer">
                  <i class="fab fa-linkedin"></i>
                </a>
                <a href="https://www.youtube.com/user/idaholegalaid/featured" 
                   aria-label="YouTube"
                   target="_blank"
                   rel="noopener noreferrer">
                  <i class="fab fa-youtube"></i>
                </a>
                <a href="https://www.instagram.com/idaholegalaid/" 
                   aria-label="Instagram"
                   target="_blank"
                   rel="noopener noreferrer">
                  <i class="fab fa-instagram"></i>
                </a>
                <a href="https://bsky.app/profile/idaholegalaid.bsky.social" 
                   aria-label="BlueSky"
                   target="_blank"
                   rel="noopener noreferrer">
                  <i class="fab fa-bluesky"></i>
                </a>
              </div>
            </div>
            
            {# Accreditations #}
            <div class="footer-accreditations-block footer-accreditations-section">
              <h3 class="footer-heading">{{ 'Accreditations'|t }}</h3>
              <div class="footer-accreditations">
                <a href="https://www.lsc.gov/grants/our-grantees/idaho-legal-aid-services-inc-program-profile" 
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Legal Services Corporation">
                  <img src="/themes/custom/b5subtheme/images/lsc-logo.jpg" 
                       alt="LSC Logo" 
                       class="accreditation-logo img-fluid">
                </a>
                <a href="https://charitynavigator.org/ein/820293641" 
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Charity Navigator Four-Star Rating">
                  <img src="https://charitynavigator.org/content/dam/cn/cn/badges/Four-StarRatingBadge-FullColor.png" 
                       alt="Charity Navigator Four-Star Rating" 
                       class="accreditation-logo img-fluid">
                </a>
                <a href="https://app.candid.org/profile/8230749" 
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Candid Transparency Seal">
                  <img src="https://widgets.guidestar.org/prod/v1/pdp/transparency-seal/8230749/svg" 
                       alt="Accreditation Seal" 
                       class="accreditation-logo img-fluid">
                </a>
              </div>
            </div>
          </div>
        </div>
        
      </div>
    </div>
  </div>
  
  {# Lower Footer #}
  <div class="footer-lower-wrapper">
    <div class="container">
      <div class="row">
        <div class="col text-center">
          <nav class="footer-legal-nav" aria-label="Legal policies">
            <a href="/privacy-policy">{{ 'Privacy Policy'|t }}</a>
            <span class="footer-separator">|</span>
            <a href="/complaint-procedures">
              <span class="d-none d-md-inline">{{ 'Client Grievance Procedure'|t }}</span>
              <span class="d-md-none">{{ 'Grievance Process'|t }}</span>
            </a>
            <span class="footer-separator">|</span>
            <a href="/nondiscrimination-policy">
              <span class="d-none d-md-inline">{{ 'Nondiscrimination Policy'|t }}</span>
              <span class="d-md-none">{{ 'Nondiscrimination'|t }}</span>
            </a>
          </nav>
        </div>
      </div>
    </div>
  </div>
</footer>