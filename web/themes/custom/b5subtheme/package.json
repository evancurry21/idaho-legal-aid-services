{
  "name": "b5subtheme",
  "version": "1.0.0",
  "description": "[Bootstrap 5](https://www.drupal.org/project/bootstrap5) subtheme.",
  "main": "index.js",
  "scripts": {
    "dev": "npx mix",
    "watch": "npx mix watch",
    "watch-poll": "npx mix watch -- --watch-options-poll=1000",
    "hot": "npx mix watch --hot",
    "prod": "npx mix --production && node scripts/strip-css-sourcemaps.js",
    "optimize-images": "node optimize-images.js",
    "check:critical": "test -s css/critical.css && grep -q 'site-header' css/critical.css && grep -q 'utility-bar' css/critical.css",
    "build": "npm run prod && npm run check:critical && npm run optimize-images",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^6.0.0",
    "bootswatch": "^5.3.6",
    "browser-sync": "^3.0.4",
    "browser-sync-webpack-plugin": "^2.4.0",
    "imagemin": "^9.0.1",
    "imagemin-cli": "^8.0.0",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "imagemin-svgo": "^11.0.1",
    "imagemin-webpack-plugin": "^2.4.2",
    "laravel-mix": "^6.0.49",
    "sass": "^1.89.2",
    "sass-loader": "^12.6.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "bootstrap": "^5.3.6"
  },
  "overrides": {
    "follow-redirects": "1.16.0",
    "fast-xml-parser": "4.5.5",
    "lodash": "4.18.1",
    "node-forge": "1.4.0",
    "picomatch": "2.3.2",
    "immutable": "3.8.3",
    "pbkdf2": "3.1.3",
    "sha.js": "2.4.12",
    "qs": "6.14.2",
    "js-yaml": "3.14.2",
    "on-headers": "1.1.0",
    "webpack": "5.104.1",
    "serialize-javascript": "7.0.5",
    "minimatch": "3.1.3",
    "@fullhuman/postcss-purgecss": { "minimatch": "9.0.7" },
    "imagemin-svgo": { "svgo": "3.3.3" },
    "postcss-svgo": { "svgo": "2.8.1" },
    "imagemin-cli": { "imagemin-svgo": { "svgo": "2.8.1" } }
  }
}
