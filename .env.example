# ILAS Payment Module - Secure Environment Variables
# Copy this file to .env and configure your secure API keys

# Stripe Configuration
STRIPE_TEST_SECRET_KEY=***REDACTED***
STRIPE_LIVE_SECRET_KEY=***REDACTED***
STRIPE_TEST_PUBLISHABLE_KEY=***REDACTED***
STRIPE_LIVE_PUBLISHABLE_KEY=***REDACTED***
STRIPE_TEST_WEBHOOK_SECRET=***REDACTED***
STRIPE_LIVE_WEBHOOK_SECRET=***REDACTED***

# PayPal Configuration
PAYPAL_BUSINESS_EMAIL=your-business@example.com

# Note: These environment variables provide the most secure way to store sensitive API keys.
# They take precedence over database configuration values.
# Alternative: Add to sites/default/settings.php as $settings['ilas_payment.stripe_live_secret_key'] = 'your_key_here';