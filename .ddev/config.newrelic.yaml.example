# Copy this file to .ddev/config.newrelic.yaml to opt into the local
# New Relic PHP agent scaffold. The overlay stays inactive until you:
#   1. copy .ddev/newrelic/Dockerfile.newrelic.example to
#      .ddev/web-build/Dockerfile.newrelic
#   2. provide NEW_RELIC_LICENSE_KEY and NEW_RELIC_APP_NAME locally
#   3. rebuild the web container with `ddev debug rebuild -s web`
#
# The repository keeps this as an example only so local DDEV remains unchanged
# unless an engineer explicitly opts in.

web_environment:
  - NEW_RELIC_APP_NAME=<PANTHEON_SITE_NAME>-local
  - NEW_RELIC_LICENSE_KEY=<NEW_RELIC_LICENSE_KEY>
  - NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true
  - NEW_RELIC_LOG_LEVEL=warning
