# Local observability example values.
# Copy the keys you need into .ddev/.env or .ddev/.env.local and restart DDEV.

SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_BROWSER_DSN=https://exampleBrowserKey@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=<SENTRY_AUTH_TOKEN>

PUBLIC_SITE_URL=https://<PUBLIC_SITE_URL>
ILAS_LOCAL_BROWSER_OBSERVABILITY=0

# Assistant runtime credentials and rollout toggles.
# Set these only in .ddev/.env or .ddev/.env.local, then restart DDEV.
ILAS_COHERE_API_KEY=<COHERE_API_KEY>
ILAS_LLM_ENABLED=0
ILAS_GEMINI_API_KEY=<GEMINI_API_KEY>
ILAS_PINECONE_API_KEY=<PINECONE_API_KEY>
ILAS_VECTOR_SEARCH_ENABLED=0
ILAS_LEGALSERVER_ONLINE_APPLICATION_URL=https://example.com/intake?pid=<PID>&h=<HASH>

# Voyage AI reranking credentials and rollout toggle.
ILAS_VOYAGE_API_KEY=<VOYAGE_API_KEY>
ILAS_VOYAGE_ENABLED=0

# Langfuse trace export credentials (US cloud).
# Enables runtime Langfuse tracing when both keys are present.
# See settings.php L471-484 for the secret-gated enablement pattern.
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Trusted proxy addresses for DDEV reverse proxy.
# Prevents flood-trust warnings from being logged on every assistant API request.
ILAS_TRUSTED_PROXY_ADDRESSES=172.0.0.0/8,127.0.0.1
