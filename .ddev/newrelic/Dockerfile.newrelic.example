## Copy this file to .ddev/web-build/Dockerfile.newrelic to opt into a local
## New Relic PHP agent install for DDEV. This file is intentionally kept out of
## .ddev/web-build by default so it cannot affect local containers unless an
## engineer explicitly enables it.
##
## This template is intentionally conservative: the agent is for local DDEV
## only. Pantheon already provides the hosted PHP agent path and must not use
## a Composer/PECL/APT install from this repository.
##
## Update the version below as needed when enabling it locally.

ARG BASE_IMAGE
FROM $BASE_IMAGE

RUN set -eux; \
  apt-get update; \
  apt-get install -y --no-install-recommends ca-certificates curl; \
  curl -fsSL https://download.newrelic.com/php_agent/release/newrelic-php5-10.18.0.9-linux.tar.gz -o /tmp/newrelic-php-agent.tar.gz; \
  tar -xzf /tmp/newrelic-php-agent.tar.gz -C /tmp; \
  NR_INSTALL_SILENT=1 NR_INSTALL_USE_CP_NOT_LN=1 /tmp/newrelic-php5-*/newrelic-install install; \
  rm -rf /var/lib/apt/lists/* /tmp/newrelic-php-agent.tar.gz /tmp/newrelic-php5-*

## Configure the generated newrelic.ini manually after enabling this template.
## Keep the agent disabled until NEW_RELIC_LICENSE_KEY and NEW_RELIC_APP_NAME
## are provided through local-only DDEV environment variables.
